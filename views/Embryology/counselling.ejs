<!doctype html>
<html
  lang="en"
  class="light-style layout-menu-fixed layout-compact"
  dir="ltr"
  data-theme="theme-default"
  data-assets-path="../assets/"
  data-template="vertical-menu-template-free"
  data-style="light"
>
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0"
    />
    <title><%= title %></title>
    <%- include('../header') -%>
  </head>
  <body>
<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <!-- PATIENT INFO -->
    <div class="mb-4 card">
      <div class="card-body">

        <div class="row align-items-center">

          <div class="col-md-4">
            <strong>Couple No.</strong><br>
            <small>Referred By: SFDKJ</small>
          </div>

          <div class="col-md-4 text-center">
            <i class="bx bx-user fs-2"></i><br>
            <strong>LAKSHAY CHAUDHARY, MRN: MR_33</strong><br>
            <small>Age: 23 Y, 0 M, 22 D Male</small>
          </div>

          <div class="col-md-4 text-end">
            <i class="bx bx-user fs-2"></i><br>
            <strong>FIRS</strong><br>
            <small>Age: 0 Y, 0 M, 0 D</small>
          </div>

        </div>

      </div>
    </div>

    <!-- COUNSELLING -->
    <div class="mb-4 card">

      <div class="card-header">
        <h5 class="mb-0">Counselling</h5>
      </div>

      <div class="card-body">

        <!-- ASSIGN TEAM -->
        <h6 class="mb-3">Assign Team</h6>

        <table class="table table-bordered">
          <thead>
            <tr>
              <th>Staff Designation</th>
              <th>Staff</th>
            </tr>
          </thead>

          <tbody>
            <tr>
              <td>Doctor</td>
              <td><select class="form-control"><option>Select</option></select></td>
            </tr>
            <tr>
              <td>Assistant Doctor</td>
              <td><select class="form-control"><option>Select</option></select></td>
            </tr>
            <tr>
              <td>Counsellor</td>
              <td><select class="form-control"><option>Select</option></select></td>
            </tr>
            <tr>
              <td>Coordinator</td>
              <td><select class="form-control"><option>Select</option></select></td>
            </tr>
          </tbody>
        </table>

      </div>

    </div>

    <!-- CLINICAL COUNSELLING -->
    <div class="mb-4 card">

      <div class="card-header">
        <h6 class="mb-0">Clinical Counselling</h6>
      </div>

      <div class="card-body row">

        <div class="col-md-6">
          <label class="form-label">Done By</label>
          <select class="form-control">
            <option>Select</option>
          </select>
        </div>

        <div class="col-md-6">
          <label class="form-label">Date</label>
          <input type="date" class="form-control">
        </div>

      </div>

    </div>

    <!-- FINANCIAL COUNSELLING -->
    <div class="mb-4 card">

      <div class="card-header">
        <h6 class="mb-0">Financial Counselling</h6>
      </div>

      <div class="card-body row">

        <div class="col-md-6">
          <label class="form-label">Done By</label>
          <select class="form-control">
            <option>Select</option>
          </select>
        </div>

        <div class="col-md-6">
          <label class="form-label">Date</label>
          <input type="date" class="form-control">
        </div>

      </div>

    </div>

    <!-- NOTES -->
    <div class="mb-4 card">

      <div class="card-header">
        <h6 class="mb-0">Notes</h6>
      </div>

      <div class="card-body">

        <table class="table table-bordered">

          <thead>
            <tr>
              <th>Date</th>
              <th>Note</th>
              <th>Recorded By</th>
            </tr>
          </thead>

          <tbody class="Notes-Info-Divs">

            <tr>
              <td><input type="date" class="form-control"></td>
              <td><input type="text" class="form-control"></td>
              <td><input type="text" class="form-control"></td>
            </tr>

          </tbody>

        </table>

      </div>

    </div>

    <!-- PACKAGE -->
    <div class="mb-4 card">

      <div class="card-header">
        <h6 class="mb-0">Choose the Package</h6>
      </div>

      <div class="card-body">

        <div class="row align-items-end">

          <div class="col-md-6">
            <label class="form-label">Choose the Package</label>
            <select class="form-control">
              <option>Select</option>
            </select>
          </div>

          <div class="col-md-6 text-end">
            <button class="btn btn-primary">Save</button>
          </div>

        </div>

      </div>

    </div>

  </div>
</div>
    <%- include('../footer') -%>
  </body>
</html>
