          </div>
        </div>

        <!-- Obstetric History -->
        <h6 class="text-success">Obstetric History</h6>
        <div class="mb-3 table-responsive">
          <table class="table table-bordered" id="obstetricHistoryTable">
            <thead>
              <tr>
                <th>Sl.No</th>
                <th>Year of Pregnancy</th>
                <th>Conception</th>
                <th>Abortion</th>
