<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <div class="mb-4 card">

      <div class="justify-content-between align-items-center card-header d-flex">
        <h5 class="mb-0 card-title">Infertility History</h5>
        <button onclick="toggleSection()" style="border:none; background:none; cursor:pointer;">
      ▼
    </button>
      </div>
<script>
  function toggleSection() {
    const div = document.getElementById("tobeclosed");

    if (div.style.display === "none") {
      div.style.display = "block";
    } else {
      div.style.display = "none";
    }
  }
</script>
      <div class="card-body" style="display: none;" id="tobeclosed">

        <!-- Chief Complaints -->
        <div class="mb-3">
          <label for="chiefComplaintSelect" class="form-label">Chief Complaints</label>
          <select id="chiefComplaintSelect" class="form-select">
            <option value="primary">Primary(Same Partner)</option>
            <option value="secondary">Secondary</option>
            <option value="other">Other</option>
          </select>
        </div>

        <!-- Vitals -->
        <h6 class="mb-3 text-success">General History - Vitals</h6>
