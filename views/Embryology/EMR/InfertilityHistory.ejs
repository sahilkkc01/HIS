            </div>
            <div class="form-check form-check-inline">
              <input type="radio" id="mhPainless" name="menstrualPain" class="form-check-input" value="Painless" />
              <label class="form-check-label" for="mhPainless">Painless</label>
            </div>
            <div class="form-check form-check-inline">
              <input type="radio" id="mhPainfull" name="menstrualPain" class="form-check-input" value="Painfull" />
              <label class="form-check-label" for="mhPainfull">Painfull</label>
            </div>
            <div class="form-check form-check-inline">
              <input type="radio" id="mhNFlow" name="menstrualFlowType" class="form-check-input" value="N flow" />
