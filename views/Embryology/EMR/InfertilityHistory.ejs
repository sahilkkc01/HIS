        <!-- Comments -->
        <div class="mb-3">
          <textarea class="form-control" rows="2" maxlength="2000" placeholder="Comment"></textarea>
        </div>

        <!-- Menstrual History -->
        <h6 class="text-success">Menstrual History</h6>
        <div class="mb-3 align-items-center row g-3">
          <div class="col-md-3">
            <label class="form-label" for="lmpDate">LMP</label>
            <input type="date" id="lmpDate" class="form-control" />
          </div>
