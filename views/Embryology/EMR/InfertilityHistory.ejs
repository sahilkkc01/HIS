              </tr>
            </thead>
            <tbody>
              <tr>
                <td><input type="date" class="form-control"></td>
                <td><input type="text" class="form-control"></td>
                <td><input type="text" class="form-control"></td>
                <td><input type="text" class="form-control"></td>
                <td>
                  <button class="btn btn-primary btn-sm add-investigation-row">
                    <i class="bx bx-plus"></i>
                  </button>
                  <button class="btn btn-danger btn-sm remove-investigation-row">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Partner History -->
        <h6 class="text-success">Partner History</h6>
        <div>
          <textarea class="form-control" rows="3" maxlength="2000" placeholder="Partner history details..."></textarea>
        </div>

      </div>

    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
  // Calculate BMI automatically (weight / height^2)
  $('#height, #weight').on('input', function() {
    let heightM = parseFloat($('#height').val()) / 100;
    let weightKg = parseFloat($('#weight').val());
    if (heightM > 0 && weightKg > 0) {
      let bmi = weightKg / (heightM * heightM);
      $('#bmi').val(bmi.toFixed(2));
    } else {
      $('#bmi').val('');
    }
  });

  // Treatment History Add Row
  $('#addTreatmentRow').on('click', function() {
    let rowCount = $('#treatmentHistoryBody tr').length + 1;
    let newRow = `
      <tr>
        <td>${rowCount}</td>
        <td><input type="text" class="form-control"></td>
        <td><input type="text" class="form-control"></td>
        <td><input type="date" class="form-control"></td>
        <td><input type="text" class="form-control"></td>
        <td>
          <button class="btn btn-danger btn-sm remove-treatment-row">
            <i class="fa-solid fa-trash"></i>
          </button>
        </td>
      </tr>
    `;
    $('#treatmentHistoryBody').append(newRow);
  });

  // Remove Treatment Row
  $(document).on('click', '.remove-treatment-row', function() {
    $(this).closest('tr').remove();
    // Re-index S.No
    $('#treatmentHistoryBody tr').each(function(index) {
      $(this).find('td:first').text(index + 1);
    });
  });

  // Obstetric History Add Row
  $('#addObstetricRow').on('click', function() {
    let tbody = $('#obstetricHistoryTable tbody');
    let rowCount = tbody.find('tr').length + 1;
    let newRow = `
      <tr>
        <td>${rowCount}</td>
        <td><input type="text" class="form-control"></td>
        <td>
          <select class="form-select">
            <option>Natural</option>
            <option>Assisted</option>
            <option>Other</option>
          </select>
        </td>
        <td>
          <select class="form-select">
            <option>Yes</option>
            <option>No</option>
          </select>
        </td>
        <td>
          <select class="form-select">
            <option>Vaginal</option>
            <option>Cesarean</option>
            <option>Other</option>
          </select>
        </td>
        <td><input type="text" class="form-control"></td>
        <td><input type="text" class="form-control"></td>
        <td><input type="text" class="form-control"></td>
        <td>
          <button class="btn btn-danger btn-sm remove-obstetric-row">
            <i class="fa-solid fa-trash"></i>
          </button>
        </td>
      </tr>
    `;
    tbody.append(newRow);
  });

  // Remove Obstetric Row
  $(document).on('click', '.remove-obstetric-row', function() {
    $(this).closest('tr').remove();
    // Re-index S.No
    $('#obstetricHistoryTable tbody tr').each(function(index) {
      $(this).find('td:first').text(index + 1);
    });
  });

  // Past Infertility Investigations: Add Row
  $(document).on('click', '.add-investigation-row', function() {
    let tbody = $('#infertilityInvestigationsTable tbody');
    let newRow = `
      <tr>
        <td><input type="date" class="form-control"></td>
        <td><input type="text" class="form-control"></td>
        <td><input type="text" class="form-control"></td>
        <td><input type="text" class="form-control"></td>
        <td>
          <button class="btn btn-primary btn-sm add-investigation-row">
            <i class="bx bx-plus"></i>
          </button>
          <button class="btn btn-danger btn-sm remove-investigation-row">
            <i class="fa-solid fa-trash"></i>
          </button>
        </td>
      </tr>
    `;
    tbody.append(newRow);
  });
// Add Row
$(document).on('click', '.add-row', function () {
  let row = `
    <tr>
      <td><input type="date" class="form-control"></td>
      <td><input type="text" class="form-control"></td>
      <td><input type="text" class="form-control"></td>
      <td><input type="text" class="form-control"></td>
      <td class="text-center">
        <button class="btn btn-primary btn-sm add-row">
          <i class="bx bx-plus"></i>
        </button>
        <button class="btn btn-danger btn-sm remove-row">
          <i class="fa-solid fa-trash"></i>
        </button>
      </td>
    </tr>
  `;
  $('#partnerInvestigationsTable tbody').append(row);
});

// Remove Row
$(document).on('click', '.remove-row', function () {
  $(this).closest('tr').remove();
});
  // Remove Past Infertility Investigation Row
  $(document).on('click', '.remove-investigation-row', function() {
    $(this).closest('tr').remove();
  });
</script>

