                </td>
                <td>
                  <select class="form-select">
                    <option>Yes</option>
                    <option>No</option>
                  </select>
                </td>
                <td>
                  <select class="form-select">
                    <option>Vaginal</option>
                    <option>Cesarean</option>
                    <option>Other</option>
                  </select>
                </td>
                <td><input type="text" class="form-control"></td>
                <td><input type="text" class="form-control"></td>
                <td><input type="text" class="form-control"></td>
                <td>
                  <button class="btn btn-danger btn-sm remove-obstetric-row">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </td>
              </tr>
            </tbody>
          </table>
          <button id="addObstetricRow" class="btn btn-primary btn-sm">
            <i class="bx bx-plus me-1"></i> Add Row
          </button>
        </div>

        <!-- Recurrent Pregnancy Loss Toggle -->
        <div class="mb-3 form-check form-switch">
          <input class="form-check-input" type="checkbox" id="recurrentPregnancyLoss">
          <label class="form-check-label" for="recurrentPregnancyLoss">Recurrent Pregnancy Loss</label>
        </div>

        <!-- Past Infertility Investigations -->
        <h6 class="text-success">Past Infertility Investigations</h6>
        <div class="mb-3 table-responsive">
          <table class="table table-bordered" id="infertilityInvestigationsTable">
            <thead>
              <tr>
                <th>Date</th>
                <th>Place</th>
