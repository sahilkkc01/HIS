          </div>
        </div>

        <!-- Duration of infertility -->
        <div class="mb-4 row g-3">
          <label class="form-label">Duration of infertility:</label>
          <div class="col-md-3">
            <input type="number" class="form-control" placeholder="Years" id="durationYears">
          </div>
          <div class="col-md-3">
            <input type="number" class="form-control" placeholder="Months" id="durationMonths">
          </div>
        </div>

        <!-- OI/TI, IVF, IUI -->
        <div class="mb-4 row g-3">
          <div class="col-md-4">
            <input type="text" class="form-control" placeholder="OI/TI" id="oiTi">
          </div>
          <div class="col-md-4">
            <input type="text" class="form-control" placeholder="IVF" id="ivf">
          </div>
          <div class="col-md-4">
            <input type="text" class="form-control" placeholder="IUI" id="iui">
          </div>
        </div>

        <!-- Treatment History Table -->
        <h6>Treatment History</h6>
        <div class="mb-3 table-responsive">
