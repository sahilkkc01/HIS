          <div class="col-md-3">
            <input type="number" class="form-control" placeholder="Weight (kg)" id="weight">
          </div>
          <div class="col-md-3">
            <input type="text" class="form-control" placeholder="BMI" id="bmi" readonly>
          </div>
          <div class="col-md-3">
            <input type="number" class="form-control" placeholder="Pulse (BPM)" id="pulse">
          </div>
        </div>

        <div class="mb-4 row g-3">
          <div class="col-md-3">
            <input type="text" class="form-control" placeholder="Systolic" id="bpSystolic">
          </div>
          <div class="col-md-3">
            <input type="text" class="form-control" placeholder="Diastolic" id="bpDiastolic">
          </div>
          <div class="col-md-2">
            <input type="text" class="form-control" placeholder="Gravida" id="gravida">
          </div>
          <div class="col-md-2">
