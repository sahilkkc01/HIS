          </div>
        </div>

        <!-- Family History -->
        <div class="mb-3">
          <label class="form-label">Family History</label>
          <div>
            <div class="form-check form-check-inline">
              <input type="radio" id="familyYes" name="familyHistory" class="form-check-input" value="Yes" />
              <label class="form-check-label" for="familyYes">Yes</label>
            </div>
            <div class="form-check form-check-inline">
              <input type="radio" id="familyNo" name="familyHistory" class="form-check-input" value="No" />
