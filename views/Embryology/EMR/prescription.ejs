<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <div class="mb-4 card">

      <!-- Header -->
      <div class="justify-content-between align-items-center card-header d-flex">
        <h5 class="mb-0 card-title">Prescription</h5>

        <div class="d-flex gap-2">
          <button type="button" id="addPrescription" class="btn btn-primary">
            <i class="bx bx-plus me-1"></i> Add
          </button>

          <button type="button" id="printPrescription" class="btn btn-success">
            <i class="bx bx-printer me-1"></i> Print
          </button>
        </div>
      </div>

      <!-- Body -->
      <div class="card-body">

        <!-- Table -->
        <div class="table-responsive">
          <table class="table table-bordered align-middle">

            <thead>
              <tr>
                <th>Drug/Molecule</th>
                <th>Dose</th>
                <th>Frequency</th>
                <th>Days</th>
                <th style="width:100px;">Action</th>
              </tr>
            </thead>

            <tbody class="Prescription-Info-Divs">

              <!-- Default Row -->
              <tr class="prescription-row">

                <td>
                  <input type="text" class="form-control" placeholder="Type to search...">
                </td>

                <td>
                  <input type="text" class="form-control" placeholder="Dose">
                </td>

                <td>
                  <select class="form-control">
                    <option>TID (Three Times a Day)</option>
                    <option>BID (Twice a Day)</option>
                    <option>OD (Once a Day)</option>
                  </select>
                </td>

                <td>
                  <input type="text" class="form-control" placeholder="Days">
                </td>

                <td class="text-center">
                  <button class="btn btn-danger btn-sm remove-prescription">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </td>

              </tr>

            </tbody>

          </table>
        </div>

        <!-- Comment -->
        <div class="mt-3">
          <input type="text" class="form-control" placeholder="Comment">
        </div>

      </div>

    </div>

  </div>
</div>

<script>
  $(document).ready(function () {

  // ADD ROW
  $('#addPrescription').on('click', function () {

    let row = `
      <tr class="prescription-row">

        <td>
          <input type="text" class="form-control" placeholder="Type to search...">
        </td>

        <td>
          <input type="text" class="form-control" placeholder="Dose">
        </td>

        <td>
          <select class="form-control">
            <option>TID (Three Times a Day)</option>
            <option>BID (Twice a Day)</option>
            <option>OD (Once a Day)</option>
          </select>
        </td>

        <td>
          <input type="text" class="form-control" placeholder="Days">
        </td>

        <td class="text-center">
          <button class="btn btn-danger btn-sm remove-prescription">
            <i class="fa-solid fa-trash"></i>
          </button>
        </td>

      </tr>
    `;

    $('.Prescription-Info-Divs').append(row);
  });

  // REMOVE ROW
  $(document).on('click', '.remove-prescription', function () {
    $(this).closest('tr').remove();
  });

});
</script>