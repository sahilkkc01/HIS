<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <div class="mb-4 card">

      <!-- Header -->
      <div class="justify-content-between align-items-center card-header d-flex">
        <h5 class="mb-0 card-title">Chief Complaint</h5>

        <button
          type="button"
          id="addChiefComplaint"
          class="btn btn-primary"
        >
          <i class="bx bx-plus me-1"></i> Add
        </button>
      </div>

      <!-- Body -->
      <div class="card-body">

        <div class="ChiefComplaint-Info-Divs">
          <!-- dynamic rows -->
        </div>

      </div>

    </div>

  </div>
</div>
<script>

function addChiefComplaintEntry() {

  const newRow = $("<div>", {
    class: "chief-entry border rounded p-3 mb-3"
  });

  newRow.html(`

    <div class="row mb-2">
      <div class="col-md-12">
        <label class="form-label">Complaint Description</label>
        <textarea class="form-control complaint-description" rows="2"></textarea>
      </div>
    </div>

    <div class="row mb-2">

      <div class="col-md-6">
        <label class="form-label">Duration</label>
        <input type="text" class="form-control complaint-duration" placeholder="e.g. 2 weeks">
      </div>

      <div class="col-md-6">
        <label class="form-label">Severity</label>
        <select class="form-select complaint-severity">
          <option value="">Select</option>
          <option value="mild">Mild</option>
          <option value="moderate">Moderate</option>
          <option value="severe">Severe</option>
        </select>
      </div>

    </div>

    <div class="row mb-2">

      <div class="col-md-6">
        <label class="form-label">Onset</label>
        <input type="date" class="form-control complaint-onset">
      </div>

      <div class="col-md-6">
        <label class="form-label">Status</label>
        <select class="form-select complaint-status">
          <option value="">Select</option>
          <option value="active">Active</option>
          <option value="resolved">Resolved</option>
          <option value="improving">Improving</option>
          <option value="worsening">Worsening</option>
        </select>
      </div>

    </div>

    <div class="text-end">
      <button type="button" class="btn btn-sm btn-danger delete-chief">
        <i class="fa-solid fa-trash"></i> 
      </button>
    </div>

  `);

  $(".ChiefComplaint-Info-Divs").append(newRow);

}


// Add new row
$("#addChiefComplaint").click(function () {
  addChiefComplaintEntry();
});


// Delete row (works for dynamic elements)
$(document).on("click", ".delete-chief", function () {
  $(this).closest(".chief-entry").remove();
});



</script>