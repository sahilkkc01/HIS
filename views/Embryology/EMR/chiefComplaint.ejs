<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <div class="mb-4 card">

      <div class="justify-content-between align-items-center card-header d-flex">
        <h5 class="mb-0 card-title">Chief Complaint</h5>

        <button
          type="button"
          id="addChiefComplaint"
          class="btn btn-primary"
        >
          <i class="bx bx-plus me-1"></i> Add
        </button>
      </div>

      <div class="card-body">

        <div class="chief-complaint-form">

          <div class="mb-3 row">
            <div class="col-md-12">
              <label for="complaintDescription" class="form-label">
                Complaint Description
              </label>
              <textarea
                class="form-control"
                id="complaintDescription"
                rows="4"
                placeholder="Describe the chief complaint..."
              ></textarea>
            </div>
          </div>

          <div class="mb-3 row">

            <div class="col-md-6">
              <label for="complaintDuration" class="form-label">
                Duration
              </label>
              <input
                type="text"
                class="form-control"
                id="complaintDuration"
                placeholder="e.g., 2 weeks, 3 months"
              />
            </div>

            <div class="col-md-6">
              <label for="complaintSeverity" class="form-label">
                Severity
              </label>
              <select class="form-select" id="complaintSeverity">
                <option value="">Select Severity</option>
                <option value="mild">Mild</option>
                <option value="moderate">Moderate</option>
                <option value="severe">Severe</option>
                <option value="very-severe">Very Severe</option>
              </select>
            </div>

          </div>

          <div class="mb-3 row">

            <div class="col-md-6">
              <label for="complaintOnset" class="form-label">
                Onset
              </label>
              <input
                type="date"
                class="form-control"
                id="complaintOnset"
              />
            </div>

            <div class="col-md-6">
              <label for="complaintStatus" class="form-label">
                Status
              </label>
              <select class="form-select" id="complaintStatus">
                <option value="">Select Status</option>
                <option value="active">Active</option>
                <option value="resolved">Resolved</option>
                <option value="improving">Improving</option>
                <option value="worsening">Worsening</option>
              </select>
            </div>

          </div>

          <div class="mb-4">
            <button
              type="button"
              class="btn btn-primary"
              id="saveChiefComplaint"
            >
              Save Chief Complaint
            </button>

            <button
              type="button"
              class="btn btn-secondary ms-2"
              id="cancelChiefComplaint"
            >
              Cancel
            </button>
          </div>

        </div>


        <div class="chief-complaint-list">

          <h6 class="mb-3">Existing Chief Complaints</h6>

          <div class="text-nowrap table-responsive">

            <table class="table table-bordered">

              <thead>
                <tr>
                  <th>Complaint</th>
                  <th>Duration</th>
                  <th>Severity</th>
                  <th>Onset</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>

              <tbody id="chiefComplaintTableBody">
                <!-- Data will come here -->
              </tbody>

            </table>

          </div>

        </div>

      </div>
    </div>

  </div>
</div>