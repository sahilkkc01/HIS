<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <div class="mb-4 card">

      <!-- Header -->
      <div class="justify-content-between align-items-center card-header d-flex">
        <h5 class="mb-0 card-title">Service Advice</h5>

        <button type="button" id="addServiceAdvice" class="btn btn-primary">
          <i class="bx bx-plus me-1"></i> Add
        </button>
      </div>

      <!-- Body -->
      <div class="card-body">

        <!-- Dynamic Container -->
        <div class="ServiceAdvice-Info-Divs">

          <!-- Default Row -->
          <div class="row align-items-center mb-2 advice-row">

            <div class="col-md-10">
              <select class="form-control">
                <option>Anti TPO</option>
                <option>TSH</option>
                <option>AMH</option>
                <option>FSH</option>
              </select>
            </div>

            <div class="col-md-2 d-flex justify-content-end gap-2">
              <button class="btn btn-danger btn-sm remove-advice">
                <i class="fa-solid fa-trash"></i>
              </button>
            </div>

          </div>

        </div>

      </div>

    </div>

  </div>
</div>
<script>
  $(document).ready(function () {

  // ADD ROW
  $('#addServiceAdvice').on('click', function () {

    let row = `
      <div class="row align-items-center mb-2 advice-row">

        <div class="col-md-10">
          <select class="form-control">
            <option>Anti TPO</option>
            <option>TSH</option>
            <option>AMH</option>
            <option>FSH</option>
          </select>
        </div>

        <div class="col-md-2 d-flex justify-content-end gap-2">
          <button class="btn btn-danger btn-sm remove-advice">
            <i class="fa-solid fa-trash"></i>
          </button>
        </div>

      </div>
    `;

    $('.ServiceAdvice-Info-Divs').append(row);
  });

  // REMOVE ROW
  $(document).on('click', '.remove-advice', function () {
    $(this).closest('.advice-row').remove();
  });

});
</script>