<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <div class="mb-4 card">

      <!-- Header -->
      <div class="justify-content-between align-items-center card-header d-flex">
        <h5 class="mb-0 card-title">Doctor Notes</h5>

        <button type="button" id="addDoctorNote" class="btn btn-primary">
          <i class="bx bx-plus me-1"></i> Add
        </button>
      </div>

      <div class="card-body">

        <!-- Notes Container -->
        <div id="notesContainer">

          <!-- SINGLE ROW -->
          <div class="row align-items-center mb-2 note-row">

            <!-- Notes Input -->
            <div class="col-md-8">
              <input type="text" class="form-control" placeholder="Notes">
            </div>

            <!-- Confidential Toggle -->
            <div class="col-md-3 d-flex align-items-center gap-2">
              <div class="form-check form-switch m-0">
                <input class="form-check-input" type="checkbox">
              </div>
              <label class="mb-0">Confidential</label>
            </div>

            <!-- Delete Button -->
            <div class="col-md-1 text-end">
              <button class="btn btn-danger btn-sm remove-note">
                <i class="fa-solid fa-trash"></i>
              </button>
            </div>

          </div>

        </div>

      </div>

    </div>

  </div>
</div>
<script>
  $(document).ready(function () {

  // ADD NEW ROW
  $('#addDoctorNote').on('click', function () {

    let newRow = `
      <div class="row align-items-center mb-2 note-row">

        <div class="col-md-8">
          <input type="text" class="form-control" placeholder="Notes">
        </div>

        <div class="col-md-3 d-flex align-items-center gap-2">
          <div class="form-check form-switch m-0">
            <input class="form-check-input" type="checkbox">
          </div>
          <label class="mb-0">Confidential</label>
        </div>

        <div class="col-md-1 text-end">
          <button class="btn btn-danger btn-sm remove-note">
            <i class="fa-solid fa-trash"></i>
          </button>
        </div>

      </div>
    `;

    $('#notesContainer').append(newRow);
  });

  // REMOVE ROW
  $(document).on('click', '.remove-note', function () {
    $(this).closest('.note-row').remove();
  });

});
</script>