<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Pre Existing Conditions</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css"/>
  <style>
    body { background: #f4f6fb; }

    /* Card header — light blue like the screenshot */
    .pec-header {
      background: #e0f4f4;
      border-bottom: 1px solid #b2dfdb;
      padding: 10px 16px;
    }

    /* Accordion chevron */
    .accordion-icon { transition: transform .2s ease; display: inline-block; }
    .accordion-icon.open { transform: rotate(90deg); }

    /* Each condition row */
    .condition-row {
      border-bottom: 1px solid #e9ecef;
      padding: 10px 0;
    }
    .condition-row:last-child { border-bottom: none; }

    /* Underline-only inputs (EMR style) */
    .input-underline {
      border: none;
      border-bottom: 1px solid #adb5bd;
      border-radius: 0;
      background: transparent;
      padding: 2px 4px;
      outline: none;
      box-shadow: none !important;
      width: 100%;
      font-size: 0.9rem;
    }
    .input-underline:focus {
      border-bottom: 2px solid #17a2b8;
      background: transparent;
    }
    .input-underline::placeholder { color: #adb5bd; font-size: 0.85rem; }

    /* Form label */
    .emr-label {
      font-size: 0.78rem;
      color: #6c757d;
      margin-bottom: 2px;
      display: block;
    }

    /* Star button */
    .btn-star {
      background: #17a2b8;
      border: none;
      color: #fff;
      width: 34px;
      height: 34px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      cursor: pointer;
      transition: background .15s;
    }
    .btn-star.starred { background: #f0a500; }
    .btn-star:hover { opacity: .85; }

    /* Delete button */
    .btn-del {
      background: #dc3545;
      border: none;
      color: #fff;
      width: 34px;
      height: 34px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      cursor: pointer;
      transition: background .15s;
    }
    .btn-del:hover { background: #b02a37; }

    /* Add button */
    .btn-add {
      background: #17a2b8;
      color: #fff;
      border: none;
      font-size: 0.85rem;
      padding: 6px 14px;
      border-radius: 6px;
      font-weight: 500;
    }
    .btn-add:hover { background: #138496; }

    /* Title */
    .pec-title {
      color: #17a2b8;
      font-size: 0.95rem;
      font-weight: 600;
      margin: 0;
    }

    /* Toggle cursor */
    .toggle-area { cursor: pointer; }
  </style>
</head>
<body>
<div class="container-fluid py-4" style="max-width: 900px;">
  <div class="card shadow-sm border-0">

    <!-- Card Header -->
    <div class="pec-header d-flex align-items-center justify-content-between">
      <div class="d-flex align-items-center toggle-area" id="pecToggle">
        <i class="bx bx-chevron-right accordion-icon open fs-5 text-secondary me-1"></i>
        <span class="pec-title">Pre Existing Conditions</span>
      </div>
      <button class="btn-add" id="btnAdd">
        <i class="bx bx-plus"></i> Add
      </button>
    </div>

    <!-- Card Body -->
    <div class="card-body px-3 py-2" id="pecBody">

      <!-- Header Row (column labels) -->
      <div class="row align-items-end g-2 mb-1 d-none" id="colHeaders">
        <div class="col-5">
          <span class="emr-label" style="font-size:0.82rem; font-weight:600; color:#495057;">Conditions</span>
        </div>
        <div class="col-4">
          <span class="emr-label" style="font-size:0.82rem; font-weight:600; color:#495057;">Since</span>
        </div>
        <div class="col-3"></div>
      </div>

      <!-- Conditions Container -->
      <div id="conditionsContainer">
        <!-- Empty State -->
        <div class="text-center text-muted py-4" id="emptyMsg">
          <i class="bx bx-folder-open fs-4 me-1"></i>
          No pre-existing conditions added yet. Click <strong>Add</strong> to begin.
        </div>
      </div>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>
  let count = 0;

  // Accordion toggle
  $('#pecToggle').on('click', function () {
    $('#pecBody').slideToggle(200);
    $('#pecToggle .accordion-icon').toggleClass('open');
  });

  // Add row
  $('#btnAdd').on('click', addRow);

  function addRow() {
    count++;
    $('#emptyMsg').hide();
    $('#colHeaders').removeClass('d-none');

    const row = $(`
      <div class="condition-row d-flex align-items-center gap-2" data-id="${count}">
        <div style="flex:0 0 42%;">
          <input type="text" class="input-underline" placeholder="Enter condition..."/>
        </div>
        <div style="flex:0 0 30%;">
          <input type="text" class="input-underline since-input" placeholder="Enter details"/>
        </div>
        <div class="d-flex gap-2 ms-auto">
          <button class="btn-star" title="Mark important" data-starred="0">
            <i class="bx bx-star"></i>
          </button>
          <button class="btn-del" title="Delete">
            <i class="bx bx-trash"></i>
          </button>
        </div>
      </div>
    `);

    $('#conditionsContainer').append(row);
    row.find('input').first().focus();
  }

  // Star toggle
  $(document).on('click', '.btn-star', function () {
    const isStarred = $(this).data('starred') === 1;
    if (isStarred) {
      $(this).data('starred', 0).removeClass('starred');
      $(this).find('i').removeClass('bxs-star').addClass('bx-star');
    } else {
      $(this).data('starred', 1).addClass('starred');
      $(this).find('i').removeClass('bx-star').addClass('bxs-star');
    }
  });

  // Delete row
  $(document).on('click', '.btn-del', function () {
    $(this).closest('.condition-row').remove();
    if ($('.condition-row').length === 0) {
      $('#emptyMsg').show();
      $('#colHeaders').addClass('d-none');
    }
  });
</script>
</body>
</html>