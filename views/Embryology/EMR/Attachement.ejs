<div class="container-div Attachement-Container">
    <div class="align-items-center Head2 d-flex">
      <div
        class="Left-Heading"
        onclick="dropToggle('#AttachementContent')"
      >
        <span><i class="fa-solid fa-angle-down" id="Attachementi"></i> </span>
        Attachments
      </div>
      
    </div>

    <div
      class="Content-Div"
      id="AttachementContent"
      style="display: none"
    >
      <div class="right-add-icon justify-content-end py-2 mr-2 d-flex">
        <button type="button" id="addAttachment" onclick="dropToggleButton('#AttachementContent','#Attachementi')" class="btn-secondary btn-style btn"> <strong><i class="fa-solid fa-plus"></i> Add</strong> </button>
      </div>
      
      <div class="attachment-form">
        <div class="row">
          <div class="col-md-6">
            <div class="form-group">
              <label for="attachmentType">Attachment Type</label>
              <select class="form-control" id="attachmentType">
                <option value="">Select Type</option>
                <option value="prescription">Prescription</option>
                <option value="report">Medical Report</option>
                <option value="scan">Scan Image</option>
                <option value="xray">X-Ray</option>
                <option value="lab">Lab Report</option>
                <option value="other">Other</option>
              </select>
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-group">
              <label for="attachmentDate">Date</label>
              <input type="date" class="form-control" id="attachmentDate">
            </div>
          </div>
        </div>
        
        <div class="row">
          <div class="col-md-12">
            <div class="form-group">
              <label for="attachmentDescription">Description</label>
              <textarea class="form-control" id="attachmentDescription" rows="3" placeholder="Enter description"></textarea>
            </div>
          </div>
        </div>
        
        <div class="row">
          <div class="col-md-12">
            <div class="form-group">
              <label for="attachmentFile">Upload File</label>
              <input type="file" class="form-control" id="attachmentFile">
              <small class="text-muted form-text">Supported formats: PDF, JPG, PNG, DOC</small>
            </div>
          </div>
        </div>
        
        <div class="form-group">
          <button type="button" class="btn btn-primary" id="saveAttachment">Save Attachment</button>
          <button type="button" class="ml-2 btn btn-secondary" id="cancelAttachment">Cancel</button>
        </div>
      </div>

      <div class="mt-4 attachment-list">
        <h6>Existing Attachments</h6>
        <div class="table-responsive">
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Type</th>
                <th>Date</th>
                <th>Description</th>
                <th>File</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="attachmentTableBody">
              <!-- Attachments will be populated here -->
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script>
    function attachmentSave() {
      const attachmentData = {
        type: $('#attachmentType').val(),
        date: $('#attachmentDate').val(),
        description: $('#attachmentDescription').val(),
        file: $('#attachmentFile')[0].files[0]?.name || ''
      };
      
      console.log("Submitting Attachment:", attachmentData);
      
      // AJAX request to backend
      axios.post("/embrology/attachmentSubmit", attachmentData, {
        headers: {
          "Content-Type": "application/json",
        },
      })
      .then(function (response) {
        console.log("Success:", response.data);
        addAttachmentToList(attachmentData);
        clearAttachmentForm();
      })
      .catch(function (error) {
        console.error("Error:", error);
      });
    }

    function addAttachmentToList(data) {
      const row = `
        <tr>
          <td>${data.type}</td>
          <td>${data.date}</td>
          <td>${data.description}</td>
          <td>
            <span class="bg-primary badge">${data.file}</span>
            <button class="ml-2 btn btn-sm btn-outline-primary" onclick="viewAttachment('${data.file}')">
              <i class="fa-solid fa-eye"></i> View
            </button>
          </td>
          <td>
            <button class="btn btn-sm btn-danger" onclick="deleteAttachment(this)">
              <i class="fa-solid fa-trash"></i> Delete
            </button>
          </td>
        </tr>
      `;
      $('#attachmentTableBody').append(row);
    }

    function clearAttachmentForm() {
      $('#attachmentType').val('');
      $('#attachmentDate').val('');
      $('#attachmentDescription').val('');
      $('#attachmentFile').val('');
    }

    function viewAttachment(filename) {
      alert('Viewing attachment: ' + filename);
      // Implement file viewing logic here
    }

    function deleteAttachment(button) {
      $(button).closest('tr').remove();
    }

    // Event listeners
    $('#saveAttachment').click(attachmentSave);
    $('#cancelAttachment').click(clearAttachmentForm);
  </script>