<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <div class="mb-4 card">

      <!-- Header -->
      <div class="justify-content-between align-items-center card-header d-flex">
        <h5 class="mb-0 card-title">Attachments</h5>
      </div>

      <!-- Body -->
      <div class="card-body">

        <!-- Top Row -->
        <div class="row align-items-end mb-3">

          <div class="col-md-8">
            <label>Select</label>
            <select class="form-control" id="attachmentType">
              <option>Proof of atleast one living child</option>
              <option>Aadhar Card</option>
              <option>Medical Report</option>
            </select>
          </div>

          <div class="col-md-4 d-flex gap-2">
            <button class="btn btn-primary w-50" id="qrCodeBtn">
              <i class="bx bx-qr"></i> Qr Code
            </button>

            <label class="btn btn-secondary w-50 mb-0">
              Upload
              <input type="file" id="attachmentFile" hidden>
            </label>
          </div>

        </div>

        <!-- Table -->
        <div class="table-responsive">
          <table class="table table-bordered align-middle">

            <thead>
              <tr>
                <th>Attachment Type</th>
                <th>File Name</th>
                <th>Date</th>
                <th>Time</th>
                <th style="width:120px;">Preview</th>
                <th style="width:80px;">Action</th>
              </tr>
            </thead>

            <tbody class="Attachment-Info-Divs">
              <!-- Rows added dynamically -->
            </tbody>

          </table>
        </div>

      </div>

    </div>

  </div>
</div>
<script>
  $(document).ready(function () {

  $('#attachmentFile').on('change', function () {

    let file = this.files[0];
    if (!file) return;

    let fileName = file.name;
    let type = $('#attachmentType').val();

    let now = new Date();
    let date = now.toISOString().split('T')[0];
    let time = now.toTimeString().split(' ')[0];

    let preview = '';

    if (file.type.startsWith('image')) {
      let url = URL.createObjectURL(file);
      preview = `<img src="${url}" width="40">`;
    } else {
      preview = `<i class="fa-solid fa-file"></i>`;
    }

    let row = `
      <tr>

        <td>${type}</td>
        <td>${fileName}</td>
        <td>${date}</td>
        <td>${time}</td>

        <td class="text-center">
          ${preview}
        </td>

        <td class="text-center">
          <button class="btn btn-danger btn-sm remove-attachment">
            <i class="fa-solid fa-trash"></i>
          </button>
        </td>

      </tr>
    `;

    $('.Attachment-Info-Divs').append(row);

    // reset input
    $('#attachmentFile').val('');
  });

  // DELETE
  $(document).on('click', '.remove-attachment', function () {
    $(this).closest('tr').remove();
  });

});
</script>