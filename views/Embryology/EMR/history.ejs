<div class="mb-4 card History-Container">

  <div class="justify-content-between align-items-center card-header d-flex">

    <h5 class="mb-0">
      <span onclick="dropToggle('#HistoryContent')" style="cursor:pointer;">
        <i class="fa-solid fa-angle-down me-2" id="Historyi"></i>
        History
      </span>
    </h5>

    <button
      type="button"
      id="addHistory"
      onclick="dropToggleButton('#HistoryContent','#Historyi')"
      class="btn btn-primary"
    >
      <i class="bx bx-plus me-1"></i> Add
    </button>

  </div>


  <div class="card-body" id="HistoryContent" style="display:none">

    <div class="history-form">

      <div class="mb-3 row">

        <div class="col-md-12">
          <label class="form-label" for="historyType">History Type</label>

          <select class="form-select" id="historyType">
            <option value="">Select Type</option>
            <option value="medical">Medical History</option>
            <option value="surgical">Surgical History</option>
            <option value="family">Family History</option>
            <option value="social">Social History</option>
            <option value="obstetric">Obstetric History</option>
            <option value="gynecological">Gynecological History</option>
            <option value="allergy">Allergy History</option>
            <option value="medication">Medication History</option>
          </select>
        </div>

      </div>


      <div class="mb-3 row">

        <div class="col-md-6">
          <label class="form-label" for="historyDate">Date</label>

          <input
            type="date"
            class="form-control"
            id="historyDate"
          >
        </div>


        <div class="col-md-6">
          <label class="form-label" for="historyDuration">Duration</label>

          <input
            type="text"
            class="form-control"
            id="historyDuration"
            placeholder="e.g., 5 years, since childhood"
          >
        </div>

      </div>



      <div class="mb-3 row">

        <div class="col-md-12">

          <label class="form-label" for="historyDescription">Description</label>

          <textarea
            class="form-control"
            id="historyDescription"
            rows="4"
            placeholder="Detailed description of the history..."
          ></textarea>

        </div>

      </div>



      <div class="mb-3 row">

        <div class="col-md-6">

          <label class="form-label" for="historyStatus">Status</label>

          <select class="form-select" id="historyStatus">
            <option value="">Select Status</option>
            <option value="active">Active</option>
            <option value="resolved">Resolved</option>
            <option value="chronic">Chronic</option>
            <option value="past">Past</option>
          </select>

        </div>


        <div class="col-md-6">

          <label class="form-label" for="historySeverity">Severity</label>

          <select class="form-select" id="historySeverity">
            <option value="">Select Severity</option>
            <option value="mild">Mild</option>
            <option value="moderate">Moderate</option>
            <option value="severe">Severe</option>
          </select>

        </div>

      </div>



      <div class="mb-3 row">

        <div class="col-md-12">

          <label class="form-label" for="historyNotes">Additional Notes</label>

          <textarea
            class="form-control"
            id="historyNotes"
            rows="3"
            placeholder="Any additional relevant information..."
          ></textarea>

        </div>

      </div>



      <div class="mb-4">

        <button
          type="button"
          class="btn btn-primary"
          id="saveHistory"
        >
          Save History
        </button>

        <button
          type="button"
          class="btn btn-secondary ms-2"
          id="cancelHistory"
        >
          Cancel
        </button>

      </div>

    </div>



    <div class="history-list">

      <h6 class="mb-3">Medical History</h6>

      <div class="text-nowrap table-responsive">

        <table class="table table-bordered">

          <thead>
            <tr>
              <th>Type</th>
              <th>Date</th>
              <th>Description</th>
              <th>Duration</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody id="historyTableBody">
          </tbody>

        </table>

      </div>

    </div>

  </div>

</div>