<style>
.custom-select-wrapper {
  position: relative;
}

.custom-dropdown {
  position: absolute;
  width: 100%;
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 8px;
  padding: 10px;
  z-index: 999;
  max-height: 220px;
  overflow-y: auto;
  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

.custom-dropdown label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
  cursor: pointer;
}

/* Toggle Switch Style */
.custom-dropdown input[type="checkbox"] {
  appearance: none;
  width: 36px;
  height: 18px;
  background: #ccc;
  border-radius: 20px;
  position: relative;
  outline: none;
  cursor: pointer;
  transition: 0.3s;
}

.custom-dropdown input[type="checkbox"]:checked {
  background: #28c76f;
}

.custom-dropdown input[type="checkbox"]::before {
  content: "";
  position: absolute;
  width: 14px;
  height: 14px;
  background: #fff;
  border-radius: 50%;
  top: 2px;
  left: 2px;
  transition: 0.3s;
}

.custom-dropdown input[type="checkbox"]:checked::before {
  transform: translateX(18px);
}
</style>
<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <div class="mb-4 card">

      <div class="justify-content-between align-items-center card-header d-flex">
        <h5 class="mb-0 card-title">Diagnosis</h5>

        <button
          type="button"
          id="addDiagnosis"
          class="btn btn-primary"
        >
          <i class="bx bx-plus me-1"></i> Add
        </button>
      </div>

      <div class="card-body">

   <div class="diagnosis-form">

  <h6 class="text-success mb-3">Diagnosis</h6>

  <!-- Male Factor -->
  <div class="row mb-3 align-items-center">
    <div class="col-md-3">
      <label>Male Factor</label>
    </div>

    <div class="col-md-5">
      <div class="custom-select-wrapper">
        <input type="text" class="form-control custom-input" placeholder="Select options" readonly>
        <div class="custom-dropdown d-none">
          <label><span>Azoospermia</span><input type="checkbox" value="Azoospermia"></label>
          <label><span>Oligospermia</span><input type="checkbox" value="Oligospermia"></label>
          <label><span>Asthenozoospermia</span><input type="checkbox" value="Asthenozoospermia"></label>
          <label><span>Teratozoospermia</span><input type="checkbox" value="Teratozoospermia"></label>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <input class="form-control" placeholder="Others">
    </div>
  </div>

  <!-- Female Factor -->
  <div class="row mb-3 align-items-center">
    <div class="col-md-3">
      <label>Female Factor</label>
    </div>

    <div class="col-md-5">
      <div class="custom-select-wrapper">
        <input type="text" class="form-control custom-input" placeholder="Select options" readonly>
        <div class="custom-dropdown d-none">
          <label><span>Ovulatory disorder</span><input type="checkbox" value="Ovulatory disorder"></label>
          <label><span>Tubal factor</span><input type="checkbox" value="Tubal factor"></label>
          <label><span>Low reserve</span><input type="checkbox" value="Low reserve"></label>
          <label><span>Endometriosis</span><input type="checkbox" value="Endometriosis"></label>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <input class="form-control" placeholder="Others">
    </div>
  </div>

  <!-- Karyotype -->
  <div class="row mb-3 align-items-center">
    <div class="col-md-3">
      <label>Karyotype Abnormality</label>
    </div>

    <div class="col-md-5">
      <div class="custom-select-wrapper">
        <input type="text" class="form-control custom-input" placeholder="Select options" readonly>
        <div class="custom-dropdown d-none">
          <label><span>Inversion</span><input type="checkbox" value="Inversion"></label>
          <label><span>Deletion</span><input type="checkbox" value="Deletion"></label>
          <label><span>Translocation</span><input type="checkbox" value="Translocation"></label>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <input class="form-control" placeholder="Others">
    </div>
  </div>

  <!-- Years -->
  <div class="row mb-3 align-items-center">
    <div class="col-md-3">
      <label>No. of years infertile</label>
    </div>

    <div class="col-md-9">
      <input type="number" class="form-control">
    </div>
  </div>

  <!-- Others -->
  <div class="row mb-3 align-items-center">
    <div class="col-md-3">
      <label>Others</label>
    </div>

    <div class="col-md-9">
      <input class="form-control">
    </div>
  </div>

</div>

      </div>

    </div>

  </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
$(document).ready(function () {

  // Open dropdown
  $('.custom-input').on('click', function () {
    $('.custom-dropdown').addClass('d-none'); // close others
    $(this).siblings('.custom-dropdown').toggleClass('d-none');
  });

  // Checkbox change
  $('.custom-dropdown input[type="checkbox"]').on('change', function () {
    const wrapper = $(this).closest('.custom-select-wrapper');
    let selected = [];

    wrapper.find('input[type="checkbox"]:checked').each(function () {
      selected.push($(this).val());
    });

    wrapper.find('.custom-input').val(selected.join(', '));
  });

  // Close on outside click
  $(document).on('click', function (e) {
    if (!$(e.target).closest('.custom-select-wrapper').length) {
      $('.custom-dropdown').addClass('d-none');
    }
  });

});
</script>
