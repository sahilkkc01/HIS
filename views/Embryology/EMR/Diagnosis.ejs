<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <div class="mb-4 card">

      <div class="justify-content-between align-items-center card-header d-flex">
        <h5 class="mb-0 card-title">Diagnosis</h5>

        <button
          type="button"
          id="addDiagnosis"
          class="btn btn-primary"
        >
          <i class="bx bx-plus me-1"></i> Add
        </button>
      </div>

      <div class="card-body">

        <div class="diagnosis-form">

          <div class="mb-3 row">

            <div class="col-md-6">
              <label class="form-label" for="diagnosisCode">ICD Code</label>
              <input
                type="text"
                class="form-control"
                id="diagnosisCode"
                placeholder="e.g., E11.9"
              >
            </div>

            <div class="col-md-6">
              <label class="form-label" for="diagnosisName">Diagnosis Name</label>
              <input
                type="text"
                class="form-control"
                id="diagnosisName"
                placeholder="e.g., Type 2 Diabetes"
              >
            </div>

          </div>


          <div class="mb-3 row">

            <div class="col-md-6">
              <label class="form-label" for="diagnosisType">Diagnosis Type</label>

              <select class="form-select" id="diagnosisType">
                <option value="">Select Type</option>
                <option value="primary">Primary</option>
                <option value="secondary">Secondary</option>
                <option value="differential">Differential</option>
                <option value="provisional">Provisional</option>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label" for="diagnosisDate">Date</label>

              <input
                type="date"
                class="form-control"
                id="diagnosisDate"
              >
            </div>

          </div>


          <div class="mb-3 row">

            <div class="col-md-12">
              <label class="form-label" for="diagnosisDescription">Description</label>

              <textarea
                class="form-control"
                id="diagnosisDescription"
                rows="3"
                placeholder="Detailed description of the diagnosis..."
              ></textarea>
            </div>

          </div>


          <div class="mb-3 row">

            <div class="col-md-6">

              <label class="form-label" for="diagnosisStatus">Status</label>

              <select class="form-select" id="diagnosisStatus">
                <option value="">Select Status</option>
                <option value="confirmed">Confirmed</option>
                <option value="suspected">Suspected</option>
                <option value="ruled-out">Ruled Out</option>
                <option value="resolved">Resolved</option>
              </select>

            </div>

            <div class="col-md-6">

              <label class="form-label" for="diagnosisPriority">Priority</label>

              <select class="form-select" id="diagnosisPriority">
                <option value="">Select Priority</option>
                <option value="high">High</option>
                <option value="medium">Medium</option>
                <option value="low">Low</option>
              </select>

            </div>

          </div>


          <div class="mb-4">

            <button
              type="button"
              class="btn btn-primary"
              id="saveDiagnosis"
            >
              Save Diagnosis
            </button>

            <button
              type="button"
              class="btn btn-secondary ms-2"
              id="cancelDiagnosis"
            >
              Cancel
            </button>

          </div>

        </div>



        <div class="diagnosis-list">

          <h6 class="mb-3">Existing Diagnoses</h6>

          <div class="text-nowrap table-responsive">

            <table class="table table-bordered">

              <thead>
                <tr>
                  <th>ICD Code</th>
                  <th>Diagnosis</th>
                  <th>Type</th>
                  <th>Date</th>
                  <th>Status</th>
                  <th>Priority</th>
                  <th>Actions</th>
                </tr>
              </thead>

              <tbody id="diagnosisTableBody">
              </tbody>

            </table>

          </div>

        </div>

      </div>

    </div>

  </div>
</div>