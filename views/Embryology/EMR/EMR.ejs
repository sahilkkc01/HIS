<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EMR  </title>
  <%- include("../../header") -%>
</head>

<body>
    <div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <!-- PATIENT INFO -->
   <div class="mb-4 card">
  <div class="card-body">
    <div class="row align-items-center">

      <!-- Left -->
      <div class="col-md-4">
        <strong>UHID:</strong> <span id="p_uhid">-</span><br>
        <strong>Patient Id:</strong> <span id="patientId">-</span><br>
        <small>Gender: <span id="p_gender">-</span></small>
      </div>

      <!-- Center -->
      <div class="col-md-4 text-center">
        <img id="p_image" src="/images/1.png" class="rounded mb-1" width="60" height="60"/>
        <br>
        <strong id="p_name">-</strong><br>
        <small id="p_age">-</small>
      </div>

      <!-- Right (Father/Spouse) -->
      <div class="col-md-4 text-end">
        <strong id="p_family">-</strong><br>
        <small id="p_contact">-</small>
      </div>

    </div>
  </div>
</div>
    </div>
    </div>
<%- include("./preExisting") %>
<%- include("./allergies") -%>
<%- include("./chiefComplaint") -%>
<%- include("./InfertilityHistory") -%>
<%- include("./examination") -%>
<%- include("./Diagnosis") -%>
<%- include("./DoctorNotes") -%>
<%- include("./ServiceAdvice") -%>
<%- include("./prescription") -%>
<%- include("./Attachment") -%>
<%- include("./treatmentAdvice") -%>
<%- include("./FollowUp") -%>


<%- include("../../footer") -%>

<script>
$(document).ready(function () {

  const urlParams = new URLSearchParams(window.location.search);
  const id = urlParams.get("id");

  if (id) {
    loadPatient(id);
  }

  function loadPatient(id) {
    $.ajax({
      url: "/getPatientById?id=" + encodeURIComponent(id),
      type: "GET",
      success: function (res) {
        console.log("Patient:", res);

        const p = res.patient;
        if (!p) return;

        // 🔹 Full Name
        const fullName = [
          p.prefix,
          p.firstName,
          p.middleName,
          p.lastName
        ].filter(Boolean).join(" ");

        // 🔹 Age text
        const ageText = p.age ? `${p.age} Years` : "";

        // 🔹 Fill UI
        $("#p_uhid").text(p.uhid || "-");
        $("#patientId").text(p.id || "-");
        $("#p_gender").text(p.gender || "-");
        $("#p_name").text(fullName || "-");
        $("#p_age").text(ageText);
        $("#p_family").text(p.fatherName || "-");
        $("#p_contact").text(p.mobile || "-");

        // 🔹 Image
        if (p.patientImage) {
          $("#p_image").attr("src", "/MyUploads/" + p.patientImage);
        }

      },
      error: function (err) {
        console.error("Error loading patient:", err.responseJSON?.message);
      }
    });
  }

});
</script>
</body>
</html>