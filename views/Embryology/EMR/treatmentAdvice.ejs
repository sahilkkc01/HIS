<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <div class="mb-4 card">

      <!-- Header -->
      <div class="justify-content-between align-items-center card-header d-flex">
        <h5 class="mb-0 card-title">Treatment Advice</h5>
      </div>

      <!-- Body -->
      <div class="card-body">

        <!-- FORM BOX -->
        <div class="p-3 border rounded mb-3">

          <div class="row">

            <!-- LEFT -->
            <div class="col-md-6">

              <div class="mb-3">
                <label class="form-label">Treatment Type*</label>
                <select class="form-control" id="treatmentType">
                  <option value="">Select</option>
                  <option>Medication</option>
                  <option>Procedure</option>
                  <option>Therapy</option>
                </select>
              </div>

              <div class="mb-3">
                <label class="form-label">Remarks</label>
                <input type="text" class="form-control" id="treatmentRemarks">
              </div>

            </div>

            <!-- RIGHT -->
            <div class="col-md-6">

              <div class="mb-3">
                <label class="form-label">Doctor</label>
                <select class="form-control" id="treatmentDoctor">
                  <option value="">Select</option>
                  <option>Dr. Sharma</option>
                  <option>Dr. Gupta</option>
                </select>
              </div>

              <div class="mb-3">
                <label class="form-label">Choose a date:</label>
                <input type="date" class="form-control" id="treatmentDate">
              </div>

            </div>

          </div>

          <!-- ADD BUTTON -->
          <div class="text-end">
            <button class="btn btn-primary" id="addTreatmentAdvice">
              <i class="bx bx-plus me-1"></i> Add
            </button>
          </div>

        </div>

        <!-- LIST -->
        <div class="table-responsive">
          <table class="table table-bordered">

            <thead>
              <tr>
                <th>Type</th>
                <th>Doctor</th>
                <th>Date</th>
                <th>Remarks</th>
                <th style="width:80px;">Action</th>
              </tr>
            </thead>

            <tbody class="TreatmentAdvice-Info-Divs">
              <!-- Dynamic rows -->
            </tbody>

          </table>
        </div>

      </div>

    </div>

  </div>
</div>
<script>
  $(document).ready(function () {

  $('#addTreatmentAdvice').on('click', function () {

    let type = $('#treatmentType').val();
    let doctor = $('#treatmentDoctor').val();
    let date = $('#treatmentDate').val();
    let remarks = $('#treatmentRemarks').val();

    if (!type || !doctor || !date) {
      alert("Please fill required fields");
      return;
    }

    let row = `
      <tr>

        <td>${type}</td>
        <td>${doctor}</td>
        <td>${date}</td>
        <td>${remarks || '-'}</td>

        <td class="text-center">
          <button class="btn btn-danger btn-sm remove-treatment">
            <i class="fa-solid fa-trash"></i>
          </button>
        </td>

      </tr>
    `;

    $('.TreatmentAdvice-Info-Divs').append(row);

    // Clear form
    $('#treatmentType').val('');
    $('#treatmentDoctor').val('');
    $('#treatmentDate').val('');
    $('#treatmentRemarks').val('');
  });

  // DELETE
  $(document).on('click', '.remove-treatment', function () {
    $(this).closest('tr').remove();
  });

});
</script>