<div class="mb-4 card TreatmentAdvice-Container">

  <div class="justify-content-between align-items-center card-header d-flex">

    <h5 class="mb-0">
      <span onclick="dropToggle('#TreatmentAdviceContent')" style="cursor:pointer;">
        <i class="fa-solid fa-angle-down me-2" id="TreatmentAdvicei"></i>
        Treatment Advice
      </span>
    </h5>

    <button
      type="button"
      id="addTreatmentAdvice"
      onclick="dropToggleButton('#TreatmentAdviceContent','#TreatmentAdvicei')"
      class="btn btn-primary"
    >
      <i class="bx bx-plus me-1"></i> Add
    </button>

  </div>


  <div class="card-body" id="TreatmentAdviceContent" style="display:none">

    <div class="treatment-advice-form">

      <div class="mb-3 row">

        <div class="col-md-6">

          <label class="form-label" for="treatmentDate">Treatment Date</label>

          <input
            type="date"
            class="form-control"
            id="treatmentDate"
          >

        </div>


        <div class="col-md-6">

          <label class="form-label" for="treatmentDoctor">Doctor</label>

          <input
            type="text"
            class="form-control"
            id="treatmentDoctor"
            placeholder="Doctor's name"
          >

        </div>

      </div>



      <div class="mb-3 row">

        <div class="col-md-12">

          <label class="form-label" for="treatmentType">Treatment Type</label>

          <select class="form-select" id="treatmentType">
            <option value="">Select Type</option>
            <option value="medication">Medication</option>
            <option value="procedure">Medical Procedure</option>
            <option value="therapy">Therapy</option>
            <option value="surgery">Surgery</option>
            <option value="lifestyle">Lifestyle Modification</option>
            <option value="monitoring">Monitoring</option>
            <option value="referral">Referral</option>
            <option value="other">Other</option>
          </select>

        </div>

      </div>



      <div class="mb-3 row">

        <div class="col-md-12">

          <label class="form-label" for="treatmentDescription">Treatment Description</label>

          <textarea
            class="form-control"
            id="treatmentDescription"
            rows="4"
            placeholder="Detailed description of the treatment..."
          ></textarea>

        </div>

      </div>



      <div class="mb-3 row">

        <div class="col-md-6">

          <label class="form-label" for="treatmentDuration">Expected Duration</label>

          <input
            type="text"
            class="form-control"
            id="treatmentDuration"
            placeholder="e.g., 2 weeks, 3 months"
          >

        </div>


        <div class="col-md-6">

          <label class="form-label" for="treatmentStatus">Status</label>

          <select class="form-select" id="treatmentStatus">
            <option value="">Select Status</option>
            <option value="recommended">Recommended</option>
            <option value="started">Started</option>
            <option value="ongoing">Ongoing</option>
            <option value="completed">Completed</option>
            <option value="discontinued">Discontinued</option>
          </select>

        </div>

      </div>



      <div class="mb-3 row">

        <div class="col-md-6">

          <label class="form-label" for="treatmentPriority">Priority</label>

          <select class="form-select" id="treatmentPriority">
            <option value="">Select Priority</option>
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
          </select>

        </div>


        <div class="col-md-6">

          <label class="form-label" for="treatmentFollowUp">Follow-up Required</label>

          <select class="form-select" id="treatmentFollowUp">
            <option value="">Select</option>
            <option value="yes">Yes</option>
            <option value="no">No</option>
          </select>

        </div>

      </div>



      <div class="mb-3 row">

        <div class="col-md-12">

          <label class="form-label" for="treatmentNotes">Additional Notes</label>

          <textarea
            class="form-control"
            id="treatmentNotes"
            rows="3"
            placeholder="Any additional notes about the treatment..."
          ></textarea>

        </div>

      </div>



      <div class="mb-4">

        <button
          type="button"
          class="btn btn-primary"
          id="saveTreatmentAdvice"
        >
          Save Treatment
        </button>

        <button
          type="button"
          class="btn btn-secondary ms-2"
          id="cancelTreatmentAdvice"
        >
          Cancel
        </button>

      </div>

    </div>



    <div class="treatment-advice-list">

      <h6 class="mb-3">Treatment History</h6>

      <div class="text-nowrap table-responsive">

        <table class="table table-bordered">

          <thead>
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th>Doctor</th>
              <th>Status</th>
              <th>Duration</th>
              <th>Priority</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody id="treatmentAdviceTableBody">
          </tbody>

        </table>

      </div>

    </div>

  </div>

</div>