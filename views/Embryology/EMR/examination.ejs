<script>
  $(document).ready(function () {

  // -----------------------------
  // 1. HANDLE NAD / ABNORMAL TOGGLE
  // -----------------------------
  $(document).on('change', 'input[type=radio][data-target]', function () {
    const target = $(this).data('target');
    const value = $(this).val();

    if (value === "NAD" || value === "Normal" || value === "NotAssessed") {
      $(target)
        .hide()
        .find('input, select, textarea')
        .val('')
        .prop('disabled', true);
    } else {
      $(target)
        .show()
        .find('input, select, textarea')
        .prop('disabled', false);
    }
  });

  // -----------------------------
  // 2. INITIAL STATE (HIDE ALL DEPENDENT FIELDS)
  // -----------------------------
  $('.dependent-field')
    .hide()
    .find('input, select, textarea')
    .prop('disabled', true);

  // -----------------------------
  // 3. HYDROSALPINX TOGGLE
  // -----------------------------
  $('input[name="hydroRight"]').on('change', function () {
    if (this.value === 'Yes') {
      $('.hydro-right-fields').show();
    } else {
      $('.hydro-right-fields').hide().find('input').val('');
    }
  });

  $('input[name="hydroLeft"]').on('change', function () {
    if (this.value === 'Yes') {
      $('.hydro-left-fields').show();
    } else {
      $('.hydro-left-fields').hide().find('input').val('');
    }
  });

  // Hide initially
  $('.hydro-right-fields, .hydro-left-fields').hide();

  // -----------------------------
  // 4. NAD BUTTON (MASTER RESET)
  // -----------------------------
  $('#addExamination').on('click', function () {

    // Select all NAD radios
    $('input[type=radio][value="NAD"]').each(function () {
      $(this).prop('checked', true).trigger('change');
    });

    // Select all "No"
    $('input[type=radio][value="No"]').prop('checked', true);

    // Clear all inputs
    $('input[type=text], input[type=number], input[type=date], textarea').val('');

    // Reset selects
    $('select').prop('selectedIndex', 0);

    // Hide all dependent fields
    $('.dependent-field')
      .hide()
      .find('input, select, textarea')
      .prop('disabled', true);

    // Hide hydrosalpinx
    $('.hydro-right-fields, .hydro-left-fields').hide();

  });

});
</script>