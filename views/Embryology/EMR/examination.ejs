<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <div class="mb-4 card">

      <div class="justify-content-between align-items-center card-header d-flex">
        <h5 class="mb-0 card-title">Examination</h5>

        <button
          type="button"
          id="addExamination"
          class="btn btn-primary"
        >
          <i class="bx bx-plus me-1"></i> Add
        </button>
      </div>

      <div class="card-body">

        <div class="examination-form">

          <div class="mb-3 row">

            <div class="col-md-6">
              <label class="form-label" for="examinationDate">Date</label>
              <input type="date" class="form-control" id="examinationDate">
            </div>

            <div class="col-md-6">
              <label class="form-label" for="examinationTime">Time</label>
              <input type="time" class="form-control" id="examinationTime">
            </div>

          </div>


          <div class="mb-3 row">

            <div class="col-md-12">
              <label class="form-label" for="examinationType">Examination Type</label>

              <select class="form-select" id="examinationType">
                <option value="">Select Type</option>
                <option value="general">General Examination</option>
                <option value="systemic">Systemic Examination</option>
                <option value="local">Local Examination</option>
                <option value="special">Special Examination</option>
              </select>
            </div>

          </div>


          <div class="mb-3 row">

            <div class="col-md-6">
              <label class="form-label" for="temperature">Temperature (°C)</label>
              <input type="number" class="form-control" id="temperature" step="0.1" placeholder="e.g., 98.6">
            </div>

            <div class="col-md-6">
              <label class="form-label" for="bloodPressure">Blood Pressure</label>
              <input type="text" class="form-control" id="bloodPressure" placeholder="e.g., 120/80">
            </div>

          </div>


          <div class="mb-3 row">

            <div class="col-md-6">
              <label class="form-label" for="pulseRate">Pulse Rate (bpm)</label>
              <input type="number" class="form-control" id="pulseRate" placeholder="e.g., 72">
            </div>

            <div class="col-md-6">
              <label class="form-label" for="respiratoryRate">Respiratory Rate (rpm)</label>
              <input type="number" class="form-control" id="respiratoryRate" placeholder="e.g., 16">
            </div>

          </div>


          <div class="mb-3 row">

            <div class="col-md-6">
              <label class="form-label" for="weight">Weight (kg)</label>
              <input type="number" class="form-control" id="weight" step="0.1" placeholder="e.g., 70.5">
            </div>

            <div class="col-md-6">
              <label class="form-label" for="height">Height (cm)</label>
              <input type="number" class="form-control" id="height" placeholder="e.g., 175">
            </div>

          </div>


          <div class="mb-3 row">

            <div class="col-md-12">
              <label class="form-label" for="examinationFindings">Findings</label>

              <textarea
                class="form-control"
                id="examinationFindings"
                rows="4"
                placeholder="Describe examination findings..."
              ></textarea>
            </div>

          </div>


          <div class="mb-3 row">

            <div class="col-md-12">
              <label class="form-label" for="examinationNotes">Additional Notes</label>

              <textarea
                class="form-control"
                id="examinationNotes"
                rows="3"
                placeholder="Any additional observations..."
              ></textarea>
            </div>

          </div>


          <div class="mb-4">

            <button
              type="button"
              class="btn btn-primary"
              id="saveExamination"
            >
              Save Examination
            </button>

            <button
              type="button"
              class="btn btn-secondary ms-2"
              id="cancelExamination"
            >
              Cancel
            </button>

          </div>

        </div>



        <div class="examination-list">

          <h6 class="mb-3">Existing Examinations</h6>

          <div class="text-nowrap table-responsive">

            <table class="table table-bordered">

              <thead>
                <tr>
                  <th>Date & Time</th>
                  <th>Type</th>
                  <th>Vital Signs</th>
                  <th>Findings</th>
                  <th>Actions</th>
                </tr>
              </thead>

              <tbody id="examinationTableBody">
              </tbody>

            </table>

          </div>

        </div>

      </div>

    </div>

  </div>
</div>