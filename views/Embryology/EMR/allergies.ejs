<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <div class="mb-4 card">

      <!-- Header -->
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Allergies</h5>

        <div class="d-flex gap-2">
          <button type="button" id="addAllergy" class="btn btn-primary">
            <i class="bx bx-plus me-1"></i> Add
          </button>

          <button type="button" id="saveAllergyBtn" class="btn btn-success">
            <i class="bx bx-save me-1"></i> Save
          </button>
        </div>
      </div>

      <!-- Body -->
      <div class="card-body">

        <!-- Radio -->
        <div class="mb-3">
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="allergies" id="noKnownAllergies">
            <label class="form-check-label">No Known Allergies</label>
          </div>

          <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="allergies" id="hasAllergies">
            <label class="form-check-label">Allergies</label>
          </div>
        </div>

        <!-- Dynamic Rows -->
        <div class="Allergies-Info-Divs"></div>

      </div>

    </div>

  </div>
</div>


<script>
$(document).ready(function () {

  const urlParams = new URLSearchParams(window.location.search);
  const patientId = urlParams.get("id");

  if (patientId) {
    loadAllergies(patientId);
  }

  $("#addAllergy").hide(); // initial hide

});


// 🔹 Add Row
function addAllergyEntry(name = "", severity = "") {

  const row = $(`
    <div class="allergy-entry row align-items-center mb-3">

      <div class="col-md-6">
        <input type="text" class="form-control allergy-name-input"
          placeholder="Enter allergy" value="${name}">
      </div>

      <div class="col-md-4">
        <select class="form-select allergy-severity">
          <option value="">Severity</option>
          <option value="low" ${severity==="low"?"selected":""}>Low</option>
          <option value="medium" ${severity==="medium"?"selected":""}>Medium</option>
          <option value="high" ${severity==="high"?"selected":""}>High</option>
        </select>
      </div>

      <div class="col-md-2">
        <button type="button" class="btn btn-sm btn-danger delete-icon">
          <i class="fa-solid fa-trash"></i>
        </button>
      </div>

    </div>
  `);

  $(".Allergies-Info-Divs").append(row);

  row.find(".delete-icon").click(function () {
    $(this).closest(".allergy-entry").remove();
  });
}


// 🔥 LOAD
function loadAllergies(patientId) {

  $.ajax({
    url: "/embryology/getAllergies?patientId=" + encodeURIComponent(patientId),
    type: "GET",
    success: function (res) {

      const data = res.data || [];

      $(".Allergies-Info-Divs").empty();

      if (data.length === 0) {
        $("#noKnownAllergies").prop("checked", true);
        $("#addAllergy").hide();
        return;
      }

      $("#hasAllergies").prop("checked", true);
      $("#addAllergy").show();

      data.forEach(item => {
        addAllergyEntry(item.allergy_name, item.severity);
      });

    }
  });
}


// 🔹 Add
$("#addAllergy").click(function () {
  addAllergyEntry();
  $("#hasAllergies").prop("checked", true);
});


// 🔹 Radio logic
$("#noKnownAllergies").click(function () {
  $(".Allergies-Info-Divs").empty();
  $("#addAllergy").hide();
});

$("#hasAllergies").click(function () {
  $("#addAllergy").show();

  if ($(".allergy-entry").length === 0) {
    addAllergyEntry();
  }
});


// 🔥 SAVE
$("#saveAllergyBtn").click(function () {

  const urlParams = new URLSearchParams(window.location.search);
  const patientId = urlParams.get("id");

  if (!patientId) {
    alert("Patient not found");
    return;
  }

  // No allergies case
  if ($("#noKnownAllergies").is(":checked")) {
    $.ajax({
      url: "/embryology/saveAllergies",
      type: "POST",
      contentType: "application/json",
      data: JSON.stringify({
        patientId,
        allergies: []
      }),
      success: function () {
        alert("Saved");
        loadAllergies(patientId);
      }
    });
    return;
  }

  const allergies = [];

  $(".allergy-entry").each(function () {
    const name = $(this).find(".allergy-name-input").val().trim();
    const severity = $(this).find(".allergy-severity").val();

    if (name) {
      allergies.push({
        allergy: name,
        severity
      });
    }
  });

  $.ajax({
    url: "/embryology/saveAllergies",
    type: "POST",
    contentType: "application/json",
    data: JSON.stringify({
      patientId,
      allergies
    }),
    success: function (res) {
      alert(res.message || "Saved");
      loadAllergies(patientId);
    }
  });

});

</script>