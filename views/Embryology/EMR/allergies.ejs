<div class="content-wrapper">
  <div class="container-xxl container-p-y flex-grow-1">

    <div class="mb-4 card">

      <!-- Header -->
      <div class="justify-content-between align-items-center card-header d-flex">
        <h5 class="mb-0 card-title">Allergies</h5>

        <button
          type="button"
          id="addAllergy"
          class="btn btn-primary"
        >
          <i class="bx bx-plus me-1"></i> Add 
        </button>
      </div>

      <!-- Body -->
      <div class="card-body">

        <!-- Radio buttons -->
        <div class="mb-3">
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="allergies" id="noKnownAllergies">
            <label class="form-check-label" for="noKnownAllergies">No Known Allergies</label>
          </div>

          <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="allergies" id="hasAllergies">
            <label class="form-check-label" for="hasAllergies">Allergies</label>
          </div>
        </div>

        <!-- Dynamic Allergies Container -->
        <div class="Allergies-Info-Divs">
          <!-- Allergy rows will be added here -->
        </div>

      </div>

    </div>

  </div>
</div>

<!-- Script -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
function addAllergyEntry() {
  const newDiv = $("<div>", {
    class: "allergy-entry row align-items-center mb-3"
  });

  newDiv.html(`
    <div class="col-md-6">
      <input
        type="text"
        class="form-control allergy-name-input"
        placeholder="Enter allergy"
      >
    </div>

    <div class="col-md-4">
      <select class="form-select allergy-severity">
        <option value="">Severity</option>
        <option value="low">Low</option>
        <option value="medium">Medium</option>
        <option value="high">High</option>
      </select>
    </div>

    <div class="col-md-2 d-flex gap-2">
      <button type="button" class="btn btn-sm btn-danger delete-icon">
        <i class="fa-solid fa-trash"></i>
      </button>
    </div>
  `);

  $(".Allergies-Info-Divs").append(newDiv);

  // Delete row
  newDiv.find(".delete-icon").click(function() {
    $(this).closest(".allergy-entry").remove();
  });
}

// Add button click
$("#addAllergy").click(function() {
  addAllergyEntry();
  $("#hasAllergies").prop("checked", true);
});

// Radio: No Known Allergies
$("#noKnownAllergies").click(function() {
  $(".Allergies-Info-Divs").empty();
  $("#addAllergy").hide();
});

// Radio: Has Allergies
$("#hasAllergies").click(function() {
  $(".Allergies-Info-Divs").show();
  addAllergyEntry();
  $("#addAllergy").show();
});

// Optional: initialize with no allergies
$(document).ready(function() {
  $("#addAllergy").hide();
});
</script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">