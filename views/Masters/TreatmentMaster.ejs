<!doctype html>
<html lang="en" class="light-style" dir="ltr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Treatment Master</title>
  <%- include('../header') -%>
  <style>
    .treatment-list { max-height: 70vh; overflow-y: auto; }
    .treatment-item { cursor: pointer; padding: .5rem .75rem; border-bottom: 1px solid #f1f1f1; }
    .treatment-item:hover { background: #f8f9fa; }
    .treatment-item.active { background: #e9f2ff; font-weight: 600; }
    .no-treatments { padding: 1rem; color: #6c757d; text-align:center; }
    .small-muted { font-size:.85rem; color:#6c757d }
  </style>
</head>

<body>
  <div class="container-fluid vh-100 d-flex flex-column">
    <div class="container-fluid py-4">
      <div class="card">
        <h5 class="card-header">Treatment Master</h5>
        <div class="card-body">
          <div class="row gx-4">
            <!-- Left: Treatment list -->
            <div class="col-md-4 mb-3">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div style="flex:1">
                  <input id="treatmentSearch" class="form-control form-control-sm" placeholder="Search treatments...">
                </div>
                <div class="ms-2">
                  <button id="newTreatmentBtn" class="btn btn-sm btn-outline-primary">New</button>
                </div>
              </div>

              <div class="card shadow-sm">
                <div class="card-body p-2 treatment-list" id="treatmentListContainer" aria-live="polite">
                  <div class="no-treatments">Loading treatments...</div>
                </div>
              </div>
            </div>

            <!-- Right: Form -->
            <div class="col-md-8">
              <form id="TreatmentForm">
                <input type="hidden" id="treatmentId" name="id">
                <div id="errordiv" style="display:none;"></div>

                <!-- Treatment Info -->
                <div class="row mb-3">
                  <div class="col-md-8 mb-2">
                    <label class="form-label" for="treatmentName">Treatment Name*</label>
                    <input type="text" id="treatmentName" name="treatmentName" class="form-control form-control-sm" required>
                  </div>
                </div>

                <div class="mt-3">
                  <button type="submit" class="btn btn-primary btn-sm me-2">Save Treatment</button>
                </div>
              </form>
            </div> <!-- end right col -->
          </div> <!-- end row -->
        </div> <!-- card-body -->
      </div> <!-- card -->
    </div> <!-- container-fluid -->
  </div> <!-- container-fluid vh-100 -->

  <%- include('../footer') -%>

  <script>
    $(function () {
      const formId = '#TreatmentForm';
      const errorDiv = '#errordiv';
      const treatmentListContainer = $('#treatmentListContainer');
      let treatmentsCache = [];
      let activeTreatmentId = null;

      // Render treatment list
      function renderTreatmentList(list, filter = '') {
        treatmentListContainer.empty();
        const filtered = list.filter(t => (t.name || '').toLowerCase().includes(filter.toLowerCase()));
        if (!filtered.length) {
          treatmentListContainer.html('<div class="no-treatments">No treatments found.</div>');
          return;
        }
        filtered.forEach(t => {
          const el = $(`
            <div class="treatment-item" data-id="${t.id}">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <div>${escapeHtml(t.name)}</div>
                </div>
              </div>
            </div>
          `);
          if (t.id == activeTreatmentId) el.addClass('active');
          el.on('click', () => {
            $('.treatment-item').removeClass('active');
            el.addClass('active');
            activeTreatmentId = t.id;
            fetchTreatment(t.id);
          });
          treatmentListContainer.append(el);
        });
      }

      function escapeHtml(text) {
        if (!text) return '';
        return String(text)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      }

      // Fetch treatment list from server
      async function loadTreatmentList() {
        treatmentListContainer.html('<div class="no-treatments">Loading treatments...</div>');
        try {
          const res = await axios.get('/treatments/list');
          treatmentsCache = Array.isArray(res.data) ? res.data : (res.data.treatments || []);
          renderTreatmentList(treatmentsCache);
        } catch (err) {
          treatmentListContainer.html('<div class="no-treatments">Failed to load treatments.</div>');
          console.error('loadTreatmentList error', err);
        }
      }

      // Fetch single treatment by id and populate form
      async function fetchTreatment(id) {
        try {
          const res = await axios.get(`/getTreatmentsById/${id}`);
          const t = res.data.treatment || res.data;
          if (t) {
            $('#treatmentId').val(t.id);
            $('#treatmentName').val(t.name || '');
            $(errorDiv).hide();
          }
        } catch (e) {
          $(errorDiv).removeClass('alert-success').addClass('alert alert-danger')
            .text('Failed to load treatment.').show();
        }
      }

      // New treatment button - reset form and active state
      $('#newTreatmentBtn').on('click', function () {
        activeTreatmentId = null;
        $('.treatment-item').removeClass('active');
        $('#treatmentId').val('');
        $('#TreatmentForm')[0].reset();
        $(errorDiv).hide();
      });

      // Search/filter
      $('#treatmentSearch').on('input', function () {
        const q = $(this).val();
        renderTreatmentList(treatmentsCache, q);
      });

      // Submit form (create/update)
      $(formId).on('submit', async function (e) {
        e.preventDefault();

        // Validate required fields
        let valid = true;
        $(formId + ' [required]').each(function () {
          if (!this.value.trim()) { valid = false; return false; }
        });
        if (!valid) {
          $(errorDiv).removeClass('alert-success').addClass('alert alert-danger')
            .text('Please fill all required fields.').show();
          return;
        }

        const idVal = $('#treatmentId').val();
        const data = {
          name: $('#treatmentName').val()
        };

        try {
          let res;
          if (idVal) {
            // Update existing treatment
            res = await axios.post(`/treatments/update/${idVal}`, data);
          } else {
            // Create new treatment
            res = await axios.post('/treatments/create', data);
          }

          $(errorDiv).removeClass('alert-danger').addClass('alert alert-success')
            .text(res.data.message || 'Treatment saved successfully').show();

          // Refresh list and highlight saved treatment
          const savedId = res.data.id || res.data.treatment?.id || idVal;
          await loadTreatmentList();

          if (savedId) {
            activeTreatmentId = savedId;
            $(`[data-id="${savedId}"]`).addClass('active');
            $('#treatmentId').val(savedId);
          }

          setTimeout(() => $(errorDiv).fadeOut(), 1600);

        } catch (err) {
          const em = err.response?.data?.message || 'Error saving treatment.';
          $(errorDiv).removeClass('alert-success').addClass('alert alert-danger')
            .text(em).show();
        }
      });

      // initial load
      loadTreatmentList();
    });
  </script>
</body>
</html>
