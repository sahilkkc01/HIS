<!doctype html>
<html
  lang="en"
  class="light-style layout-menu-fixed layout-compact"
  dir="ltr"
  data-theme="theme-default"
  data-assets-path="../assets/"
  data-template="vertical-menu-template-free"
  data-style="light">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

    <title>Approve GRN</title>

  <%- include('../header') -%>

          <!-- Content wrapper -->
          <div class="content-wrapper">
            <!-- Content -->
            <div class="container-xxl flex-grow-1 container-p-y">
              <!-- Basic Bootstrap Table -->
              <div class="card">
                <div class="row card-header flex-column flex-md-row pb-4">
				<div class="d-md-flex justify-content-between align-items-center dt-layout-start col-md-auto me-auto mt-0">
				<h5 class="card-title mb-0 text-md-start text-center">All GRN</h5></div>
				<div class="d-md-flex justify-content-between align-items-center dt-layout-end col-md-auto ms-auto mt-0">
				
				<div class="dt-buttons btn-group flex-wrap mb-0"> 
				
				<div class="btn-group">
				<input type="search" class="form-control ms-4" id="searchBox" placeholder="Search" aria-controls="DataTables_Table_1">
				
				<button class="btn buttons-collection btn-label-primary dropdown-toggle me-4" tabindex="0" aria-controls="DataTables_Table_0" type="button" aria-haspopup="dialog" aria-expanded="false"><span><span class="d-flex align-items-center gap-2"><i class="icon-base bx bx-export me-sm-1"></i> <span class="d-none d-sm-inline-block">Export</span></span></span></button></div> 
				
				<button class="btn create-new btn-primary" tabindex="0" id="approveGrn" aria-controls="DataTables_Table_0" type="button"><span><span class="d-flex align-items-center gap-2"></i> <span class="d-none d-sm-inline-block">Approve</span></span></span></button> 
				<button class="btn create-new btn-danger" tabindex="0" id="rejectGrn" aria-controls="DataTables_Table_0" type="button"><span><span class="d-flex align-items-center gap-2 "></i> <span class="d-none d-sm-inline-block">Reject</span></span></span></button> 
				  </div>
				 </div>
				</div>
				
                <div class="table-responsive text-nowrap">
                    <table class="table" id="tblid">
                      <thead>
                        <tr>
                          <th>GRN NO</th>
                          <th>GRN Date</th>
                          <th>Store</th>
                          <th>Entry Gate</th>
                          <th>Supplier</th>
                          <th>Invoice Date</th>
                          <th>Invoice No.</th>
                          <th>Total Amount</th>
                          <th>Total GST</th>
                          <th>Other Charges</th>
                          <th>GRN Discount</th>
                          <th>Net Amount</th>
                          <th>Received By</th>
                          <th>Created By</th>
                          <th>Status</th>
                        </tr>
                      </thead>
                      <tbody id="grnBody" class="table-border-bottom-0"></tbody>
                    </table>
                    <div id="paginationControls"></div>
                  </div>
                  
                  <!-- Items Table -->
                  <div class="table-responsive text-nowrap mt-3">
                    <h5>GRN Items</h5>
                    <table class="table" id="itemsTable">
                      <thead>
                        <tr>
                          <th>Item Name</th>
                          <th>Batch Code</th>
                          <th>Expiry Date</th>
                          <th>MRP</th>
                          <th>Cost Price</th>
                          <th>GST %</th>
                          <th>GST Amount</th>
                          <th>Received Qty</th>
                          <th>Free Qty</th>
                          <th>Total Cost</th>
                          <th>Net Amount</th>
                        </tr>
                      </thead>
                      <tbody id="itemsBody" class="table-border-bottom-0"></tbody>
                    </table>
                  </div>
              </div>
              <!--/ Basic Bootstrap Table -->
            </div>
            <!-- / Content -->

          <%- include('../footer') -%>

         
          <script>
            document.addEventListener("DOMContentLoaded", function () {
              fetchGrnData(); // Initial fetch
          
              // Fetch and display GRN data
              function fetchGrnData() {
                axios.get("/inventory/getAllGrn")
                  .then(response => {
                    const grns = response.data.grns;
                    const tbody = document.getElementById("grnBody");
                    tbody.innerHTML = "";
          
                    grns.forEach(grn => {
                      const row = `
                        <tr data-items='${JSON.stringify(grn.items)}' data-id=${grn.id}>
                          <td>${grn.grnNo}</td>
                          <td>${grn.grnDate}</td>
                          <td>${grn.store}</td>
                          <td>${grn.gateEntryNo || "N/A"}</td>
                          <td>${grn.supplier}</td>
                          <td>${grn.invoiceDate || "N/A"}</td>
                          <td>${grn.invoiceNo || "N/A"}</td>
                          <td>${grn.totalAmount}</td>
                          <td>${grn.totalGst}</td>
                          <td>${grn.otherCharges}</td>
                          <td>${grn.grnDiscount}</td>
                          <td>${grn.netAmount}</td>
                          <td>${grn.receivedBy}</td>
                          <td>${grn.requestedBy}</td>
                          <td>${grn.status}</td>
                        </tr>
                      `;
                      tbody.innerHTML += row;
                    });
          
                    // Pagination (if applicable)
                    pagi_search('#searchBox', '#tblid', '#paginationControls');
                  })
                  .catch(error => console.error("Error fetching GRN data:", error));
              }
          
              // Handle row click to show items and highlight row
              document.getElementById("tblid").addEventListener("click", function (event) {
                const row = event.target.closest("tr");
                if (!row || !row.dataset.items) return;
          
                // Remove highlight from all rows
                document.querySelectorAll("#tblid tr").forEach(tr => tr.classList.remove("selected-row"));
          
                // Highlight the selected row
                row.classList.add("selected-row");
          
                const items = JSON.parse(row.dataset.items);
                const itemsBody = document.getElementById("itemsBody");
                itemsBody.innerHTML = "";
          
                items.forEach(item => {
                  const itemRow = `
                    <tr>
                      <td>${item.item_name}</td>
                      <td>${item.batchCode}</td>
                      <td>${item.expiryDate}</td>
                      <td>${item.mrp}</td>
                      <td>${item.costPrice}</td>
                      <td>${item.gst}</td>
                      <td>${item.gstAmount}</td>
                      <td>${item.receivedQty}</td>
                      <td>${item.freeQty}</td>
                      <td>${item.totalCost}</td>
                      <td>${item.netAmount}</td>
                    </tr>
                  `;
                  itemsBody.innerHTML += itemRow;
                });
              });
          
              // Approve GRN
              document.getElementById("approveGrn").addEventListener("click", function () {
                const selectedRow = document.querySelector(".selected-row");
                if (!selectedRow) {
                  alert("Please select a GRN to approve.");
                  return;
                }
                const grnId = selectedRow.dataset.id;
          
                axios.post(`/inventory/approveGrn/${grnId}`)
                  .then(response => {
                    alert(response.data.message || "GRN Approved Successfully");
                    fetchGrnData(); // Refresh data without reloading
                  })
                  .catch(error => {
                    console.error("Error approving GRN:", error);
                    alert(error.response?.data?.message || "Error approving GRN");
                  });
              });
          
              // Reject GRN
              document.getElementById("rejectGrn").addEventListener("click", function () {
                const selectedRow = document.querySelector(".selected-row");
                if (!selectedRow) {
                  alert("Please select a GRN to reject.");
                  return;
                }
                const grnId = selectedRow.dataset.id;
          
                axios.post(`/inventory/rejectGrn/${grnId}`)
                  .then(response => {
                    alert(response.data.message || "GRN Rejected Successfully");
                    fetchGrnData(); // Refresh data without reloading
                  })
                  .catch(error => {
                    console.error("Error rejecting GRN:", error);
                    alert(error.response?.data?.message || "Error rejecting GRN");
                  });
              });
            });
          </script>
            
          
            
