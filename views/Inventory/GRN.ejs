<!doctype html>
<html
  lang="en"
  class="light-style layout-menu-fixed layout-compact"
  dir="ltr"
  data-theme="theme-default"
  data-assets-path="../assets/"
  data-template="vertical-menu-template-free"
  data-style="light">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

    <title>Indent</title>

    <%- include('../header') -%>

          <!-- Content wrapper -->
          <div class="content-wrapper">
            <!-- Content -->
            <style>.displaynone{display:none;}.bx-qr-scan{font-size:80px;}</style>
            <div class="container-xxl flex-grow-1 container-p-y">
              <div class="row">
                  <!-- Vertical & Horizontal Scrollbars -->
                  <div class="col-12">
                      <div class="card overflow-hidden">
                          <h5 class="card-header">Goods Received Notes</h5>
                          <div class="card">
                              <!-- Account -->
                              <div class="card-body pt-4">
                                  <form id="GRNForm" method="POST">
                                      <!-- First Row -->
                                      <div class="row g-6">
                                          <div class="col-md-4">
                                              <label for="grnNo" class="form-label">GRN No</label>
                                              <input class="form-control" type="text" id="grnNo" name="grnNo" readonly value="" autofocus>
                                          </div>
                                          <div class="col-md-4">
                                              <label for="grnDate" class="form-label">GRN Date</label>
                                              <input class="form-control" type="date" id="grnDate" name="grnDate" value="">
                                          </div>
                                          <div class="col-md-4">
                                              <label for="gateEntryNo" class="form-label">Gate Entry No <span class="required-star">*</span></label>
                                              <select id="gateEntryNo" name="gateEntryNo" class="form-control select2" data-validation="required" data-error-message="Gate Entry No is required.">
                                                  <option value="">Select</option>
                                                  <option value="1">1</option>
                                                  <option value="2">2</option>
                                              </select>
                                          </div>
                                      </div>
          
                                      <!-- Second Row -->
                                      <div class="row g-6 mt-3">
                                          <div class="col-md-4">
                                              <label for="store" class="form-label">Store <span class="required-star">*</span></label>
                                              <select id="store" name="store" class="form-control select2" data-validation="required" data-error-message="Store is required.">
                                                  <option value="">Select</option>
                                              </select>
                                          </div>
                                          <div class="col-md-4">
                                              <label for="supplier" class="form-label">Supplier <span class="required-star">*</span></label>
                                              <select id="supplier" name="supplier" class="form-control select2" data-validation="required" data-error-message="Supplier is required.">
                                                  <option value="">Select</option>
                                              </select>
                                          </div>
                                          <div class="col-md-4">
                                              <label class="form-label">Pay Mode <span class="required-star">*</span></label>
                                              <div class="form-check">
                                                  <input class="form-check-input" type="radio" name="payMode" id="payModeGRC" value="GRC" data-validation="required" data-error-message="Pay Mode is required.">
                                                  <label class="form-check-label" for="payModeGRC">GRC</label>
                                              </div>
                                              <div class="form-check">
                                                  <input class="form-check-input" type="radio" name="payMode" id="payModeCredit" value="Credit">
                                                  <label class="form-check-label" for="payModeCredit">Credit</label>
                                              </div>
                                          </div>
                                      </div>
          
                                      <!-- Third Row: Invoice Details -->
                                      <div class="row g-6 mt-3">
                                          <div class="col-md-4">
                                              <label for="invoiceDate" class="form-label">Invoice Date <span class="required-star">*</span></label>
                                              <input class="form-control" type="date" id="invoiceDate" name="invoiceDate" data-validation="required" data-error-message="Invoice Date is required.">
                                          </div>
                                          <div class="col-md-4">
                                              <label for="invoiceNo" class="form-label">Invoice No <span class="required-star">*</span></label>
                                              <input class="form-control" type="text" id="invoiceNo" name="invoiceNo" data-validation="required" data-error-message="Invoice No is required.">
                                          </div>
                                      </div>
          
                                      <!-- Fourth Row: Get Items -->
                                      <div class="row g-6 mt-3">
                                          <div class="col-md-12">
                                              <div class="form-check-label">
                                                
                                                  <div class="radio d-flex align-items-center mt-2">
                                                      <label class="form-check-label pt-1 pr-2"> Against Purchase Order</label>
                                                      <button type="button" id="getPO" class="btn btn-primary btn-sm ms-2">
                                                          <strong>Get PO</strong>
                                                      </button>
                                                  </div>
                                              </div>
                                          </div>
                                      </div>
                                  </form>
                              </div>
                              <!-- /Account -->
                          </div>
                      </div>
                  </div>
                  <!--/ Vertical & Horizontal Scrollbars -->
          
                  <!-- Items Table -->
                  <div class="card overflow-hidden mt-3">
                      <div class="row card-header flex-column flex-md-row pb-4 col-md-6">
                          <input type="search" class="form-control ms-4 mb-2 mt-2" id="searchBox" placeholder="Search item to Add in GRN" aria-controls="DataTables_Table_1">
                          <ul id="searchResults" class="list-group mt-2" style="display: none;"></ul>
                      </div>
          
                      <div class="table-responsive text-nowrap">
                          <table class="table table-bordered">
                              <thead>
                                  <tr>
                                      <th>Item Code</th>
                                      <th>Item Name</th>
                                      <th>Batch Code</th>
                                      <th>Expiry Date</th>
                                      <th>PO Quantity</th>
                                      <th>PO Pending Quantity</th>
                                      <th>Received Quantity</th>
                                      <th>Free Quantity</th>
                                      <th>UOM</th>
                                      <th>Available Stock</th>
                                      <th>Cost Price</th>
                                      <th>Cost Amount</th>
                                      <th>MRP</th>
                                      <th>Amount</th>
                                      <th>GST %</th>
                                      <th>GST Amount</th>
                                      <th>Net Amount</th>
                                      <th>Remarks</th>
                                      <th>Rack</th>
                                      <th>Shelf</th>
                                      <th>Bin</th>
                                      <th>Action</th>
                                  </tr>
                              </thead>
                              <tbody class="table-border-bottom-0" id="mainTblBody">
                                  <tr>
                                      <td>ITM01</td>
                                      <td>Paracetamol</td>
                                      <td>BATCH001</td>
                                      <td><input class="form-control" type="date" value="2024-12-31"></td>
                                      <td>100</td>
                                      <td>50</td>
                                      <td><input class="form-control" type="number" value="50"></td>
                                      <td><input class="form-control" type="number" value="0"></td>
                                      <td>PCS</td>
                                      <td>200</td>
                                      <td>10.00</td>
                                      <td>500.00</td>
                                      <td>15.00</td>
                                      <td>750.00</td>
                                      <td>12%</td>
                                      <td>90.00</td>
                                      <td>840.00</td>
                                      <td><input class="form-control" type="text" placeholder="Remarks"></td>
                                      <td><input class="form-control" type="text" placeholder="Rack"></td>
                                      <td><input class="form-control" type="text" placeholder="Shelf"></td>
                                      <td><input class="form-control" type="text" placeholder="Bin"></td>
                                      <td>
                                          <button class="btn btn-icon btn-outline-danger">
                                              <i class="bx bx-trash bx-sm"></i>
                                          </button>
                                      </td>
                                  </tr>
                              </tbody>
                          </table>
                      </div>
                  </div>
          
                  <!-- Total Amount and Remarks Section -->
                  <div class="card overflow-hidden mt-3">
                      <div class="card-body pt-4">
                          <div class="row g-6">
                              <div class="col-md-3">
                                  <label class="form-label">Total Amount: </label>
                                  <input class="form-control" type="text" readonly>
                              </div>
                              <div class="col-md-3">
                                  <label class="form-label">GST Amount: </label>
                                  <input class="form-control" type="text" readonly>
                              </div>
                              <div class="col-md-3">
                                  <label class="form-label">Other Charges: </label>
                                  <input class="form-control" type="number" value="0">
                              </div>
                              <div class="col-md-3">
                                  <label class="form-label">GRN Discount: </label>
                                  <input class="form-control" type="number" value="0">
                              </div>
                              <div class="col-md-3">
                                  <label class="form-label">Net Amount: </label>
                                  <input class="form-control" type="text" readonly>
                              </div>
                              <div class="col-md-3">
                                  <label class="form-label">Received By: <span class="required-star">*</span></label>
                                  <select class="form-control select2" data-validation="required" data-error-message="Received By is required.">
                                      <option value="">Select</option>
                                  </select>
                              </div>
                              <div class="col-md-6">
                                  <label class="form-label">Remarks: </label>
                                  <textarea class="form-control" placeholder="Enter remarks"></textarea>
                              </div>
                          </div>
                          <div class="mt-6">
                              <button type="submit" class="btn btn-primary me-3">Save</button>
                              <button type="reset" class="btn btn-outline-secondary">Cancel</button>
                          </div>
                      </div>
                  </div>
              </div>
          </div>
            <!-- / Content -->
					  

              

          <%- include('../footer') -%>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const searchBox = document.getElementById("searchBox");
    const searchResults = document.getElementById("searchResults");
    const mainTblBody = document.getElementById("mainTblBody");
    let itemsData = []; // Store fetched items

    fetchItems();

    // Fetch items from the server
    function fetchItems() {
        axios.get("/inventory/getItems") // Replace with your API endpoint
            .then(response => {
                itemsData = response.data.items; // Store fetched items
                console.log(itemsData);
            })
            .catch(error => {
                console.error("Error fetching items:", error);
            });
    }

    // Filter and display items based on search query
    searchBox.addEventListener("input", function () {
        const query = searchBox.value.toLowerCase();
        if (query) {
            const filteredItems = itemsData.filter(item => 
                item.medicine_name.toLowerCase().includes(query) ||
                item.generic_name.toLowerCase().includes(query) ||
                item.molecule.toLowerCase().includes(query)
            );
            displaySearchResults(filteredItems);
        } else {
            searchResults.style.display = "none";
        }
    });

    // Display search results in the UL
    function displaySearchResults(items) {
        searchResults.innerHTML = ""; // Clear previous results
        if (items.length > 0) {
            items.forEach(item => {
                const li = document.createElement("li");
                li.className = "list-group-item";
                li.textContent = `${item.medicine_name} (${item.molecule}) - ${item.uom}, MRP-${item.mrp} Cost Price-${item.cost_price} GST-${item.gst}%`;
                li.addEventListener("click", () => selectItem(item));
                searchResults.appendChild(li);
            });
            searchResults.style.display = "block";
        } else {
            searchResults.style.display = "none";
        }
    }

    // Add selected item to the mainTblBody
    function selectItem(item) {
        // Prevent duplicate entries
        if (document.querySelector(`#mainTblBody tr[data-id="${item.id}"]`)) {
            alert("Item already added!");
            return;
        }

        const row = document.createElement("tr");
        row.setAttribute("data-id", item.id);
        row.innerHTML = `
            <td>${item.id || "ITM" + Math.floor(Math.random() * 1000)}</td>
            <td>${item.medicine_name}</td>
            <td><input class="form-control" type="text" value="BATCH001"></td>
            <td><input class="form-control" type="date"></td>
            <td><input class="form-control" type="number" value="100"></td>
            <td><input class="form-control" type="number" value="50"></td>
            <td><input class="form-control receivedQty" type="number" value="0"></td>
            <td><input class="form-control freeQty" type="number" value="0"></td>
            <td>${item.uom}</td>
            <td>${item.available_stock || 0}</td>
            <td>${item.cost_price}</td>
            <td class="costAmount">0.00</td>
            <td>${item.mrp}</td>
            <td class="totalAmount">0.00</td>
            <td>${item.gst}%</td>
            <td class="gstAmount">0.00</td>
            <td class="netAmount">0.00</td>
            <td><input class="form-control" type="text" placeholder="Remarks"></td>
            <td><input class="form-control" type="text" placeholder="Rack"></td>
            <td><input class="form-control" type="text" placeholder="Shelf"></td>
            <td><input class="form-control" type="text" placeholder="Bin"></td>
            <td>
                <button class="btn btn-icon btn-outline-danger" onclick="removeItem(this)">
                    <i class="bx bx-trash bx-sm"></i>
                </button>
            </td>
        `;

        mainTblBody.appendChild(row);
        searchResults.style.display = "none"; // Hide search results after selection
        searchBox.value = ""; // Clear search box

        attachEventListeners(row);
    }

    // Remove item from the table
    window.removeItem = function (button) {
        button.closest("tr").remove();
    };

    // Attach event listeners for cost calculations
    function attachEventListeners(row) {
        const receivedQty = row.querySelector(".receivedQty");
        const freeQty = row.querySelector(".freeQty");
        const costAmount = row.querySelector(".costAmount");
        const totalAmount = row.querySelector(".totalAmount");
        const gstAmount = row.querySelector(".gstAmount");
        const netAmount = row.querySelector(".netAmount");

        receivedQty.addEventListener("input", updateAmounts);
        freeQty.addEventListener("input", updateAmounts);

        function updateAmounts() {
            const costPrice = parseFloat(row.cells[10].textContent) || 0;
            const gstPercent = parseFloat(row.cells[14].textContent) || 0;
            const received = parseInt(receivedQty.value) || 0;
            const free = parseInt(freeQty.value) || 0;
            const totalQty = received + free;

            const cost = received * costPrice;
            const gst = (cost * gstPercent) / 100;
            const total = cost + gst;

            costAmount.textContent = cost.toFixed(2);
            gstAmount.textContent = gst.toFixed(2);
            totalAmount.textContent = total.toFixed(2);
            netAmount.textContent = total.toFixed(2);
        }
    }
});

</script>