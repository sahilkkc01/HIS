<!doctype html>
<html
  lang="en"
  class="light-style layout-menu-fixed layout-compact"
  dir="ltr"
  data-theme="theme-default"
  data-assets-path="../assets/"
  data-template="vertical-menu-template-free"
  data-style="light">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

    <title>GRN</title>

    <%- include('../header') -%>

          <!-- Content wrapper -->
          <div class="content-wrapper">
            <!-- Content -->
            <style>.displaynone{display:none;}.bx-qr-scan{font-size:80px;}</style>
            <div class="container-xxl flex-grow-1 container-p-y">
                <form id="GRNForm" method="POST">
              <div class="row">
                  <!-- Vertical & Horizontal Scrollbars -->
                  <div class="col-12">
                      <div class="card overflow-hidden">
                          <h5 class="card-header">Goods Received Notes</h5>
                          <div class="card">
                              <!-- Account -->
                              <div class="card-body pt-4">
                                
                                    <div id="errordiv"></div>
                                      <!-- First Row -->
                                      <div class="row g-6">
                                          <div class="col-md-4">
                                              <label for="grnNo" class="form-label">GRN No</label>
                                              <input class="form-control" disabled type="text" id="grnNo" name="grnNo" readonly value="" autofocus>
                                          </div>
                                          <div class="col-md-4">
                                              <label for="grnDate" class="form-label">GRN Date</label>
                                              <input class="form-control" readonly type="date" id="grnDate" name="grnDate" value="">
                                          </div>
                                          <div class="col-md-4">
                                              <label for="gateEntryNo" class="form-label">Gate Entry No <span class="required-star">*</span></label>
                                              <select id="gateEntryNo" name="gateEntryNo" class="form-control select2" data-validation="required" data-error-message="Gate Entry No is required.">
                                                  <option value="">Select</option>
                                                  <option value="1">1</option>
                                                  <option value="2">2</option>
                                              </select>
                                          </div>
                                      </div>
          
                                      <!-- Second Row -->
                                      <div class="row g-6 mt-3">
                                          <div class="col-md-4">
                                              <label for="store" class="form-label">Store <span class="required-star">*</span></label>
                                              <select id="store" name="store"  class="form-control select2" data-validation="required" data-error-message="Please enter store">
                                                  <option value="">Select</option>
                                                  <option value="add-new">add-new</option>
                                              </select>
                                          </div>
                                          <div class="col-md-4">
                                              <label for="supplier" class="form-label">Supplier <span class="required-star">*</span></label>
                                              <select id="supplier" name="supplier" class="form-control select2" data-validation="required" data-error-message="Please enter supplier.">
                                                  <option value="">Select</option>
                                                  <option value="demo">Demo</option>
                                              </select>
                                          </div>
                                          <div class="col-md-4">
                                              <label class="form-label">Pay Mode <span class="required-star">*</span></label>
                                              <div class="form-check">
                                                  <input class="form-check-input" type="radio" name="payMode" id="payModeGRC" value="GRC" data-validation="required" data-error-message="Please enter pay mode">
                                                  <label class="form-check-label" for="payModeGRC">GRC</label>
                                              </div>
                                              <div class="form-check">
                                                  <input class="form-check-input" type="radio" name="payMode" id="payModeCredit" value="Credit">
                                                  <label class="form-check-label" for="payModeCredit">Credit</label>
                                              </div>
                                          </div>
                                      </div>
          
                                      <!-- Third Row: Invoice Details -->
                                      <div class="row g-6 mt-3">
                                          <div class="col-md-4">
                                              <label for="invoiceDate" class="form-label">Invoice Date <span class="required-star">*</span></label>
                                              <input class="form-control" type="date" id="invoiceDate" name="invoiceDate" data-validation="required" data-error-message="Please enter Invoice Date .">
                                          </div>
                                          <div class="col-md-4">
                                              <label for="invoiceNo" class="form-label">Invoice No <span class="required-star">*</span></label>
                                              <input class="form-control" type="text" id="invoiceNo" name="invoiceNo" data-validation="required" data-error-message="Please enter Invoice No.">
                                          </div>
                                      </div>
          
                                      <!-- Fourth Row: Get Items -->
                                      <div class="row g-6 mt-3">
                                          <div class="col-md-12">
                                              <div class="form-check-label">
                                                
                                                  <div class="radio d-flex align-items-center mt-2">
                                                      <label class="form-check-label pt-1 pr-2"> Against Purchase Order</label>
                                                      <button type="button" id="getPOs" class="btn btn-primary btn-sm ms-2">
                                                          <strong>Get PO</strong>
                                                      </button>
                                                  </div>
                                              </div>
                                          </div>
                                      </div>
                                
                              </div>
                              <!-- /Account -->
                          </div>
                      </div>
                  </div>
                  <!--/ Vertical & Horizontal Scrollbars -->
          
                  <!-- Items Table -->
                  <div class="card overflow-hidden mt-3">
                      <div class="row card-header flex-column flex-md-row pb-4 col-md-6">
                          <input type="search" class="form-control ms-4 mb-2 mt-2" id="searchBox" placeholder="Search item to Add in GRN" aria-controls="DataTables_Table_1">
                          <ul id="searchResults" class="list-group mt-2" style="display: none;"></ul>
                      </div>
                      <div id="poInfo" class="alert alert-primary text-center mx-3" style="display: none;">
                        PO No: <strong id="selectedPONo"></strong>
                        <input type="hidden" name="poNo" id="poNo">
                    </div>
                    
                      <div class="table-responsive text-nowrap">
                          <table class="table table-bordered" id="dataTable">
                              <thead>
                                  <tr>
                                      <th>Item Name</th>
                                      <th>Batch Code*</th>
                                      <th>Expiry Date*</th>
                                      <th style="min-width: 140px;">PO Qty</th>
                                      <th>PO Pending Qty</th>
                                      <th>Received Qty*</th>
                                      <th>Free Qty</th>
                                      <th>UOM</th>
                                    
                                      <th style="min-width: 142px;">MRP/Unit</th>
                                      <th>Total MRP</th>
                                      <th  style="min-width: 142px;">Cost/Unit</th>
                                      <th>Total Cost</th>
                                      <th>Discount</th>
                                      <th>GST %</th>
                                      <th>GST Amount</th>
                                      <th>Net Amount</th>
                                      <th>Remarks</th>
                                      <th>Rack</th>
                                      <th>Shelf</th>
                                      <th>Bin</th>
                                      <th>Action</th>
                                  </tr>
                              </thead>
                              <tbody class="table-border-bottom-0" id="mainTblBody">
                                 
                              </tbody>
                          </table>
                      </div>
                  </div>
          
                  <!-- Total Amount and Remarks Section -->
                  <div class="card overflow-hidden mt-3">
                      <div class="card-body pt-4">
                          <div class="row g-6">
                              <div class="col-md-3">
                                  <label class="form-label">Total Amount: </label>
                                  <input class="form-control" id="totalAmount" name="totalAmount" type="number" readonly>
                              </div>
                              <div class="col-md-3">
                                  <label class="form-label">GST Amount: </label>
                                  <input class="form-control" id="totalGst" name="totalGst" type="number" readonly>
                              </div>
                              <div class="col-md-3">
                                  <label class="form-label">Other Charges: </label>
                                  <input class="form-control" id="otherCharges" name="otherCharges" type="number" value="0">
                              </div>
                              <div class="col-md-3">
                                  <label class="form-label">GRN Discount: </label>
                                  <input class="form-control" id="grnDiscount" name="grnDiscount" type="number" value="0">
                              </div>
                              <div class="col-md-3">
                                  <label class="form-label">Net Amount: </label>
                                  <input class="form-control" id="netAmount" name="netAmount" type="text" readonly>
                              </div>
                              <div class="col-md-3">
                                  <label class="form-label">Received By: <span class="required-star">*</span></label>
                                  <select class="form-control select2" id="receivedBy" name="receivedBy" data-validation="required" data-error-message="Received By is required.">
                                      <option value="">Select</option>
                                  </select>
                              </div>
                              <div class="col-md-6">
                                  <label class="form-label">Remarks: </label>
                                  <textarea class="form-control" id="remark" name="remark" placeholder="Enter remarks"></textarea>
                              </div>
                          </div>
                          <div id="loadingIndicator"></div>
                          <div class="mt-6">
                              <button type="submit" class="btn btn-primary me-3">Save</button>
                              <button type="reset" onclick=" window.location.href = '/inventory/grn-list'" class="btn btn-outline-secondary">Cancel</button>
                          </div>
                      </div>
                  </div>
              </div>
                </form>
          </div>
            <!-- / Content -->
					  
<!-- Purchase Order Modal -->
<div class="modal fade" id="poModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Purchase Order Details</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
  
          <!-- Search Box -->
          <div class="mb-3">
            <input type="text" id="poSearch" class="form-control" placeholder="Search Purchase Order...">
          </div>
  
          <!-- Purchase Order Table -->
          <div class="table-responsive text-nowrap">
            <table class="table" id="poTable">
              <thead>
                <tr>
                  <th>PO No</th>
                  <th>PO Date</th>
                  <th>Indent No</th>
                  <th>Store</th>
                  <th>Supplier</th>
                  <th>Payment Mode</th>
                  <th>Expected Delivery</th>
                  <th>Payment Terms</th>
                  <th>Total GST</th>
                  <th>Other Charges</th>
                  <th>PO Discount</th>
                  <th>Net Amount</th>
                  <th>Created By</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody id="poBody" class="table-border-bottom-0"></tbody>
            </table>
            <div id="poPaginationControls"></div>
          </div>
  
          <!-- Purchase Order Items Table -->
          <div class="table-responsive text-nowrap mt-3">
            <h5>PO Items</h5>
            <table class="table" id="poItemsTable">
              <thead>
                <tr>
                  <th>Item Name</th>
                  <th>UOM</th>
                  <th>MRP</th>
                  <th>Cost Price</th>
                  <th>Order Qty</th>
                  <th>Order Pending Qty</th>
                  <th>GST %</th>
                  <th>GST Amount</th>
                  <th>Total Cost</th>
                  <th>Net Amount</th>
                </tr>
              </thead>
              <tbody id="poItemsBody" class="table-border-bottom-0"></tbody>
            </table>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" id="addPO" class="btn btn-primary me-2">Add</button>
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>
  
              

          <%- include('../footer') -%>
       <script>
        document.addEventListener("DOMContentLoaded", function () {
    const searchBox = document.getElementById("searchBox");
    const searchResults = document.getElementById("searchResults");
    const mainTblBody = document.getElementById("mainTblBody");
    const totalAmountInput = document.getElementById("totalAmount");
    const totalGstInput = document.getElementById("totalGst");
    const otherChargesInput = document.getElementById("otherCharges");
    const grnDiscountInput = document.getElementById("grnDiscount");
    const netAmountInput = document.getElementById("netAmount");

    let itemsData = [];

    fetchItems();

    function fetchItems() {
        axios.get("/inventory/getItems")
            .then(response => {
                itemsData = response.data.items;
            })
            .catch(error => {
                console.error("Error fetching items:", error);
            });
    }

    searchBox.addEventListener("input", function () {
        const query = searchBox.value.toLowerCase();
        if (query) {
            const filteredItems = itemsData.filter(item =>
                item.medicine_name.toLowerCase().includes(query) ||
                item.molecule.toLowerCase().includes(query)
            );
            displaySearchResults(filteredItems);
        } else {
            searchResults.style.display = "none";
        }
    });

    function displaySearchResults(items) {
        searchResults.innerHTML = "";
        if (items.length > 0) {
            items.forEach(item => {
                const li = document.createElement("li");
                li.className = "list-group-item";
                li.textContent = `${item.medicine_name} (${item.molecule}) - ${item.uom}, MRP-${item.mrp} Cost-${item.cost_price} GST-${item.gst}%`;
                li.addEventListener("click", () => selectItem(item));
                searchResults.appendChild(li);
            });
            searchResults.style.display = "block";
        } else {
            searchResults.style.display = "none";
        }
    }

    function selectItem(item) {
        if (document.querySelector(`#mainTblBody tr[data-id="${item.id}"]`)) {
            alert("Item already added!");
            return;
        }

        const row = document.createElement("tr");
        row.setAttribute("data-id", item.id);
        row.innerHTML = `
    <td data-key="item_name">${item.medicine_name}</td>
    <td><input class="form-control batchCode" type="text" data-key="batchCode" data-validation="required" data-error-message="Please enter Batch Code."></td>
    <td><input class="form-control expiryDate" type="date" data-key="expiryDate" data-validation="required futureDate" data-error-message="Please enter Expiry Date."></td>
    <td><input class="form-control poQuantity" disabled data-key="poQuantity" type="number"></td>
    <td><input class="form-control poPendingQty" disabled data-key="poPendingQty" type="number"></td>
    <td><input class="form-control receivedQty" type="number" data-key="receivedQty" value="0" min="1" data-validation="required greaterThanZero" data-error-message="Please enter Received Qty."></td>
    <td><input class="form-control freeQty" type="number" data-key="freeQty" value="0"></td>
    <td data-key="uom">${item.uom}</td>

    <td><input class="form-control mrp" type="number" data-key="mrp" value="${item.mrp}"></td>
    <td class="totalMRP" data-key="totalMRP">0.00</td>
    <td><input class="form-control costPrice" type="number" data-key="costPrice" value="${item.cost_price}"></td>
    <td class="totalCost" data-key="totalCost">0.00</td>
    <td><input class="form-control discount" type="number" data-key="discount" value="0" max="90"></td>
    <td data-key="gst">${item.gst}</td>
    <td class="gstAmount" data-key="gstAmount">0.00</td>
    <td class="netAmount" data-key="netAmount">0.00</td>
    <td><input class="form-control remarks" type="text" data-key="remarks" placeholder="Remarks"></td>
    <td><input class="form-control rack" type="text" data-key="rack" placeholder="Rack"></td>
    <td><input class="form-control shelf" type="text" data-key="shelf" placeholder="Shelf"></td>
    <td><input class="form-control bin" type="text" data-key="bin" placeholder="Bin"></td>
    <td>
        <button class="btn btn-icon btn-outline-danger" onclick="removeItem(this)">
            <i class="bx bx-trash bx-sm"></i>
        </button>
    </td>
`;

        mainTblBody.appendChild(row);
        searchResults.style.display = "none";
        searchBox.value = "";

        attachEventListeners(row);
        updateTotalValues(); // Recalculate total when adding a new item
    }

    window.removeItem = function (button) {
        button.closest("tr").remove();
        updateTotalValues(); // Recalculate total after removing an item
    };

    function attachEventListeners(row) {
    const receivedQty = row.querySelector(".receivedQty");
    const freeQty = row.querySelector(".freeQty");
    const discount = row.querySelector(".discount");
    const mrpInput = row.querySelector(".mrp");
    const costPriceInput = row.querySelector(".costPrice");
    const pendingQty = parseFloat(row.querySelector(".poPendingQty").value) || 0; // Get pending PO qty

    receivedQty.addEventListener("input", updateAmounts);
    discount.addEventListener("input", updateAmounts);
    mrpInput.addEventListener("input", updateAmounts);
    costPriceInput.addEventListener("input", updateAmounts);

    function updateAmounts() {
        const totalMRP = row.querySelector(".totalMRP");
        const totalCost = row.querySelector(".totalCost");
        const gstAmount = row.querySelector(".gstAmount");
        const netAmount = row.querySelector(".netAmount");

        let mrp = parseFloat(mrpInput.value) || 0;
        let costPrice = parseFloat(costPriceInput.value) || 0;
        let gstPercent = parseFloat(row.cells[13].textContent) || 0;
        let received = parseInt(receivedQty.value) || 0;
        let free = parseInt(freeQty.value) || 0;
        let discountValue = parseFloat(discount.value) || 0;
        let totalQty = received;

        // ✅ Validate Received Quantity (should not exceed Pending PO Quantity)
        if (document.getElementById("poNo").value && received > pendingQty) {
            alert("Received Quantity cannot exceed Pending PO Quantity.");
            receivedQty.value = pendingQty;
            received = pendingQty;
        }

        // ✅ Validate Discount (should not exceed 90%)
        if (discountValue > 90) {
            alert("Discount cannot exceed 90%.");
            discount.value = 90;
            discountValue = 90;
        }

        // ✅ Calculate values
        const totalMRPValue = totalQty * mrp;
        const totalCostValue = totalQty * costPrice;
        const discountAmount = (totalCostValue * discountValue) / 100;
        const costAfterDiscount = totalCostValue - discountAmount;
        const gst = (costAfterDiscount * gstPercent) / 100;
        const netTotal = costAfterDiscount + gst;

        totalMRP.textContent = totalMRPValue.toFixed(2);
        totalCost.textContent = totalCostValue.toFixed(2);
        gstAmount.textContent = gst.toFixed(2);
        netAmount.textContent = netTotal.toFixed(2);

        updateTotalValues();
    }
}
function updateTotalValues() {
    let totalAmount = 0;
    let totalGst = 0;
    let netAmount = 0;

    document.querySelectorAll("#mainTblBody tr").forEach(row => {
        totalAmount += parseFloat(row.querySelector(".totalCost").textContent) || 0;
        totalGst += parseFloat(row.querySelector(".gstAmount").textContent) || 0;
        netAmount += parseFloat(row.querySelector(".netAmount").textContent) || 0;
    });

    const otherCharges = parseFloat(otherChargesInput.value) || 0;
    let grnDiscount = parseFloat(grnDiscountInput.value) || 0;

    // ✅ Validate GRN Discount (cannot be more than Net Amount)
    if (grnDiscount > netAmount) {
        alert("GRN Discount cannot exceed the Net Amount.");
        grnDiscountInput.value = netAmount.toFixed(2);
        grnDiscount = netAmount;
    }

    totalAmountInput.value = totalAmount.toFixed(2);
    totalGstInput.value = totalGst.toFixed(2);
    netAmountInput.value = (netAmount + otherCharges - grnDiscount).toFixed(2);
}

// ✅ Attach event listeners to update total values dynamically
otherChargesInput.addEventListener("input", updateTotalValues);
grnDiscountInput.addEventListener("input", updateTotalValues);

    function fetchPOs(store) {
  if (!store) {
    alert("Please select a store first.");
    return;
  }

  axios.get(`/inventory/getPOsByStore/${encodeURIComponent(store)}`)
    .then(response => {
      const poList = response.data.purchaseOrders;
      const tbody = document.getElementById("poBody");
      tbody.innerHTML = ""; // Clear previous data

      poList.forEach(po => {
        const row = `
          <tr data-items='${JSON.stringify(po.items)}' data-id="${po.id}" data-pono="${po.poNo}">
            <td>${po.poNo}</td>
            <td>${po.poDate}</td>
            <td>${po.indentNo || "N/A"}</td>
            <td>${po.store}</td>
            <td>${po.supplier}</td>
            <td>${po.paymentMode}</td>
            <td>${po.expectedDeliveryDate}</td>
            <td>${po.paymentTerms || "N/A"}</td>
            <td>${po.totalGst}</td>
            <td>${po.otherCharges || "0"}</td>
            <td>${po.poDiscount || "0"}</td>
            <td>${po.netAmount}</td>
            <td>${po.createdBy}</td>
            <td>${po.status}</td>
          </tr>
        `;
        tbody.innerHTML += row;
      });

      // Enable search and pagination for PO table
      pagi_search("#poSearch", "#poTable", "#poPaginationControls");
    })
    .catch(error => console.error("Error fetching PO data:", error));
}

document.getElementById("getPOs").addEventListener("click", function () {
  const storeElement = document.getElementById("store");
  const store = storeElement.value;

  if (!store) {
    alert("Please select a valid store.");
    return;
  }

  fetchPOs(store);
  $("#poModal").modal("show"); // Show PO modal
});

let selectedPONumber = null;
let selectedPOItems = [];
// Handle PO selection to show items
document.getElementById("poTable").addEventListener("click", function (event) {
    const row = event.target.closest("tr");
    if (!row || !row.dataset.items) return;

    // Remove selection from all rows and highlight the selected row
    document.querySelectorAll("#poTable tr").forEach(tr => tr.classList.remove("selected-row"));
    row.classList.add("selected-row");

    // Store selected PO number and items (REMOVE `const` to update global variables)
    selectedPONumber = row.dataset.pono; // FIX: No `const`
    selectedPOItems = JSON.parse(row.dataset.items); // FIX: No `const`

    $('#poNo').val(selectedPONumber); // Set PO number in input field

    const itemsBody = document.getElementById("poItemsBody");
    itemsBody.innerHTML = "";

    selectedPOItems.forEach(item => {
        const itemRow = `
            <tr>
                <td>${item.item_name}</td>
                <td>${item.uom}</td>
                <td>${item.mrpUnit}</td>
                <td>${item.costPrice}</td>
                <td>${item.orderQty}</td>
                <td>${item.orderPendingQty || item.orderQty}</td>
                <td>${item.gst}</td>
                <td>${item.gstAmount}</td>
                <td>${item.totalCost}</td>
                <td>${item.netAmount}</td>
            </tr>
        `;
        itemsBody.innerHTML += itemRow;
    });
});

document.getElementById("addPO").addEventListener("click", function () {
    if (selectedPOItems.length === 0) {
        alert("Please select a PO first.");
        return;
    }

    if (!selectedPONumber) {
        alert("PO number is missing. Please select a PO again.");
        return;
    }

    // Update and show PO No.
    document.getElementById("selectedPONo").textContent = selectedPONumber;
    document.getElementById("poInfo").style.display = "block";

    const mainTableBody = document.getElementById("mainTblBody");
    mainTableBody.innerHTML = ""; // Clear existing items before adding new ones

    selectedPOItems.forEach(item => {
        const newRow = document.createElement("tr");
        newRow.innerHTML = `
            <td data-key="item_name">${item.item_name}</td>
            <td><input class="form-control batchCode" type="text" data-key="batchCode" data-validation="required" data-error-message="Please enter Batch Code."></td>
            <td><input class="form-control expiryDate" type="date" data-key="expiryDate" data-validation="required futureDate" data-error-message="Please enter Expiry Date."></td>
            <td><input class="form-control poQuantity" disabled data-key="poQuantity" type="number" value="${item.orderQty}"></td>
            <td><input class="form-control poPendingQty" disabled data-key="poPendingQty" type="number" value="${item.poPendingQty || item.orderQty}"></td>
            <td><input class="form-control receivedQty" type="number" data-key="receivedQty" value="0" min="1" data-validation="required greaterThanZero" data-error-message="Please enter Received Qty."></td>
            <td><input class="form-control freeQty" type="number" data-key="freeQty" value="0"></td>
            <td data-key="uom">${item.uom}</td>
       
            <td><input class="form-control mrp" type="number" data-key="mrp" readonly value="${item.mrpUnit}"></td>
            <td class="totalMRP" data-key="totalMRP">0.00</td>
            <td><input class="form-control costPrice" type="number" data-key="costPrice" readonly value="${item.costPrice}"></td>
            <td class="totalCost" data-key="totalCost">0.00</td>
