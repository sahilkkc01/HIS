<!doctype html>
<html lang="en" class="light-style layout-menu-fixed layout-compact" dir="ltr" data-theme="theme-default">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stock Transactions</title>
    <%- include('../header') -%>
</head>
<body>
    <div class="content-wrapper">
        <div class="container-xxl flex-grow-1 container-p-y">
            <div class="card">
                <div class="row card-header flex-column flex-md-row pb-4">
                    <div class="d-md-flex justify-content-between align-items-center col-md-auto me-auto">
                        <h5 class="card-title mb-0">Stock Transactions</h5>
                    </div>
                    <div class="d-md-flex justify-content-between align-items-center col-md-auto ms-auto">
                        <div class="btn-group">
                            <input type="search" class="form-control" id="searchBox" placeholder="Search Transactions">
                        </div>
                        <button class="btn btn-success ms-2" id="exportTransactions">
                            <i class="bx bx-download"></i> Export Excel
                        </button>
                    </div>
                </div>
                
                <div class="table-responsive text-nowrap">
                    <table class="table" id="transactionTable">
                        <thead>
                            <tr>
                                <th>Transaction ID</th>
                                <th>Store</th>
                                <th>GRN ID</th>
                                <th>Type</th>
                                <th>Item Name</th>
                                <th>Batch Code</th>
                                <th>Expiry Date</th>
                                <th>Quantity</th>
                                <th>Cost Price</th>
                                <th>Total Cost</th>
                                <th>Net Amount</th>
                                <th>Transaction Date</th>
                            </tr>
                        </thead>
                        <tbody id="transactionBody"></tbody>
                    </table>
                    <div id="paginationControls"></div>
                </div>
            </div>
        </div>
    </div>
    
    <%- include('../footer') -%>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            axios.get("/inventory/getAllStockTransactions")
                .then(response => {
                    console.log(response);
                    const transactions = response.data.transactions;
                    const tbody = document.getElementById("transactionBody");
                    tbody.innerHTML = "";

                    transactions.forEach(transaction => {
                        const row = `
                            <tr>
                                <td>${transaction.id}</td>
                                <td>${transaction.store}</td>
                                <td>${transaction.grnId || "N/A"}</td>
                                <td>${transaction.transactionType}</td>
                                <td>${transaction.itemName}</td>
                                <td>${transaction.batchCode}</td>
                                <td>${transaction.expiryDate || "N/A"}</td>
                                <td>${transaction.quantity}</td>
                                <td>${transaction.costPrice.toFixed(2)}</td>
                                <td>${transaction.totalCost.toFixed(2)}</td>
                                <td>${transaction.netAmount.toFixed(2)}</td>
                                <td>${new Date(transaction.transactionDate).toLocaleString()}</td>
                            </tr>
                        `;
                        tbody.innerHTML += row;
                    });

                    pagi_search('#searchBox', '#transactionTable', '#paginationControls');
                })
                .catch(error => {
                    console.error("Error fetching transactions:", error);
                });
        });
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.17.3/xlsx.full.min.js"></script>
    <script>
    document.getElementById("exportTransactions").addEventListener("click", function () {
        let table = document.getElementById("transactionTable");
        let ws = XLSX.utils.table_to_sheet(table);
        let wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "StockTransactions");
    
        // Export to Excel file
        XLSX.writeFile(wb, "stock_transactions.xlsx");
    });
    </script>
</body>
</html>
