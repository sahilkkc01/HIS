<!doctype html>
<html lang="en" class="light-style layout-menu-fixed layout-compact" dir="ltr" data-theme="theme-default">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Current Stock</title>
    <%- include('../header') -%>
</head>
<body>
    <div class="content-wrapper">
        <div class="container-xxl flex-grow-1 container-p-y">
            <div class="card">
                <div class="row card-header flex-column flex-md-row pb-4">
                    <div class="d-md-flex justify-content-between align-items-center col-md-auto me-auto">
                        <h5 class="card-title mb-0">Current Stock</h5>
                    </div>
                    <div class="d-md-flex justify-content-between align-items-center col-md-auto ms-auto">
                        <div class="btn-group">
                            <input type="search" class="form-control" id="searchBox" placeholder="Search Stock">
                        </div>
                        <button class="btn btn-success ms-2" id="exportStock">
                            <i class="bx bx-download"></i> Export Excel
                        </button>
                    </div>
                </div>
                
                <div class="table-responsive text-nowrap">
                    <table class="table" id="stockTable">
                        <thead>
                            <tr>
                                <th>Store</th>
                                <th>Item Name</th>
                                <th>Batch Code</th>
                                <th>Expiry Date</th>
                                <th>Available Stock</th>
                                <th>MRP</th>
                                <th>Cost Price</th>
                                <th>GST</th>
                                <th>GST Amount</th>
                                <th>Total Cost</th>
                                <th>Net Amount</th>
                                <th>Last Updated</th>
                            </tr>
                        </thead>
                        <tbody id="stockBody"></tbody>
                    </table>
                    <div id="paginationControls"></div>
                </div>
            </div>
            
        </div>
    </div>
    
    <%- include('../footer') -%>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            axios.get("/inventory/getCurrentStock")
                .then(response => {
                    console.log(response)
                    const stocks = response.data.stock;
                    const tbody = document.getElementById("stockBody");
                    tbody.innerHTML = "";

                    stocks.forEach(stock => {
                        const row = `
                            <tr>
                                <td>${stock.store || "N/A"}</td>
                                <td>${stock.itemName || "N/A"}</td>
                                <td>${stock.batchCode || "N/A"}</td>
                                <td>${stock.expiryDate || "N/A"}</td>
                                <td>${stock.availableStock}</td>
                                <td>${stock.mrp}</td>
                                <td>${stock.costPrice}</td>
                                <td>${stock.gst}</td>
                                <td>${stock.gstAmount}</td>
                                <td>${stock.totalCost}</td>
                                <td>${stock.netAmount}</td>
                                <td>${new Date(stock.lastUpdated).toLocaleString()}</td>
                            </tr>
                        `;
                        tbody.innerHTML += row;
                    });
                    pagi_search('#searchBox', '#stockTable', '#paginationControls');
                })
                .catch(error => {
                    console.error("Error fetching stock data:", error);
                });
        });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.17.3/xlsx.full.min.js"></script>
    <script>
    document.getElementById("exportStock").addEventListener("click", function () {
        let table = document.getElementById("stockTable");
        let ws = XLSX.utils.table_to_sheet(table);
        let wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "CurrentStock");
    
        // Export to Excel file
        XLSX.writeFile(wb, "current_stock.xlsx");
    });
    </script>
    
</body>
</html>