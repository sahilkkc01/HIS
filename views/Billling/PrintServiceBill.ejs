<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Service Invoice</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<style>
body{background:#f4f6f9}
.invoice-box{background:#fff;max-width:900px;margin:auto;border:1px solid #ddd}
.top-bar{background:#2f8db3;color:#fff;padding:20px}
.logo{height:80px}
.section{padding:20px;border-top:1px solid #eee}
.table th{background:#f1f1f1}
.total-box{font-size:18px;font-weight:600}
</style>
</head>

<body>

<div class="invoice-box mt-4">

<div class="top-bar d-flex justify-content-between align-items-center">
<div>
<img src="../images/crmlogo.png" class="logo">
</div>
<div class="text-end">
<h4>Service Invoice</h4>
<div id="invoiceMeta"></div>
</div>
</div>

<div class="section row">
<div class="col-md-6">
<h6>From</h6>
<div>Your Clinic Name</div>
<div>Your Address</div>
</div>
<div class="col-md-6 text-end">
<h6>To</h6>
<div id="patientName"></div>
<div id="patientAddress"></div>
</div>
</div>

<div class="section row text-center">
<div class="col-md-4">
<div>Invoice No</div>
<div id="billId"></div>
</div>
<div class="col-md-4">
<div>Date</div>
<div id="billDate"></div>
</div>
<div class="col-md-4">
<div>Doctor</div>
<div id="doctor"></div>
</div>
</div>

<div class="section">
<table class="table table-bordered">
<thead>
<tr>
<th>#</th>
<th>Service</th>
<th>Amount</th>
</tr>
</thead>
<tbody id="servicesTableBody"></tbody>
</table>
</div>

<div class="section">
<div class="row">
<div class="col-md-6">
<p><strong>Payment Mode:</strong> <span id="modeOfPayment"></span></p>
<p><strong>Remark:</strong> <span id="remark"></span></p>
</div>

<div class="col-md-6 text-end">
<p>Discount: ₹<span id="discountAmount"></span></p>
<p>Tax: ₹<span id="taxAmount"></span></p>
<h5 class="total-box">Total: ₹<span id="netAmount"></span></h5>
</div>
</div>
</div>

</div>

<script>
document.addEventListener("DOMContentLoaded",function(){

const billIdParam='<%=billId%>';

axios.get(`/billing/getServiceBill/${billIdParam}`)
.then(res=>{

const bill=res.data;

document.getElementById("billId").textContent=bill.id;
document.getElementById("billDate").textContent=new Date(bill.createdAt).toLocaleDateString();
document.getElementById("doctor").textContent=bill.doctor||"-";

document.getElementById("modeOfPayment").textContent=bill.modeOfPayment;
document.getElementById("remark").textContent=bill.remark||"-";

document.getElementById("discountAmount").textContent=bill.discountAmount||0;
document.getElementById("taxAmount").textContent=bill.taxAmount||0;
document.getElementById("netAmount").textContent=bill.netAmount;

if(bill.patient){
const p=bill.patient;

const name=[p.prefix,p.firstName,p.middleName,p.lastName].filter(Boolean).join(" ");
document.getElementById("patientName").textContent=name;
document.getElementById("patientAddress").textContent=[p.address,p.city,p.state].filter(Boolean).join(", ");
}

const tbody=document.getElementById("servicesTableBody");
tbody.innerHTML="";

bill.services.forEach((s,i)=>{
tbody.innerHTML+=`
<tr>
<td>${i+1}</td>
<td>${s.name}</td>
<td>₹${s.amount}</td>
</tr>`;
});

})
.catch(err=>{
console.error(err);
alert("Failed to load service bill");
});

});
</script>

</body>
</html>