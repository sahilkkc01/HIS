           <script>
            $(document).ready(function() {
    $('input[name="opbill"]').change(function() {
        if ($('#nwpat').is(':checked')) {
            $('#nwp').show();  
            $('#extp').hide().find("input, select, textarea, span").not("#categoryDropdown, #newPatientGender").val("").text(""); // Clear except specific IDs
        } else if ($('#extpat').is(':checked')) {
            $('#extp').show();  
            $('#nwp').hide().find("input, select, textarea, span").not("#categoryDropdown, #newPatientGender").val("").text(""); // Clear except specific IDs
        }
    });
});

           </script>

              <script>
                $(document).ready(function () {
    $("#searchPatient").click(function () {
        let category = $("#categoryDropdown").val();
        let searchValue = $("#searhcValue").val().trim();

        if (!searchValue) {
            alert("Please enter a search value.");
            return;
        }

        axios.get(`/patientFilter`, {
            params: { [category]: searchValue }
        })
        .then(response => {
            if (response.data) {
              console.log(response)
                let patient = response.data;
                $("#patientId").val(patient.id);
                $("#patientName").text(patient.name);
                $("#patientGender").text((patient.gender === "M" ? "Male" : patient.gender === "F" ? "Female" : "Other"));
                $("#patientAge").text( patient.age + " Y");
                $("#patientBloodGroup").text( patient.bloodGroup);
                $("#patientUHID").text( patient.uhid);
                $("#patientMobile").text( patient.mobile);
                // $("#patientAdvance").text("Advance: " + (patient.advance || "N/A"));
                // $("#patientBalance").text("Balance: " + (patient.balance || "N/A"));
                // $("#patientPackage").text("Package: " + (patient.package || "NA"));
            } else {
                alert("Patient not found.");
            }
        })
        .catch(error => {
            console.error("Error fetching patient data:", error);
            alert(error.response.data.message || 'Patient not found');
        });
    });
});

document.addEventListener("DOMContentLoaded", function () {
    const searchBox = document.getElementById("searchBox");
    const searchResults = document.getElementById("searchResults");
    const mainTblBody = document.getElementById("mainTblBody");
    const netAmount = document.getElementById("netAmount");
    const discountCat = document.getElementById("discountCat");
    const discountVal = document.getElementById("discountVal");
    const dicountAmount = document.getElementById("dicountAmount");
    const totalGst = document.getElementById("totalGst");
    const remark = document.getElementById("remark");
    const doctor = document.getElementById("doctor");
    const generateBillBtn = document.getElementById("generateBill");

    let itemsData = [];

    function fetchItems() {
        axios.get("/inventory/getItems")
            .then(response => {
                itemsData = response.data.items;
            })
            .catch(error => {
                console.error("Error fetching items:", error);
            });
    }
    fetchItems();

    searchBox.addEventListener("input", function () {
        const query = searchBox.value.toLowerCase().trim();
        if (query) {
            const filteredItems = itemsData.filter(item =>
                item.medicine_name.toLowerCase().includes(query) ||
                item.molecule.toLowerCase().includes(query)
            );
            displaySearchResults(filteredItems);
        } else {
            searchResults.style.display = "none";
        }
    });

    function displaySearchResults(items) {
        searchResults.innerHTML = "";
        if (items.length > 0) {
            items.forEach(item => {
                const li = document.createElement("li");
                li.className = "list-group-item";
                li.textContent = `${item.medicine_name} (${item.molecule}) - ${item.uom}, MRP-${item.mrp} Cost-${item.cost_price} GST-${item.gst}%`;
                li.addEventListener("click", () => selectItem(item));
                searchResults.appendChild(li);
            });
            searchResults.style.display = "block";
        } else {
            searchResults.style.display = "none";
        }
    }

    function selectItem(item) {
        if (document.querySelector(`#mainTblBody tr[data-id="${item.id}"]`)) {
            alert("Item already added!");
            return;
        }

        const gstRate = item.gst;
        const basePrice = item.mrp / (1 + gstRate / 100);
        const gstAmount = item.mrp - basePrice;

        const row = document.createElement("tr");
        row.setAttribute("data-id", item.id);
        row.setAttribute("data-gst", gstRate);
        row.innerHTML = `
            <td>${mainTblBody.children.length + 1}</td>
            <td>${item.medicine_name}</td>
            <td><input class="form-control indentQty" type="number" value="1" min="1"></td>
            <td>${item.uom}</td>
            <td><input class="form-control gstAmount" type="number" value="${gstAmount.toFixed(2)}" readonly></td>
            <td><input class="form-control mrp" type="number" value="${item.mrp}" readonly></td>
            <td><input class="form-control totalPrice" type="number" value="${item.mrp}" readonly></td>
            <td>
                <button class="btn btn-icon btn-outline-danger removeItem">
                    <i class="bx bx-trash bx-sm"></i>
                </button>
            </td>
        `;

        mainTblBody.appendChild(row);
        searchResults.style.display = "none";
        searchBox.value = "";

        attachEventListeners(row);
        updateTotalValues();
    }

    function attachEventListeners(row) {
        const indentQty = row.querySelector(".indentQty");
        indentQty.addEventListener("input", updateTotalValues);

        const removeButton = row.querySelector(".removeItem");
        removeButton.addEventListener("click", function () {
            row.remove();
            updateTotalValues();
        });
    }

    function updateTotalValues() {
        let totalAmount = 0;
        let totalTax = 0;

        document.querySelectorAll("#mainTblBody tr").forEach((row, index) => {
            row.children[0].textContent = index + 1;

            const indentQty = parseInt(row.querySelector(".indentQty")?.value) || 0;
            const mrp = parseFloat(row.querySelector(".mrp")?.value) || 0;
            const gstRate = parseFloat(row.getAttribute("data-gst")) || 0;

            const basePrice = mrp / (1 + gstRate / 100);
            const totalBasePrice = basePrice * indentQty;
            const gstAmount = (mrp - basePrice) * indentQty;

            row.querySelector(".gstAmount").value = gstAmount.toFixed(2);
            row.querySelector(".totalPrice").value = (mrp * indentQty).toFixed(2);

            totalAmount += totalBasePrice;
            totalTax += gstAmount;
        });

        applyDiscount(totalAmount, totalTax);
    }

    function applyDiscount(totalAmount, totalTax) {
    let discount = parseFloat(discountVal.value) || 0;

    if (discountCat.value === "P") {
        if (discount > 100) {
            discount = 100;
            discountVal.value = 100; // Enforce max 100 in input field
        }
        discount = (totalAmount * discount) / 100;
    } else if (discountCat.value === "A") {
        if (discount > totalAmount) {
            discount = totalAmount;
            discountVal.value = totalAmount.toFixed(2); // Enforce max discount to totalAmount
        }
    }

    dicountAmount.textContent = discount.toFixed(2);
    totalGst.textContent = totalTax.toFixed(2);
    netAmount.textContent = (totalAmount - discount + totalTax).toFixed(2);
}

// Prevent input greater than 100% for percentage discounts
discountVal.addEventListener("input", function () {
    if (discountCat.value === "P" && parseFloat(discountVal.value) > 100) {
        discountVal.value = 100; // Restrict input to 100
    }
    updateTotalValues(); // Recalculate totals
});


    discountCat.addEventListener("change", updateTotalValues);
    discountVal.addEventListener("input", updateTotalValues);

    generateBillBtn.addEventListener("click", function () {
    const isExistingPatient = document.getElementById("extpat").checked;
    let patientId = document.getElementById("patientId").value.trim();
    let patientName, patientGender, patientAge, patientMobile;

    if (isExistingPatient) {
        if (!patientId) {
            alert("Please select an existing patient before generating the bill.");
            return;
        }
        patientName = document.getElementById("patientName").textContent.trim();
        patientGender = document.getElementById("patientGender").textContent.trim();
        patientAge = document.getElementById("patientAge").textContent.trim();
        patientMobile = document.getElementById("patientMobile").textContent.trim();
    } else {
        // New patient validation
        patientName = document.getElementById("newPatientName").value.trim();
        patientGender = document.getElementById("newPatientGender").value.trim();
        patientAge = document.getElementById("newPatientAge").value.trim();
        patientMobile = document.getElementById("newPatientMobile").value.trim();

        if (!patientName) {
            alert("Please enter the new patient's name.");
            return;
        }
    }

    const items = [];
    document.querySelectorAll("#mainTblBody tr").forEach(row => {
        items.push({
            id: row.getAttribute("data-id"),
            name: row.children[1].textContent,
            quantity: row.querySelector(".indentQty").value,
            uom: row.children[3].textContent,
            mrp: row.querySelector(".mrp").value,
            total: row.querySelector(".totalPrice").value,
            gstAmount: row.querySelector(".gstAmount").value
        });
    });
    if (items.length === 0) {
        alert("Please add at least one item before generating the bill.");
        return;
    }
    const billData = {
        patientId: isExistingPatient ? patientId : null, // Send null if new patient
        patientName,
        patientGender,
        patientAge,
        patientMobile,
        items,
        discountCategory: discountCat.value,
        discountValue: discountVal.value,
        discountAmount: dicountAmount.textContent,
        taxAmount: totalGst.textContent,
        netAmount: netAmount.textContent,
        remark: remark.value,
        doctor: doctor.value
    };
console.log(billData)
    axios.post("/billing/generateBill", billData)
        .then(response => {
          console.log(response)
            alert("Bill generated successfully!");
            const route='billing/PrintBill'
            ViewBtn(route,response.data.billId)
         
        })
        .catch(error => {
            console.error("Error generating bill:", error);
        });
});

  });

loadDropdown('doctor', 'Doctor', 'name', '')
              </script>