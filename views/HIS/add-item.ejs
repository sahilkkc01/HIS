<!doctype html>
<html lang="en" class="light-style layout-menu-fixed layout-compact" dir="ltr" data-theme="theme-default"
  data-assets-path="../assets/" data-template="vertical-menu-template-free" data-style="light">

<head>
  <meta charset="utf-8" />
  <meta name="viewport"
    content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

  <title>Add Item/Medicine</title>

  <%- include('../header') -%>

    <!-- Content wrapper -->
    <div class="content-wrapper">
      <!-- Content -->
      <style>
        .displaynone {
          display: none;
        }

        .bx-qr-scan {
          font-size: 80px;
        }
      </style>
      <div class="container-xxl flex-grow-1 container-p-y">
        <div class="row">
          <!-- Vertical & Horizontal Scrollbars -->
          <div class="col-12">
            <div class="card overflow-hidden">
              <h5 class="card-header">Add Medicine</h5>
              <div class="card">
                <!-- Account -->
                <div class="card-body pt-4">
                  <form id="addItemForm" method="post" enctype="multipart/form-data">
                    <div id="errordiv"></div>
                    <div class="row g-6">
                      <div class="col-md-6">
                        <label for="name" class="form-label">Medicine Name*</label>
                        <input class="form-control" type="text" id="name" name="medicine_name" value="" autofocus="">
                      </div>
                      <div class="col-md-3">
                        <label for="language" class="form-label">Molecule*</label>
                        <select id="brandName" name="brand_name" class="select2 form-select">
                          <option value="">Select</option>
                          <option value="add-new">Add New</option>
                        </select>
                      </div>
                      <div class="col-md-3">
                        <label class="form-label" for="genericName">Generic Name</label>
                        <div class="input-group">
                          <input type="text" id="genericName" name="generic_name" class="form-control" placeholder="">
                        </div>
                      </div>
                      <div class="col-md-3">
                        <label for="language" class="form-label">Brand Name</label>
                        <select id="brandName" name="brand_name" class="select2 form-select">
                          <option value="">Select</option>
                          <option value="add-new">Add New</option>
                        </select>
                      </div>
                      <div class="col-md-3">
                        <label for="language" class="form-label">Dosage Form</label>
                        <select id="dosageForm" name="dosage_form" class="select2 form-select">
                          <option value="">Select</option>
                          <option value="Tablet">Tablet</option>
                          <option value="Capsule">Capsule</option>
                          <option value="Injection">Injection</option>
                          <option value="Syrup">Syrup</option>
                          <option value="add-new">Add New</option>
                        </select>
                      </div>

                      <div class="col-md-3">
                        <label for="language" class="form-label">Strength</label>
                        <input class="form-control" type="text" id="strength" name="strength" value="" placeholder="">
                      </div>
                      <div class="col-md-3">
                        <label for="language" class="form-label">Strength Unit</label>
                        <select id="brandName" name="brand_name" class="select2 form-select">
                          <option value="">Select</option>
                          <option value="mg">mg</option>
                          <option value="add-new">Add New</option>
                        </select>
                      </div>
                      <div class="col-md-3">
                        <label for="language" class="form-label">Manufacturer</label>
                        <select id="manufacturer" name="manufacturer" class="select2 form-select">
                          <option value="">Select</option>
                          <option value="add-new">Add New</option>
                        </select>
                      </div>
                      <div class="col-md-3">
                        <label for="language" class="form-label">UOM*</label>
                        <select id="manufacturer" name="manufacturer" class="select2 form-select">
                          <option value="">Select</option>
                          <option value="add-new">Add New</option>
                        </select>
                      </div>
                      <div class="col-md-3">
                        <label for="language" class="form-label">Other UOM</label>
                        <select id="manufacturer" name="manufacturer" class="select2 form-select">
                          <option value="">Select</option>
                          <option value="add-new">Add New</option>
                        </select>
                      </div>
                      
                      <div class="col-md-3">
                        <label for="language" class="form-label">Conversion Factor</label>
                        <input class="form-control" type="number" id="buyPrice" name="buy_price" value=""
                          placeholder="">
                      </div>
                      <div class="col-md-3">
                        <label for="language" class="form-label">MRP*</label>
                        <input class="form-control" type="number" id="buyPrice" name="buy_price" value=""
                          placeholder="">
                      </div>
                      <div class="col-md-3">
                        <label for="language" class="form-label">Buying Price</label>
                        <input class="form-control" type="number" id="buyPrice" name="buy_price" value=""
                          placeholder="">
                      </div>
                      <div class="col-md-3">
                        <label for="language" class="form-label">Selling Price</label>
                        <input class="form-control" type="number" id="sellPrice" name="sell_price" value=""
                          placeholder="">
                      </div>
                      <div class="col-md-3">
                        <label for="language" class="form-label">Storage Conditions</label>
                        <input class="form-control" type="text" id="storageCond" name="storage_condition" value=""
                          placeholder="">
                      </div>
                      <div class="col-md-3">
                        <label for="language" class="form-label">Prescription Required</label>
                        <select id="prescReq" name="prescription_req" class="select2 form-select">
                          <option value="">Select</option>
                          <option value="Yes">Yes</option>
                          <option value="No">No</option>
                        </select>
                      </div>

                      <div class="col-md-3">
                        <label for="language" class="form-label">Interactions</label>
                        <input class="form-control" type="text" id="interaction" name="interactions" value=""
                          placeholder="">
                      </div>

                      <div class="col-md-3">
                        <label for="language" class="form-label">Category*</label>
                        <select id="category" name="category" class="select2 form-select">
                          <option value="">Select</option>
                          <option value="Antibiotic">Antibiotic</option>
                          <option value="Analgesic">Analgesic</option>
                          <option value="Antipyretic">Antipyretic</option>
                          <option value="add-new">Add New</option>
                        </select>
                      </div>
                      <div class="col-md-3">
                        <label for="language" class="form-label">HSN Code*</label>
                        <select id="category" name="category" class="select2 form-select">
                          <option value="">Select</option>
                          <option value="9001">90001</option>
                      
                        </select>
                      </div>

                      <div class="col-md-4">
                        <label for="formFile" class="form-label">Item Image</label>
                        <input class="form-control" type="file" id="itemImage" name="itemImage"
                          accept="image/png, image/jpeg, image/jpg">
                      </div>
                    </div>
                    <div id="loadingIndicator"></div>
                    <div class="mt-6">
                      <button type="submit" class="btn btn-primary me-3">Save</button>
                      <button type="reset" class="btn btn-outline-secondary">Cancel</button>
                    </div>
                  </form>
                </div>
                <!-- /Account -->
              </div>
            </div>
          </div>
          <!--/ Vertical & Horizontal Scrollbars -->
        </div>
      </div>
      <!-- / Content -->


      <%- include('../footer') -%>
        <script>

          $(document).ready(function () {
            console.log("Document is ready");

            const formId = '#addItemForm';
            const errorDivId = '#errordiv';

            document.getElementById('itemImage').addEventListener('change', function (event) {
              // Just validate the file input without calling previewImage
              validateFileInput("itemImage", ["image/jpeg", "image/jpg", "image/png"], 800);
            });

            $(formId).on('submit', async function (event) {
              event.preventDefault(); // Prevent the form from submitting

              const { isValid, errorMessage } = validateForm(formId);

              if (isValid) {
                const url = '/save-item';
                const loadingDiv = '#loadingIndicator';

                try {
                  $(loadingDiv).show(); // Show loading indicator

                  const response = await saveForm(formId, url); // Perform the form submission

                  console.log('Success:', response);
                  $(errorDivId).removeClass('alert-danger').addClass('alert-success').text(response.message).show();
                } catch (error) {
                  console.error('Error:', error);
                  $(errorDivId).removeClass('alert-success').addClass('alert-danger').text(` ${error.message || 'Unknown error'}`).show();
                } finally {
                  $(loadingDiv).hide(); // Hide loading indicator after submission
            
                }
              } else {
                $(errorDivId).removeClass('alert-success').addClass('alert-danger').text(errorMessage).show();
              }
            });
          });

        </script>