	  <script>
document.addEventListener("DOMContentLoaded", function () {
  const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];
  const scheduleContainer = document.getElementById("scheduleAccordion");
  const dayTemplate = document.getElementById("day-template");

  days.forEach((day, index) => {
    const dayElement = dayTemplate.cloneNode(true);
    dayElement.style.display = "";
    dayElement.id = ""; // Remove template ID
    const uniqueID = `collapse-${index}`;

    // Set unique IDs for collapse functionality
    const collapseButton = dayElement.querySelector(".accordion-button");
    const collapseDiv = dayElement.querySelector(".accordion-collapse");
    collapseButton.setAttribute("data-bs-target", `#${uniqueID}`);
    collapseDiv.id = uniqueID;

    // Set day name
    dayElement.querySelector(".day-name").textContent = day;

    // Append to schedule container
    scheduleContainer.appendChild(dayElement);

    // Handle Not Open checkbox
    const notOpenCheckbox = dayElement.querySelector(".not-open-checkbox");
    const accordionBody = dayElement.querySelector(".accordion-body");
    const addSlotButton = dayElement.querySelector(".add-slot");
    const scheduleSlots = dayElement.querySelector(".schedule-slots");
    const copyDayButton = dayElement.querySelector(".copy-day");

    notOpenCheckbox.addEventListener("change", function () {
      if (this.checked) {
        // Hide slots and add slot button, disable copy button
        scheduleSlots.style.display = "none";
        addSlotButton.style.display = "none";
        copyDayButton.disabled = true;

        // Clear time values for slots when "Not Open" is checked
        const slots = scheduleSlots.querySelectorAll(".slot");
        slots.forEach(function(slot) {
          const fromTimeInput = slot.querySelector(".from-time");
          const toTimeInput = slot.querySelector(".to-time");
          fromTimeInput.value = ""; // Clear "From" time
          toTimeInput.value = ""; // Clear "To" time
        });
      } else {
        // Show slots and add slot button, enable copy button
        scheduleSlots.style.display = "";
        addSlotButton.style.display = "";
        copyDayButton.disabled = false;
      }
    });

    // Handle Add Slot
    addSlotButton.addEventListener("click", function () {
      const newSlot = document.createElement("div");
      newSlot.classList.add("slot", "mb-3", "d-flex", "align-items-center");
      newSlot.innerHTML = `
        <input type="time" class="form-control me-2 from-time" name="from-time[]" placeholder="From Time">
        <input type="time" class="form-control me-2 to-time" name="to-time[]" placeholder="To Time">
        <button class="btn btn-danger btn-sm remove-slot">Remove</button>
      `;
      scheduleSlots.appendChild(newSlot);

      // Handle Remove Slot
      newSlot.querySelector(".remove-slot").addEventListener("click", function () {
        newSlot.remove();
      });
    });

    // Handle Copy to All Days
    copyDayButton.addEventListener("click", function () {
      const isNotOpen = notOpenCheckbox.checked;
      const slots = scheduleSlots.querySelectorAll(".slot");

      // Copy to all other days
      Array.from(scheduleContainer.children).forEach((otherDay) => {
        if (otherDay !== dayElement) {
          const otherCheckbox = otherDay.querySelector(".not-open-checkbox");
          const otherSlots = otherDay.querySelector(".schedule-slots");
          const otherAddSlotButton = otherDay.querySelector(".add-slot");
          const otherCopyDayButton = otherDay.querySelector(".copy-day");

          if (isNotOpen) {
            // Mark as "Not Open Today"
            otherCheckbox.checked = true;
            otherSlots.style.display = "none"; // Hide slots
            otherAddSlotButton.style.display = "none"; // Hide add slot button
            otherCopyDayButton.disabled = true; // Disable copy button
          } else {
            // Uncheck the checkbox and make the day open
            otherCheckbox.checked = false;
            otherSlots.style.display = ""; // Show slots
            otherAddSlotButton.style.display = ""; // Show add slot button
            otherCopyDayButton.disabled = false; // Enable copy button

            // Clear the existing slots before copying new ones
            otherSlots.innerHTML = "";

            // Copy the slots
            slots.forEach((slot) => {
              const fromTime = slot.querySelector(".from-time").value;
              const toTime = slot.querySelector(".to-time").value;

              // Create a new slot element
              const newSlot = document.createElement("div");
              newSlot.classList.add("slot", "mb-3", "d-flex", "align-items-center");
              newSlot.innerHTML = `
                <input type="time" class="form-control me-2 from-time" name="from-time[]" placeholder="From Time" value="${fromTime}">
                <input type="time" class="form-control me-2 to-time" name="to-time[]" placeholder="To Time" value="${toTime}">
                <button class="btn btn-danger btn-sm remove-slot">Remove</button>
              `;
              
              // Add the slot to the other day
              otherSlots.appendChild(newSlot);

              // Re-attach the event listener for "Remove"
              newSlot.querySelector(".remove-slot").addEventListener("click", function () {
                newSlot.remove();
              });
            });
          }
        }
      });
    });
  });
});


$(document).ready(function () {
    console.log("Document is ready");

    const formId = '#DoctorRegForm';
    const errorDivId = '#errordiv';

    $(formId).on('submit', async function (event) {
        event.preventDefault(); // Prevent the form from submitting

        const { isValid, errorMessage } = validateForm(formId);

        if (isValid) {
            const url = '/doctor-reg';
            const loadingDiv = '#loadingIndicator';

            try {
                $(loadingDiv).show(); // Show loading indicator
                const form = document.getElementById('DoctorRegForm');
                if (!form) throw new Error(`Form with ID '${formId}' not found.`);

                // Use FormData to collect the form data
                const formData = new FormData(form);

                // Collect day-wise data in JSON format
                const daysData = {};

                // Assuming the schedule slots for each day are stored in elements with the class 'schedule-slots'
                $('.schedule-slots').each(function (index, daySlots) {
                    const dayName = $(daySlots).closest('.accordion-item').find('.day-name').text().trim();
                    const slots = [];

                    // Check if there are slots for the current day
                    $(daySlots).find('.slot').each(function () {
                        const fromTime = $(this).find('.from-time').val();
                        const toTime = $(this).find('.to-time').val();
                        if (fromTime && toTime) {
                            slots.push({ fromTime, toTime });
                        }
                    });

                    // Only include the day if there are slots
                    if (slots.length > 0 && dayName) {
                        daysData[dayName] = slots;
                    }
                });

                // Add the day-wise data to the FormData object as 'appointmentCalendar'
                // Remove the 'on' and '' entries
                if (Object.keys(daysData).length > 0) {
                    formData.append('appointmentCalendar', JSON.stringify(daysData));
                }

                // Make an axios POST request to submit the form data
                const response = await axios.post(url, formData, {
                    headers: {
                        'Content-Type': 'multipart/form-data',
                    },
                });

                console.log('Success:', response.data);
                $(errorDivId).removeClass('alert-danger').addClass('alert-success').text(response.data.message).show();
            } catch (error) {
                console.error('Error:', error);
                $(errorDivId).removeClass('alert-success').addClass('alert-danger').text(` ${error.response.data.message || 'Unknown error'}`).show();
            } finally {
                $(loadingDiv).hide(); // Hide loading indicator after submission
            }
        } else {
            $(errorDivId).removeClass('alert-success').addClass('alert-danger').text(errorMessage).show();
        }
    });
});

