<!doctype html>
<html
  lang="en"
  class="light-style layout-menu-fixed layout-compact"
  dir="ltr"
  data-theme="theme-default"
  data-assets-path="../assets/"
  data-template="vertical-menu-template-free"
  data-style="light">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

    <title>Doctor Registration</title>

   <%- include('../header') -%>

          <!-- Content wrapper -->
          <div class="content-wrapper">
            <!-- Content -->
            <style>.displaynone{display:none;}.bx-qr-scan{font-size:80px;}</style>
            <div class="container-xxl flex-grow-1 container-p-y">
              <div class="row">
                <!-- Vertical & Horizontal Scrollbars -->
                <div class="col-12">
                  <div class="card overflow-hidden">
                    <h5 class="card-header">Doctor Registration</h5>
                    <div class="card">
                    <!-- Account -->
                    <div class="card-body">
					<div class="row border-bottom">
					<div class="col-10 col-xs-12">
                      <div class="d-flex align-items-start align-items-sm-center gap-6 pb-4">
                        <img src="../images/1.png" alt="user-avatar" class="d-block w-px-100 h-px-100 rounded" id="uploadedAvatar">
                        <div class="button-wrapper">
                          <label data-bs-toggle="tooltip" data-bs-offset="0,4" data-bs-placement="top" data-bs-html="true" title="<span>Upload from local Storage</span>" for="upload" class="btn btn-primary me-3 mb-4" tabindex="0">
                            <span class="bx bx-upload"></span>
                            <input type="file" id="upload" class="account-file-input" hidden="" accept="image/png, image/jpeg">
                          </label>
						  <label data-bs-toggle="tooltip" data-bs-offset="0,4" data-bs-placement="top" data-bs-html="true" title="<span>Upload from Webcam</span>" for="upload" class="btn btn-primary me-3 mb-4" tabindex="0">
							<span class="bx bxs-webcam"></span>
                            <input type="file" id="upload" class="account-file-input" hidden="" accept="image/png, image/jpeg">
                          </label>
                          <button data-bs-toggle="tooltip" data-bs-offset="0,4" data-bs-placement="top" data-bs-html="true" title="<span>Reset</span>" type="button" class="btn btn-outline-secondary account-image-reset mb-4">
                            <span class="bx bx-reset"></span>
                          </button>

                          <div>Allowed JPG, JPEG or PNG. Max size of 800K</div>
                        </div>
						</div>
						
                      </div>
					  <div class="col-2 text-center d-none d-sm-block">
						<i class='bx bx-qr-scan'></i>
						<div>Scan to Register</div>
					  </div>
					</div>
                    </div>
                    <div class="card-body pt-4">
                      <form id="formAccountSettings" method="POST" onsubmit="return false">
                        <div class="row g-6">
                          <div class="col-md-6">
                            <label for="firstName" class="form-label">Name*</label>
                            <input class="form-control" type="text" id="firstName" name="firstName" value="" autofocus="">
                          </div>
                          <div class="col-md-6">
                            <label class="form-label" for="phoneNumber">Mobile Number*</label>
                            <div class="input-group input-group-merge">
                              <span class="input-group-text">IND (+91)</span>
                              <input type="text" id="phoneNumber" name="phoneNumber" class="form-control" placeholder="">
                            </div>
                          </div>
                          <div class="col-md-6">
                            <label for="email" class="form-label">E-mail</label>
                            <input class="form-control" type="text" id="email" name="email" value="" placeholder="">
                          </div>
                          <div class="col-md-3">
                            <label for="language" class="form-label">Gender</label>
                            <select id="language" class="select2 form-select">
                              <option value="">Select</option>
                              <option value="M">Male</option>
                              <option value="F">Female</option>
                              <option value="O">Other</option>
                            </select>
                          </div>
                          <div class="col-md-3">
                            <label for="address" class="form-label">Practicing Since*</label>
                            <input type="number" class="form-control" id="age" name="age" placeholder="Enter Year">
                          </div>
                          <div class="col-md-6">
                            <label for="address" class="form-label">Qualifications</label>
                            <input type="text" class="form-control" id="address" name="address" placeholder="">
                          </div>
						  <div class="col-md-3">
                            <label for="language" class="form-label">Specilization</label>
                            <select id="categoryDropdown" class="select2 form-select">
                              <option value="">Select</option>
                              <option value="add-new">Add New</option>
                            </select>
                          </div>
						  <div class="col-md-3">
                            <label for="address" class="form-label">Reg No.</label>
                            <input type="text" class="form-control" id="otdetails" name="otdetails" placeholder="">
                          </div>
						  
						  <div class="col-md-3">
                            <label for="address" class="form-label">Consultation Fees</label>
                            <input type="text" class="form-control" id="otdetails" name="otdetails" placeholder="">
                          </div>
						  
						  <div class="col-md-3">
                            <div class="col-md">
                          <small class="fw-medium d-block">Services</small>
                          <div class="form-check form-check-inline mt-3">
                            <input class="form-check-input" type="checkbox" id="inlineCheckbox1" value="option1">
                            <label class="form-check-label" for="inlineCheckbox1">OPD</label>
                          </div>
                          <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" id="inlineCheckbox2" value="option2">
                            <label class="form-check-label" for="inlineCheckbox2">IPD</label>
                          </div>
                        </div>
                          </div>
						  
						  <div class="col-md-6">
                            <label for="address" class="form-label">Other Details</label>
                            <input type="text" class="form-control" id="otdetails" name="otdetails" placeholder="">
                          </div>
                          <div class="col-md-6">
						  <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="" id="defaultCheck3">
                            <label class="form-check-label" for="defaultCheck3"> Appointment Calender </label>
						   </div>
                          </div>
						  <div id="markvisit" class="row g-4 displaynone">
						<div id="schedule" class="col-7">
						<!-- Days of the week -->
						<div class="accordion" id="scheduleAccordion">
						<!-- Template for each day -->
						<div class="accordion-item" id="day-template" style="display: none;">
						<h2 class="accordion-header">
						<button class="accordion-button" type="button" data-bs-toggle="collapse">
						<span class="day-name"></span>
						</button>
						</h2>
						<div class="accordion-collapse collapse">
						<div class="accordion-body">
						<div class="d-flex justify-content-between align-items-center mb-3">
						<div>
						<input type="checkbox" class="form-check-input not-open-checkbox"> Not Open Today
						</div>
						<button class="btn btn-primary btn-sm copy-day">Copy to All Days</button>
						</div>
						<div class="schedule-slots">
						<div class="slot mb-3 d-flex align-items-center">
						<input type="time" class="form-control me-2" placeholder="From Time">
						<input type="time" class="form-control me-2" placeholder="To Time">
						<button class="btn btn-danger btn-sm remove-slot">Remove</button>
						</div>
						</div>
						<button class="btn btn-success btn-sm add-slot">+ Add Slot</button>
						</div>
						</div>
						</div>
						<!-- Days (Generated dynamically in JavaScript) -->
						</div>
						</div>


						</div>
						<!--Mark visit div close-->
                        </div>
                        <div class="mt-6">
                          <button type="submit" class="btn btn-primary me-3">Save</button>
                          <button type="reset" class="btn btn-outline-secondary">Cancel</button>
                        </div>
                      </form>
                    </div>
                    <!-- /Account -->
                  </div>
                  </div>
                </div>
                <!--/ Vertical & Horizontal Scrollbars -->
              </div>
            </div>
            <!-- / Content -->
			
			<!-- Small Modal -->
                      <div class="modal fade" id="smallModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-sm" role="document">
                          <div class="modal-content">
                            <div class="modal-header">
                              <h5 class="modal-title" id="exampleModalLabel2">Add Speciality</h5>
                              <button
                                type="button"
                                class="btn-close"
                                data-bs-dismiss="modal"
                                aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                              <div class="row">
                                <div class="col mb-6">
                                  <label for="nameSmall" class="form-label">Speciality</label>
                                  <input type="text" id="nameSmall" class="form-control" placeholder="" />
                                </div>
                              </div>
                            </div>
                            <div class="modal-footer">
                              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                                Close
                              </button>
                              <button type="button" class="btn btn-primary">Save</button>
                            </div>
                          </div>
                        </div>
                      </div>
					  

           <%- include('../footer') -%>
	
	<!-- Extra Js for this Page-->
	<script>
    $(document).ready(function () {
    $("#defaultCheck3").on("change", function () {
    if ($(this).is(":checked")) {
      $("#markvisit").removeClass("displaynone"); // Show the element
    } else {
      $("#markvisit").addClass("displaynone"); // Hide the element
    }
    });
    });
    </script>
	 <script>
    $(document).ready(function () {
      // Show modal when "Add New" is selected
      $('#categoryDropdown').on('change', function () {
        if ($(this).val() === 'add-new') {
          $('#smallModal').modal('show');
        }
      });
    });
  </script>
  
	
	  <script>
document.addEventListener("DOMContentLoaded", function () {
  const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];
  const scheduleContainer = document.getElementById("scheduleAccordion");
  const dayTemplate = document.getElementById("day-template");

  days.forEach((day, index) => {
    const dayElement = dayTemplate.cloneNode(true);
    dayElement.style.display = "";
    dayElement.id = ""; // Remove template ID
    const uniqueID = `collapse-${index}`;

    // Set unique IDs for collapse functionality
    const collapseButton = dayElement.querySelector(".accordion-button");
    const collapseDiv = dayElement.querySelector(".accordion-collapse");
    collapseButton.setAttribute("data-bs-target", `#${uniqueID}`);
    collapseDiv.id = uniqueID;

    // Set day name
    dayElement.querySelector(".day-name").textContent = day;

    // Append to schedule container
    scheduleContainer.appendChild(dayElement);

    // Handle Not Open checkbox
    const notOpenCheckbox = dayElement.querySelector(".not-open-checkbox");
    const accordionBody = dayElement.querySelector(".accordion-body");
    notOpenCheckbox.addEventListener("change", function () {
      if (this.checked) {
        accordionBody.classList.add("locked");
      } else {
        accordionBody.classList.remove("locked");
      }
    });

    // Handle Add Slot
    const addSlotButton = dayElement.querySelector(".add-slot");
    const scheduleSlots = dayElement.querySelector(".schedule-slots");
    addSlotButton.addEventListener("click", function () {
      const newSlot = document.createElement("div");
      newSlot.classList.add("slot", "mb-3", "d-flex", "align-items-center");
      newSlot.innerHTML = `
        <input type="time" class="form-control me-2" placeholder="From Time">
        <input type="time" class="form-control me-2" placeholder="To Time">
        <button class="btn btn-danger btn-sm remove-slot">Remove</button>
      `;
      scheduleSlots.appendChild(newSlot);

      // Handle Remove Slot
      newSlot.querySelector(".remove-slot").addEventListener("click", function () {
        newSlot.remove();
      });
    });

    // Handle Copy to All Days
    const copyDayButton = dayElement.querySelector(".copy-day");
    copyDayButton.addEventListener("click", function () {
      const slotsHTML = scheduleSlots.innerHTML;

      // Copy to all other days
      Array.from(scheduleContainer.children).forEach((otherDay) => {
        if (otherDay !== dayElement) {
          const otherSlots = otherDay.querySelector(".schedule-slots");
          otherSlots.innerHTML = slotsHTML;

          // Re-attach event listeners for new slots
          Array.from(otherSlots.querySelectorAll(".remove-slot")).forEach((removeButton) => {
            removeButton.addEventListener("click", function () {
              this.closest(".slot").remove();
            });
          });
        }
      });
    });
  });
});
  </script>
  <!-- Extra Js for this Page End-->
