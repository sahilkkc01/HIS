<!doctype html>
<html lang="en" class="light-style" dir="ltr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Clinic Master</title>
  <%- include('../header') -%>
  <style>
    /* same list styles as Doctor page */
    .clinic-list { max-height: 70vh; overflow-y: auto; }
    .clinic-item { cursor: pointer; padding: .5rem .75rem; border-bottom: 1px solid #f1f1f1; }
    .clinic-item:hover { background: #f8f9fa; }
    .clinic-item.active { background: #e9f2ff; font-weight: 600; }
    .no-clinics { padding: 1rem; color: #6c757d; text-align:center; }
    .small-muted { font-size:.85rem; color:#6c757d }
  </style>
</head>

<body>
  <div class="container-fluid vh-100 d-flex flex-column">
    <div class="container-fluid py-4">
      <div class="card">
        <h5 class="card-header">Clinic Master</h5>
        <div class="card-body">
          <div class="row gx-4">
            <!-- Left: Clinic list -->
            <div class="col-md-4 mb-3">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div style="flex:1">
                  <input id="clinicSearch" class="form-control form-control-sm" placeholder="Search clinics...">
                </div>
                <div class="ms-2">
                  <button id="newClinicBtn" class="btn btn-sm btn-outline-primary">New</button>
                </div>
              </div>

              <div class="card shadow-sm">
                <div class="card-body p-2 clinic-list" id="clinicListContainer" aria-live="polite">
                  <div class="no-clinics">Loading clinics...</div>
                </div>
              </div>
            </div>

            <!-- Right: Form -->
            <div class="col-md-8">
              <form id="ClinicForm">
                <input type="hidden" id="clinicId" name="id">
                <div id="errordiv" style="display:none;"></div>

                <!-- Clinic Info -->
                <div class="row mb-3">
                  <div class="col-md-6 mb-2">
                    <label class="form-label" for="clinicName">Clinic Name*</label>
                    <input type="text" id="clinicName" name="clinicName" class="form-control form-control-sm" required>
                  </div>
                  <div class="col-md-6 mb-2">
                    <label class="form-label" for="clinicContact">Contact Number*</label>
                    <input type="tel" id="clinicContact" name="clinicContact" class="form-control form-control-sm" pattern="[0-9]{10}" placeholder="10-digit number" required>
                  </div>
                </div>

                <div class="row mb-3">
                  <div class="col-12">
                    <label class="form-label" for="clinicAddress">Address</label>
                    <textarea id="clinicAddress" name="clinicAddress" class="form-control form-control-sm" rows="3"></textarea>
                  </div>
                </div>

                <div class="mt-3">
                  <button type="submit" class="btn btn-primary btn-sm me-2">Save Clinic</button>
                </div>
              </form>
            </div> <!-- end right col -->
          </div> <!-- end row -->
        </div> <!-- card-body -->
      </div> <!-- card -->
    </div> <!-- container-fluid -->
  </div> <!-- container-fluid vh-100 -->

  <%- include('../footer') -%>

  <script>
    $(function () {
      const formId = '#ClinicForm';
      const errorDiv = '#errordiv';
      const clinicListContainer = $('#clinicListContainer');
      let clinicsCache = [];
      let activeClinicId = null;

      // Render clinic list
      function renderClinicList(list, filter = '') {
        clinicListContainer.empty();
        const filtered = list.filter(c => (c.name || '').toLowerCase().includes(filter.toLowerCase()));
        if (!filtered.length) {
          clinicListContainer.html('<div class="no-clinics">No clinics found.</div>');
          return;
        }
        filtered.forEach(c => {
          const el = $(`
            <div class="clinic-item" data-id="${c.id}">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <div>${escapeHtml(c.name)}</div>
                  <div class="small-muted">${c.contact || ''}</div>
                </div>
                <div class="small-muted">${(c.address || '').slice(0,20)}</div>
              </div>
            </div>
          `);
          if (c.id == activeClinicId) el.addClass('active');
          el.on('click', () => {
            $('.clinic-item').removeClass('active');
            el.addClass('active');
            activeClinicId = c.id;
            // load clinic into form
            fetchClinic(c.id);
          });
     el.on('click', () => {
  $('.clinic-item').removeClass('active');
  el.addClass('active');
  activeClinicId = c.clinic_id;  // use clinic_id, not id
  fetchClinic(c.clinic_id);       // fetch by clinic_id
});
          clinicListContainer.append(el);
        });
      }

      // Escape helper to avoid HTML injection from names
      function escapeHtml(text) {
        if (!text) return '';
        return String(text)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      }

      // Fetch clinic list from server
      async function loadClinicList() {
        clinicListContainer.html('<div class="no-clinics">Loading clinics...</div>');
        try {
          const res = await axios.get('/clinics/list');
          clinicsCache = Array.isArray(res.data) ? res.data : (res.data.clinics || []);
          renderClinicList(clinicsCache);
        } catch (err) {
          clinicListContainer.html('<div class="no-clinics">Failed to load clinics.</div>');
          console.error('loadClinicList error', err);
        }
      }

      // Fetch single clinic by id and populate form
      async function fetchClinic(id) {
        try {
          const res = await axios.get(`/getClinicById/${id}`);
          const c = res.data.clinic || res.data;
          if (c) {
            $('#clinicId').val(c.id);
            $('#clinicName').val(c.name || '');
            $('#clinicContact').val(c.contact || '');
            $('#clinicAddress').val(c.address || '');
            $(errorDiv).hide();
          }
        } catch (e) {
          $(errorDiv).removeClass('alert-success').addClass('alert alert-danger')
            .text('Failed to load clinic.').show();
        }
      }

      // limit contact input to digits (if you have restrictInput helper, it will be used)
      try { restrictInput("clinicContact", 10); } catch(e){ /* ignore if not defined */ }

      // New clinic button - reset form and active state
      $('#newClinicBtn').on('click', function () {
        activeClinicId = null;
        $('.clinic-item').removeClass('active');
        $('#clinicId').val('');
        $('#ClinicForm')[0].reset();
        $(errorDiv).hide();
      });

      // Search/filter
      $('#clinicSearch').on('input', function () {
        const q = $(this).val();
        renderClinicList(clinicsCache, q);
      });

      // Submit form (create/update)
      $(formId).on('submit', async function (e) {
        e.preventDefault();

        // Validate required fields
        let valid = true;
        $(formId + ' [required]').each(function () {
          if (!this.value.trim()) { valid = false; return false; }
        });
        if (!valid) {
          $(errorDiv).removeClass('alert-success').addClass('alert alert-danger')
            .text('Please fill all required fields.').show();
          return;
        }

        const idVal = $('#clinicId').val();
        const data = {
          name: $('#clinicName').val(),
          contact: $('#clinicContact').val(),
          address: $('#clinicAddress').val()
        };

        try {
          let res;
          if (idVal) {
            // Update existing clinic (matches doctor pattern)
            res = await axios.post(`/clinics/update/${idVal}`, data);
          } else {
            // Create new clinic
            res = await axios.post('/clinics/create', data);
          }

          $(errorDiv).removeClass('alert-danger').addClass('alert alert-success')
            .text(res.data.message || 'Clinic saved successfully').show();

          // Refresh list and highlight saved clinic
          const savedId = res.data.id || res.data.clinic?.id || idVal;
          await loadClinicList();

          if (savedId) {
            activeClinicId = savedId;
            $(`[data-id="${savedId}"]`).addClass('active');
            $('#clinicId').val(savedId);
          }

          setTimeout(() => $(errorDiv).fadeOut(), 1600);

        } catch (err) {
          const em = err.response?.data?.message || 'Error saving clinic.';
          $(errorDiv).removeClass('alert-success').addClass('alert alert-danger')
            .text(em).show();
        }
      });

      // initial load
      loadClinicList();

    //   // Support ?id= in URL to pre-open a clinic
    //   const params = new URLSearchParams(window.location.search);
    //   const urlClinicId = params.get('id');
    //   if (urlClinicId) {
    //     activeClinicId = urlClinicId;
    //     fetchClinic(urlClinicId);
    //   }
    });
  </script>
</body>
</html>
