<!doctype html>
<html
  lang="en"
  class="light-style layout-menu-fixed layout-compact"
  dir="ltr"
  data-theme="theme-default"
  data-assets-path="../assets/"
  data-template="vertical-menu-template-free"
  data-style="light">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

    <title>List of Patients</title>

  <%- include('../header') -%>

          <!-- Content wrapper -->
          <div class="content-wrapper">
            <!-- Content -->
            <div class="container-xxl flex-grow-1 container-p-y">
              <!-- Basic Bootstrap Table -->
              <div class="card">
                <div class="row card-header flex-column flex-md-row pb-4">
				<div class="d-md-flex justify-content-between align-items-center dt-layout-start col-md-auto me-auto mt-0">
				<h5 class="card-title mb-0 text-md-start text-center">All Patient</h5></div>
				<div class="d-md-flex justify-content-between align-items-center dt-layout-end col-md-auto ms-auto mt-0">
				
				<div class="dt-buttons btn-group flex-wrap mb-0"> 
				
				<div class="btn-group">
				<input type="search" class="form-control ms-4" id="searchBox" placeholder="Search" aria-controls="DataTables_Table_1">
				
				<button class="btn buttons-collection btn-label-primary dropdown-toggle me-4" tabindex="0" aria-controls="DataTables_Table_0" type="button" aria-haspopup="dialog" aria-expanded="false"><span><span class="d-flex align-items-center gap-2"><i class="icon-base bx bx-export me-sm-1"></i> <span class="d-none d-sm-inline-block">Export</span></span></span></button></div> 
				
				<button class="btn create-new btn-primary" tabindex="0" onclick=" window.location.href = '/patient-registration'" aria-controls="DataTables_Table_0" type="button"><span><span class="d-flex align-items-center gap-2"><i class="icon-base bx bx-plus icon-sm"></i> <span class="d-none d-sm-inline-block">New Registration</span></span></span></button> 
				  </div>
				 </div>
				</div>
				
                <div class="table-responsive text-nowrap">
                  <table class="table" id="tblid">
                    <thead>
                      <tr>
                        <th>UHID</th>
                        <th>Name</th>
                        <th>Mobile</th>
                        <th>Appointment</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody id="patientTbody" class="table-border-bottom-0">

                   </tbody>
                 
                  </table>
                  <div id="paginationControls"></div>
                </div>
              </div>
              <!--/ Basic Bootstrap Table -->
            </div>
            <!-- / Content -->

          <%- include('../footer') -%>

          
          <script>
            document.addEventListener("DOMContentLoaded", function () {
                axios.get("/patients-with-appointments") // Call the API
                    .then(response => {
                        const patients = response.data.patients;
                        const tbody = document.getElementById("patientTbody"); // Use correct ID
                        tbody.innerHTML = ""; // Clear existing content
            
                        patients.forEach(patient => {
                            const appointment = patient.latestAppointment;
            
                            // Format appointment details
                            const doctorName = appointment ? appointment.doctor : "No Appointment";
                            const appointmentDate = appointment ? new Date(appointment.date).toDateString() : "N/A";
                            const appointmentTime = appointment ? appointment.time : "N/A";
            
                            // Get patient image, if available, otherwise use a placeholder
                            const imageUrl = patient.patientImage 
                                ? `../MyUploads/${patient.patientImage}` // Adjust based on actual image path
                                : "../images/5.png"; // Placeholder image
            
                            // Create table row
                            const row = `
                                <tr data-patient-id="${patient.id}">
                                    <td>${patient.uhid}</td>
                                    <td>
                                        <img width="30" src="${imageUrl}" alt="" class="rounded-circle" />
                                        ${patient.name}
                                    </td>
                                    <td>${patient.mobile}</td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="emp_name text-truncate text-heading">${doctorName}</span>
                                            <small class="emp_post text-truncate">${appointmentDate}, ${appointmentTime}</small>
                                        </div>
                                    </td>
                                    <td>
                                        <button id="action" href="javascript:;" class="btn btn-icon item-edit">
                                            <i class="icon-base bx bx-edit icon-sm"></i>
                                        </button>
                                    </td>
                                </tr>
                            `;
            
                            tbody.innerHTML += row;
                        });
                        pagi_search('#searchBox','#tblid','#paginationControls')
                    })
                    .catch(error => {
                        console.error("Error fetching patient data:", error);
                    });

                    $('#tblid').on('click', '#action', function() {
                        const id=$(this).closest('tr').data('patient-id')
                        const route='Patient-registration'
                          ViewBtn(route,id)
                         });
            });
            
            </script>
            
