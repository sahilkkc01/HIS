   <script>
$(function(){
  // debounce helper
  function debounce(fn, ms){ let t; return function(){ clearTimeout(t); t = setTimeout(()=>fn.apply(this,arguments), ms); }}

  // prescription search (as before)...
  // add/remove rows (as before)...

  // auto‐fill followUpDate when followInDays changes
  $('#followInDays').on('change', function(){
    const d = parseInt(this.value,10);
    if (!d) return $('#followUpDate').val('');
    const dt = new Date(); dt.setDate(dt.getDate()+d);
    const iso = dt.toISOString().slice(0,10);
    $('#followUpDate').val(iso);
  }).trigger('change');

  // SAVE handler
  $('.saveBtn').on('click', function(){
    // build prescriptions array
    const prescriptions = [];
    $('#medicineRepeater .medicine-row').each(function(){
      const $r = $(this);
      const name = $r.find('.medicine-name').val();
      if (!name) return;
      prescriptions.push({
        medicine_name: name,
        dosage:    $r.find('.dosage').val(),
        frequency: $r.find('.frequency').val(),
        days:      $r.find('.days').val()
      });
    });

    // gather all fields
    const payload = {
      clinic_id:       $('#clinicId').val(),
      patient_id:      $('#patientId').val(),
      doneBy:          $('#doneBy').val(),
      clinicalHistory: $('#clinicalHistory').val(),
      pulse:           $('#pulse').val(),
      bp:              $('#bp').val(),
      temp:            $('#temp').val(),
      spo2:            $('#spo2').val(),
      diagnosis:       $('#diagnosis').val(),
      tests:           $('#testsSelect').val() || [],
      prescriptions,
      doctorsAdvice:   $('#doctorsAdvice').val(),
      nextFollowUp:    $('#followUpDate').val()
    };

    $.ajax({
      url: '/saveemr',
      method: 'POST',
      contentType: 'application/json',
      data: JSON.stringify(payload),
      success(data){
        alert('Emr Done successfully!');
          setTimeout(() => {
                window.location.href = "/Patient-List";
              }, 1500);
        // optionally redirect or clear form
      },
      error(err){
        console.error(err);
        alert('Save failed');
      }
    });
  });

  // (Optional) savePrintBtn can trigger print after save...
});
</script>

    <script>
  $(function(){
    // 1) grab encrypted ID from the query string
    const params = new URLSearchParams(window.location.search);
    const encId  = params.get("id");
    if (!encId) return;

    // 2) fetch the patient record
    $.ajax({
      url: `/patient/${encId}`,
      type: "GET",
      success: function(res){
        console.log(res)
        // 
        const p = res.patient;
        // console.log(p)
        // 3) fill hidden ID for form submissions
        $("#patientId").val(encId);

        // 4) avatar
        const imgUrl = p.patientImage
          ? `/Myuploads/${p.patientImage}`
          : "../images/1.png";
        $("#uploadedAvatar").attr("src", imgUrl);

        // 5) update labels (assumes these are the first five <label> in .button-wrapper)
        const $labels = $(".button-wrapper label");
        $labels.eq(0).html(`<strong>Patient Name:</strong> <a href="#" data-bs-toggle="modal" data-bs-target="#patienthistory">${p.name}</a>`);
        $labels.eq(1).html(`<strong>Gender:</strong> ${p.gender}`);
        $labels.eq(2).html(`<strong>Age:</strong> ${p.age} Y`);
        $labels.eq(3).html(`<strong>Blood Group:</strong> ${p.bloodGroup}`);
        $labels.eq(4).html(`<strong>UHID:</strong> ${p.uhid}`);
      },
      error: function(err){
        console.error("Error fetching patient data:", err);
      }
    });
  });
</script>
<!-- jQuery + Script -->
<script>
  $(function(){
    // --- DEBOUNCE HELPER ---
    function debounce(fn, delay){
      let timer;
      return function(){
        clearTimeout(timer);
        timer = setTimeout(() => fn.apply(this, arguments), delay);
      }
    }

    // --- SEARCH & SUGGESTIONS ---
    $('#medicineRepeater').on('input', '.medicine-name', debounce(function(){
      const $input = $(this);
      const q       = $input.val().trim();
      const $sug    = $input.siblings('.suggestions');

      if (!q) {
        return $sug.hide().empty();
      }

      $.getJSON('/searchMedicine', { q })
       .done(items => {
         if (!items.length) {
           return $sug.html('<div class="list-group-item">No matches</div>').show();
         }
         const html = items.map(i => `
           <button 
             type="button" 
             class="list-group-item list-group-item-action"
             data-item='${JSON.stringify(i)}'
           >
             ${i.medicine_name} <small class="text-muted">[${i.molecule}]</small>
           </button>
         `).join('');
         $sug.html(html).show();
       })
       .fail(() => {
         $sug.hide();
       });
    }, 300));

    // --- SELECTING A SUGGESTION ---
    $('#medicineRepeater').on('click', '.suggestions button', function(){
      const item = $(this).data('item');
      const $row = $(this).closest('.medicine-row');

      $row.find('.medicine-name').val(item.medicine_name);
      $row.find('.dosage').val(item.uom);
      $row.find('.frequency').val('3 Times');
      $row.find('.days').val('');
      
      $(this).parent().hide();
    });

    // click outside to close suggestions
    $(document).on('click', e => {
      if (!$(e.target).closest('.position-relative').length) {
        $('.suggestions').hide();
      }
    });

    // --- ADD MORE ROW ---
    $('#medicineRepeater').on('click', '.addMore', function(){
      const $firstRow = $('#medicineRepeater .medicine-row:first');
      const $newRow   = $firstRow.clone();

      // clear inputs in cloned row
      $newRow.find('input').val('');
      $newRow.find('.suggestions').hide().empty();

      // change the + button in the cloned row to a remove button (optional)
      $newRow.find('.addMore')
             .removeClass('btn-success addMore')
             .addClass('btn-danger removeRow')
             .text('–');

      $('#medicineRepeater').append($newRow);
    });

    // --- REMOVE A ROW ---
    $('#medicineRepeater').on('click', '.removeRow', function(){
      $(this).closest('.medicine-row').remove();
    });
  });
</script>


