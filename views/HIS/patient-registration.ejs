    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

    <title>Patient Registration</title>

  <%- include('../header') -%>
          <!-- / Navbar -->
		  <!-- Header and Menu ends here create a header ejs file -->

          <!-- Content wrapper -->
          <div class="content-wrapper">
            <!-- Content -->
            <style>.displaynone{display:none;}.bx-qr-scan{font-size:80px;}</style>
            <div class="container-xxl flex-grow-1 container-p-y">
              <div class="row">
                <!-- Vertical & Horizontal Scrollbars -->
                <div class="col-12">
                  <div class="card overflow-hidden">
                    <h5 class="card-header">Patient Registration</h5>
                    <form id="PatientRegForm" method="post" enctype="multipart/form-data">
                      <input type="hidden" id="patientId" name="patientId">
                    <div class="card">
                    <!-- Account -->
                 
                    <div class="card-body">
					<div class="row border-bottom">
					<div class="col-10 col-xs-12">
           
         
            <div class="d-flex align-items-start align-items-sm-center gap-6 pb-4">
              <img src="../images/1.png" alt="user-avatar" class="d-block w-px-100 h-px-100 rounded" id="uploadedAvatar">
              <div class="button-wrapper">
                  <!-- Upload from Local Storage -->
                  <label data-bs-toggle="tooltip" data-bs-offset="0,4" data-bs-placement="top" data-bs-html="true" title="<span>Upload from local Storage</span>" for="patientImage" class="btn btn-primary me-3 mb-4" tabindex="0">
                      <span class="bx bx-upload"></span>
                      <input type="file" id="patientImage" name="patientImage" class="account-file-input" hidden accept="image/png, image/jpeg">
                  </label>
          
                  <!-- Upload from Webcam (no input field here, will start webcam directly) -->
                  <button type="button" data-bs-toggle="tooltip" data-bs-offset="0,4" data-bs-placement="top" data-bs-html="true" title="<span>Upload from Webcam</span>" id="webcamBtn" class="btn btn-primary me-3 mb-4">
                      <span class="bx bxs-webcam"></span> 
                  </button>
          
                  <!-- Reset Button -->
                  <button data-bs-toggle="tooltip" data-bs-offset="0,4" data-bs-placement="top" data-bs-html="true" title="<span>Reset</span>" type="button" class="btn btn-outline-secondary account-image-reset mb-4" id="resetBtn">
                      <span class="bx bx-reset"></span> Reset
                  </button>
          
                  <!-- File Type and Size Information -->
                  <div class="text-muted">Allowed JPG, JPEG or PNG. Max size of 800K</div>
              </div>
          
              <!-- Video and Canvas for Webcam -->
              
          </div>
          
						
                      </div>
					  <div class="col-2 text-center d-none d-sm-block">
						<i class='bx bx-qr-scan'></i>
						<div>Scan to Register</div>
					  </div>
					</div>
                    </div>
                    <div class="card-body pt-4">
                     
                        <div id="errordiv"></div>
                        <div class="row g-6">
                          <div class="col-md-6">
                            <label for="name" class="form-label">Name*</label>
                            <input class="form-control" type="text" id="name" name="name" value="" autofocus="" data-validation="required" data-error-message="Please Enter Name">
                          </div>
                          <div class="col-md-6">
                            <label class="form-label" for="mobile">Mobile Number*</label>
                            <div class="input-group input-group-merge">
                              <span class="input-group-text">IND (+91)</span>
                              <input type="number" id="mobile" name="mobile" class="form-control" placeholder="" data-validation="required mobileNum" data-error-message="Please Enter Mobile Number">
                            </div>
                          </div>
                          <div class="col-md-6">
                            <label for="email" class="form-label">E-mail</label>
                            <input class="form-control" type="email" id="email" name="email" value="" data-validation="email" placeholder="">
                          </div>
                          <div class="col-md-3">
                            <label for="language" class="form-label">Gender*</label>
                            <select id="gender" name="gender" class="select2 form-select" data-validation="required" data-error-message="Please Enter Gender">
                              <option value="">Select</option>
                              <option value="M">Male</option>
                              <option value="F">Female</option>
                              <option value="O">Other</option>
                            </select>
                          </div>
                          <div class="col-md-3">
                            <label for="address" class="form-label">Age*</label>
                            <input type="number" class="form-control" id="age" name="age" placeholder="" data-validation="required" data-error-message="Please Enter Age">
                          </div>
                          <div class="col-md-6">
                            <label for="address" class="form-label">Address</label>
                            <input type="text" class="form-control" id="address" name="address" placeholder="" data-validation>
                          </div>
						  <div class="col-md-6">
                            <label for="address" class="form-label">Other Details</label>
                            <input type="text" class="form-control" id="otdetails" name="otdetails" placeholder="" data-validation>
                          </div>
                          <div class="col-md-6">
						  <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="" id="defaultCheck3">
                            <label class="form-check-label" for="defaultCheck3"> Book Appointment </label>
						   </div>
                          </div>
						  <div id="markvisit" class="row g-4 displaynone">
						  <div class="col-md-2">
                            <label for="state" class="form-label">Weight (KG)</label>
                            <input class="form-control" type="number" id="weight" name="weight" step="any" placeholder="">
                          </div>
						  <div class="col-md-2">
                            <label for="state" class="form-label">Height (Feet)</label>
                            <input class="form-control" type="number" id="height" name="height" step="any" placeholder="">
                          </div>
						  <div class="col-md-2">
                            <label for="state" class="form-label">BMI</label>
                            <input class="form-control" type="number" id="bmi" name="bmi" step="any" readonly>
                          </div>
						  
						  <div class="col-md-2">
                            <label for="state" class="form-label">Fever °F</label>
                            <input class="form-control" type="number" id="fever" name="fever" step="any" placeholder="">
                          </div>
						  <div class="col-md-2">
                            <label for="state" class="form-label">BP (mm Hg)</label>
                            <input class="form-control" type="text" id="bp" name="bp"  placeholder="">
                          </div>
						  <div class="col-md-2">
                            <label for="state" class="form-label">Sugar (mg/dL)</label>
                            <input class="form-control" type="number" id="sugar" step="any" name="sugar">
                          </div>
						  
						  <div class="col-md-2">
                            <label for="clinic" class="form-label">Clinic*</label>
                            <select id="Clinic" name="Clinic" class="select2 form-select">
                              <option value="">Select</option>
                            </select>
                          </div>
						  
						  <div class="col-md-2">
                            <label for="doctor" class="form-label">Doctor*</label>
                            <select id="Doctor" name="doctor" class="select2 form-select">
                              <option value="">Select</option>
                            </select>
                          </div>
						  
						  <div class="col-md-2">
                            <label for="Date" class="form-label">Date*</label>
                            <input type="date" id="date" name="date" class="form-control">
                              
                            
                          </div>
						  <div class="col-md-2">
                            <label for="Time" class="form-label">Time*</label>
                            <select id="time" name="time" class="select2 form-select">
                              <option value="">Select</option>
                            </select>
                          </div>
						  
						  
                        </div>
						<!--Mark visit div close-->
                        </div>
                        <div id="loadingIndicator"></div>
                        <div class="mt-6">
                          <button type="button"  id="mod-btn" style="display: none !important;" onclick="updateQuery()" class="btn btn-primary me-3">Modify</button>
                          <button type="submit" id="subBtn" class="btn btn-primary me-3">Save</button>
