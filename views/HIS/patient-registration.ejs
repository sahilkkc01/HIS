                        </div>
                     
                    </div>
                    <!-- /Account -->
                 
                  </div>
                </form>
                  </div>
                </div>

           
                <!--/ Vertical & Horizontal Scrollbars -->
              </div>
            </div>
            <!-- / Content -->
            <div class="modal fade" id="WebcamModal" tabindex="-1" aria-hidden="true">
              <div class="modal-dialog modal-sm" role="document">
                  <div class="modal-content">
                      <div class="modal-header">
                          <h5 class="modal-title" id="exampleModalLabel2">Webcam</h5>
                          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>
                      <div class="modal-body">
                         
                          <!-- Webcam Section -->
                          <div id="webcamContainer" class="mt-3" style="display: none;">
                              <video id="video" width="320" height="240" autoplay></video>
                              <canvas id="canvas" width="320" height="240" style="display:none;"></canvas>
                              <button id="captureBtn" type="button" class="btn btn-success mt-3">Capture</button>
                          </div>
                      </div>
                      
                  </div>
              </div>
          </div>
          
            <%- include('../footer') -%>

            <!-- Extra Js for this Page-->
<script>
  $(document).ready(function () {
  $("#defaultCheck3").on("change", function () {
    if ($(this).is(":checked")) {
    $("#markvisit").removeClass("displaynone"); // Show the element
    $("#Doctor, #Clinic, #time ,#date").attr("data-validation", "required"); // Add required validation
  } else {
    $("#markvisit").addClass("displaynone"); // Hide the element
    $("#Doctor, #Clinic, #time ,#date").removeAttr("data-validation"); // Remove required validation
  }
  });
  });
  restrictInput("mobile", 10); // Limits mobile number to 10 digits
  restrictInput("age", 2); 

  document.getElementById('patientImage').addEventListener('change', function(event) {
    // Just validate the file input without calling previewImage
    validateFileInput("patientImage", ["image/jpeg", "image/jpg", "image/png"], 800);
});

  document.getElementById("height").addEventListener("input", function() {
    BMI("height", "weight", "bmi");
});
document.getElementById("weight").addEventListener("input", function() {
    BMI("height", "weight", "bmi");
});
loadDropdown('Doctor', 'name', '');
loadDropdown('Clinic', 'name', '');
  document.addEventListener("DOMContentLoaded", function () {
    const dateField = document.getElementById("date");
    const today = new Date().toISOString().split("T")[0]; 
    dateField.setAttribute("min", today);
  });

$(document).ready(function () {
    console.log("Document is ready");

    const formId = '#PatientRegForm';
    const errorDivId = '#errordiv';

    $(formId).on('submit', async function (event) {
        event.preventDefault(); // Prevent the form from submitting

        const { isValid, errorMessage } = validateForm(formId);

        if (isValid) {
            const url = '/patient-reg';
            const loadingDiv = '#loadingIndicator';

            try {
                $(loadingDiv).show(); // Show loading indicator

                const response = await saveForm(formId, url); // Perform the form submission

                console.log('Success:', response);
                $(errorDivId).removeClass('alert-danger').addClass('alert-success').text(response.message).show();
            } catch (error) {
                console.error('Error:', error);
                $(errorDivId).removeClass('alert-success').addClass('alert-danger').text(` ${error.message || 'Unknown error'}`).show();
            } finally {
                $(loadingDiv).hide(); // Hide loading indicator after submission
                window.location.href='/Patient-list'
            }
        } else {
            $(errorDivId).removeClass('alert-success').addClass('alert-danger').text(errorMessage).show();
        }
    });
});


document.addEventListener("DOMContentLoaded", function () {
    const doctorSelect = document.getElementById("Doctor");
    const dateInput = document.getElementById("date");
    const timeSelect = document.getElementById("time");

    // Function to fetch available time slots
    const fetchAvailableSlots = () => {
        const selectedOption = doctorSelect.selectedOptions[0]; // Get selected option
        const doctor_id = doctorSelect.value;
        const date = dateInput.value;
        

        console.log("Doctor ID:", doctor_id); // Debugging
        if (!doctor_id || !date) {
            timeSelect.innerHTML = '<option value="">Select</option>';
            return;
        }

        axios.post("/getAvailableSlots", { doctor_id, date })
            .then(response => {
                console.log(response);
                const availableSlots = response.data.availableSlots;

                timeSelect.innerHTML = '<option value="">Select</option>'; // Reset dropdown

                if (availableSlots.length === 0) {
                    timeSelect.innerHTML += '<option value="">No slots available</option>';
                } else {
                    availableSlots.forEach(slot => {
                        const option = document.createElement("option");
                        option.value = slot;
                        option.textContent = slot;
                        timeSelect.appendChild(option);
                    });
                }
            })
            .catch(error => {
                console.error("Error fetching available slots:", error);
                alert("Failed to load available slots.");
            });
    };

    // Event Listeners
    doctorSelect.addEventListener("change", fetchAvailableSlots);
    dateInput.addEventListener("change", fetchAvailableSlots);
});

  </script>

<script>
  function loadPatientData(patientId) {
    $.ajax({
        url: `/patient/${patientId}`,
        type: "GET",
        success: function (data) {
          console.log(data)
            $("#patientId").val(data.patient.id);
            $("#name").val(data.patient.name);
            $("#mobile").val(data.patient.mobile);
            $("#email").val(data.patient.email);
            $("#gender").val(data.patient.gender).trigger("change");
            $("#age").val(data.patient.age);
            $("#address").val(data.patient.address);
            $("#otdetails").val(data.patient.otdetails);
           

             // Show patient image if exists
             if (data.patient.patientImage) {
                $("#uploadedAvatar").attr("src", `/Myuploads/${data.patient.patientImage}`);
            } else {
                $("#uploadedAvatar").attr("src", "../images/1.png"); // Default image
            }
            // Show modify button, hide save button
            $("#mod-btn").show();
            $('#subBtn').prop('disabled', true);
            $('#defaultCheck3').prop('disabled', true);
        },
        error: function (err) {
            console.error("Error fetching patient data", err);
        }
    });
}

if('<%= patient %>'!==''){
  loadPatientData('<%= patient %>')
  $('input[data-validation], select').prop('readonly', true);
}
function updateQuery(){
       $('#mod-btn').prop('disabled', true);   
       $('input, select').prop('readonly', false);
       $('#subBtn').prop('disabled', false);
     }
            
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const patientImageInput = document.getElementById('patientImage');
    const webcamBtn = document.getElementById('webcamBtn');
    const uploadedAvatar = document.getElementById('uploadedAvatar');
    const resetBtn = document.getElementById('resetBtn');
    const video = document.getElementById('video');
    const canvas = document.getElementById('canvas');
    const captureBtn = document.getElementById('captureBtn');
    const webcamContainer = document.getElementById('webcamContainer');
    let stream;

    // Handle local file upload
    patientImageInput.addEventListener('change', function(event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                uploadedAvatar.src = e.target.result; // Set the image source to the uploaded file
            };
            reader.readAsDataURL(file); // Convert file to DataURL
        }
    });

    // Start video stream for webcam
    function startWebcam() {
        navigator.mediaDevices.getUserMedia({ video: true })
            .then(function(mediaStream) {
                stream = mediaStream;
                video.srcObject = mediaStream;
                webcamContainer.style.display = 'block'; // Show the webcam container
            })
            .catch(function(error) {
                console.error('Error accessing webcam:', error);
                alert('Unable to access the webcam. Please check your browser settings.');
            });
    }

    // Capture image from webcam
    captureBtn.addEventListener('click', function() {
        canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height); // Capture image from video
        const imageUrl = canvas.toDataURL('image/png'); // Convert canvas to image URL
        uploadedAvatar.src = imageUrl; // Set the image source to the captured image

        // Convert the captured image DataURL to a File and set it to the patientImage input
        const file = dataURLtoFile(imageUrl, 'webcam_capture.png');
        
        // Create a new DataTransfer object to update the file input
        const dataTransfer = new DataTransfer();
        dataTransfer.items.add(file); // Add the captured file
        patientImageInput.files = dataTransfer.files; // Update the file input with the captured file

        stopWebcam(); // Stop the webcam after capturing the image
        $('#WebcamModal').modal('hide');
    });

    // Stop the webcam
    function stopWebcam() {
        if (stream) {
            stream.getTracks().forEach(track => track.stop()); // Stop all webcam tracks
            video.srcObject = null; // Reset video source
            webcamContainer.style.display = 'none'; // Hide webcam container
        }
    }

    // Open webcam when clicking the "Upload from Webcam" button
    webcamBtn.addEventListener('click', function() {
      $('#WebcamModal').modal('show');
        startWebcam();
    });

    // Reset the avatar image to the default
    resetBtn.addEventListener('click', function() {
        uploadedAvatar.src = "../images/1.png"; // Reset to default image
        patientImageInput.value = ''; // Clear local file input
        stopWebcam(); // Stop webcam if active
    });

          // Stop webcam when the modal is closed
          $('#WebcamModal').on('hidden.bs.modal', function () {
        stopWebcam(); // Stop the webcam when the modal is closed
    });

    // Convert DataURL to a File object
    function dataURLtoFile(dataURL, filename) {
    // Split the DataURL into the MIME type and base64 string
    const arr = dataURL.split(',');

    // Ensure that the string starts with 'data:' and contains a MIME type
    if (arr.length < 2 || !arr[0].startsWith('data:')) {
        throw new Error("Invalid DataURL format.");
    }

    // Extract the MIME type from the DataURL
    const mime = arr[0].match(/:(.*?);/)[1];

    // Decode the base64 string to binary
    const bstr = atob(arr[1]);
    const n = bstr.length;
    const u8arr = new Uint8Array(n);

    // Populate the Uint8Array with the binary data
    for (let i = 0; i < n; i++) {
        u8arr[i] = bstr.charCodeAt(i);
    }

    // Create and return a File object from the binary data
    return new File([u8arr], filename, { type: mime });
}

  });


</script>
