<!doctype html>
<html
  lang="en"
  class="light-style layout-menu-fixed layout-compact"
  dir="ltr"
  data-theme="theme-default"
  data-assets-path="../assets/"
  data-template="vertical-menu-template-free"
  data-style="light">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

    <title>Add Purchase Order (PO)</title>

    <%- include('../header') -%>

          <!-- Content wrapper -->
          <div class="content-wrapper">
            <!-- Content -->
            <style>.displaynone{display:none;}.bx-qr-scan{font-size:80px;}</style>
            <div class="container-xxl flex-grow-1 container-p-y">
              <div class="row">
                <!-- Vertical & Horizontal Scrollbars -->
                <div class="col-12">
                  <div class="card overflow-hidden">
                    <h5 class="card-header">Add Purchase Order (PO)</h5>
                    <div class="card">
                    <!-- Account -->
                    <div class="card-body pt-4">
                      <form id="formAccountSettings" method="POST" onsubmit="return false">
                        <div class="row g-6">
                          <div class="col-md-3">
                            <label for="firstName" class="form-label">PO No*</label>
                            <input class="form-control" type="text" id="firstName" name="firstName" value="" autofocus="">
                          </div>
						  <div class="col-md-3">
                            <label for="firstName" class="form-label">Date</label>
                            <input class="form-control" type="text" id="firstName" name="firstName" value="" autofocus="">
                          </div>
						  <div class="col-md-3">
                            <label class="form-label" for="phoneNumber">Store</label>
                            <select id="categoryDropdown" class="select2 form-select">
                              <option value="">Select</option>
                              <option value="add-new">Add New</option>
                            </select>
                          </div>
                          <div class="col-md-3">
                            <label class="form-label" for="phoneNumber">Vendor/Supplier</label>
                            <select id="categoryDropdown" class="select2 form-select">
                              <option value="">Select</option>
                              <option value="add-new">Add New</option>
                            </select>
                          </div>
						  
						  <div class="col-md-3">
                            <label class="form-label" for="phoneNumber">Payment Terms</label>
                            <select id="categoryDropdown" class="select2 form-select">
                              <option value="">Select</option>
							  <option value="30">30 Days</option>
							  <option value="60">60 Days</option>
							  <option value="90">90 Days</option>
                              <option value="120">120 Days</option>
                            </select>
                          </div>
						  
						  <div class="col-md-3">
                            <label class="form-label" for="phoneNumber">Payment Mode</label>
                            <select id="categoryDropdown" class="select2 form-select">
                              <option value="">Select</option>
							  <option value="Cash">Cash</option>
							  <option value="Cheque">Cheque</option>
							  <option value="Card">Card</option>
							  <option value="UPI">UPI</option>
                            </select>
                          </div>
						  
						  <div class="col-md-3">
                            <label class="form-label" for="phoneNumber">Delivery Store</label>
                            <select id="categoryDropdown" class="select2 form-select">
                              <option value="">Select</option>
                              <option value="add-new">Add New</option>
                            </select>
                          </div>
						  <div class="col-md-3">
                            <label class="form-label" for="phoneNumber">Delivery Duration</label>
                            <select id="categoryDropdown" class="select2 form-select">
                              <option value="">Select</option>
							  <option value="30">30 Days</option>
							  <option value="60">60 Days</option>
							  <option value="90">90 Days</option>
                              <option value="120">120 Days</option>
                            </select>
                          </div>
                      </form>
                    </div>
                    <!-- /Account -->
                  </div>
                  </div>
                </div>
                <!--/ Vertical & Horizontal Scrollbars -->
				
				<div class="card overflow-hidden mt-3">
				<div class="row card-header flex-column flex-md-row pb-4 col-md-6">
				<input type="search" class="form-control ms-4 mb-2 mt-2" id="dt-search-1" placeholder="Search item to Add in PO" aria-controls="DataTables_Table_1">
				</div>
				
				 <div class="table-responsive text-nowrap">
                  <table class="table table-bordered">
                    <thead>
                      <tr>
					    <th>Item Code</th>
                        <th>Item Name</th>
                        <th>Order Qty</th>
						<th>Purchase Cost Price</th>
						<th>Cost Amount</th>
						<th>MRP</th>
						<th>Amount</th>
						<th>Available Stock</th>
						<th>GST</th>
						<th>GST Amount</th>
						<th>Net Amount</th>
						<th>Specification</th>
						<th>HSN Code</th>
						<th>Action</th>
                      </tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                      <tr>
                        <td>ITM01</td>
                        <td>Paracitamol</td>
                        <td>
                         <input class="form-control" type="number" id="itemQty" name="itemQty" value="" autofocus=""> 
						</td>
						<td>10</td>
						<td>10</td>
						<td>10</td>
						<td>10</td>
						<td>10</td>
						<td>10</td>
						<td>10</td>
						<td>10</td>
						<td>10</td>
						<td>10</td>
						<td><button class="btn btn-icon btn-outline-danger">
                                  <i class="bx bx-trash bx-sm"></i>
                                </button></td>
                      </tr>
                      
                    </tbody>
                  </table>
                </div>
				</div>    
				
				<div class="card overflow-hidden mt-3">
				<div class="card-body pt-4">
				<div class="row g-6">
				<div class="col-md-3">
				 <label class="form-label">Gross Amount: </label>
				 <input class="form-control" type="text" readonly>
				</div>
				<div class="col-md-3">
				 <label class="form-label">Total GST: </label>
				 <input class="form-control" type="text" readonly>
				</div>
				<div class="col-md-3">
				 <label class="form-label">Other Charges: </label>
				 <input class="form-control" type="text" >
				</div>
				<div class="col-md-3">
				 <label class="form-label">PO Discount: </label>
				 <input class="form-control" type="text" readonly>
				</div>
				<div class="col-md-3">
				 <label class="form-label">Total Net Amount: </label>
				 <input class="form-control" type="text" readonly>
				</div>
				<div class="col-md-9">
				 <label class="form-label">Remarks: </label>
				 <input class="form-control" type="text" >
				</div>
				<div class="mt-6">
                          <button type="submit" class="btn btn-primary me-3">Save</button>
                          <button type="reset" class="btn btn-outline-secondary">Cancel</button>
                        </div>
				</div>
				 </div>
				</div>
              </div>
            </div>
            <!-- / Content -->
					  

          <%- include('../footer') -%>