<!doctype html>
<html
  lang="en"
  class="light-style layout-menu-fixed layout-compact"
  dir="ltr"
  data-theme="theme-default"
  data-assets-path="../assets/"
  data-template="vertical-menu-template-free"
  data-style="light">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

    <title>Indent</title>

    <%- include('../header') -%>

          <!-- Content wrapper -->
          <div class="content-wrapper">
            <!-- Content -->
            <style>.displaynone{display:none;}.bx-qr-scan{font-size:80px;}</style>
            <div class="container-xxl flex-grow-1 container-p-y">
              <div class="row">
                <!-- Vertical & Horizontal Scrollbars -->
                <div class="col-12">
                  <div class="card overflow-hidden">
                    <h5 class="card-header">Indent</h5>
                    <div class="card">
                    <!-- Account -->
                    <div class="card-body pt-4">
                        <form id="IndentForm" method="POST">
                          <!-- First Row -->
                          <div class="row g-6">
                            <div class="col-md-4">
                              <label for="indentNo" class="form-label">Indent No</label>
                              <input class="form-control" type="text" id="indentNo" name="indentNo" disabled value="" autofocus>
                            </div>
                            <div class="col-md-4">
                              <label for="IndDate" class="form-label">Indent Date</label>
                              <input class="form-control" type="date" id="IndDate" name="IndDate" value="">
                            </div>
                            <div class="col-md-4">
                              <label for="expDelDate" class="form-label">Expected Delivery Date</label>
                              <input class="form-control" type="date" id="expDelDate" name="expDelDate" value="">
                            </div>
                          </div>
                      
                          <!-- Second Row -->
                          <div class="row g-6 mt-3">
                            <div class="col-md-6">
                              <label class="form-label" for="fromStore">From Store</label>
                              <select id="fromStore" name="fromStore" class="select2 form-select">
                                <option value="">Select</option>
                                <option value="add-new">Add New</option>
                              </select>
                            </div>
                            <div class="col-md-6">
                              <label class="form-label" for="toStore">To Store</label>
                              <select id="toStore" name="toStore" class="select2 form-select">
                                <option value="">Select</option>
                                <option value="add-new">Add New</option>
                              </select>
                            </div>
                          </div>
                      
                          <!-- Checkbox Row -->
                          <div class="row g-6 mt-1">
                            <div class="col-md-12">
                              <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="againstPatient" name="againstPatient">
                                <label class="form-check-label" for="againstPatient">Against Patient</label>
                              </div>
                            </div>
                          </div>
                      
                          <!-- Fourth Row -->
                          <div class="row g-6 ">
                            <div class="col-md-6">
                              <label for="patientName" class="form-label">Patient Name</label>
                              <input class="form-control" type="text" id="patientName" name="patientName" disabled value="">
                            </div>
                            <div class="col-md-6">
                              <label for="contactNo" class="form-label">Contact Number</label>
                              <input class="form-control" type="number" id="contactNo" name="contactNo" disabled data-validation="mobileNo" value="">
                            </div>
                          </div>
                        </form>
                      </div>
                      
                    <!-- /Account -->
                  </div>
                  </div>
                </div>
                <!--/ Vertical & Horizontal Scrollbars -->
				
				<div class="card overflow-hidden mt-3">
				<div class="row card-header flex-column flex-md-row pb-4 col-md-6">
				<input type="search" class="form-control ms-4 mb-2 mt-2" id="itemSearch" placeholder="Search item to Add in Indent" aria-controls="DataTables_Table_1">
				</div>
				
				 <div class="table-responsive text-nowrap">
                  <table class="table table-bordered">
                    <thead>
                      <tr>
                        <th>Item Name</th>
                        <th>Indent Qty</th>
						<th>UOM</th>
						<th>MRP</th>
						<th>Action</th>
                      </tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                      <tr>
                        <td>ITM01</td>
                        <td>Paracitamol</td>
                        <td>
                         <input class="form-control" type="number" id="itemQty" name="itemQty" value="" autofocus=""> 
						</td>
						<td>10</td>
						
						<td><button class="btn btn-icon btn-outline-danger">
                                  <i class="bx bx-trash bx-sm"></i>
                                </button></td>
                      </tr>
                      
                    </tbody>
                  </table>
                </div>
				</div>    
				
				<div class="card overflow-hidden mt-3">
				<div class="card-body pt-4">
				<div class="row g-6">
			
				<div class="col-md-3">
				 <label class="form-label">Total Amount: </label>
				 <input class="form-control" type="text" readonly>
				</div>
				<div class="col-md-9">
				 <label class="form-label">Remarks: </label>
				 <input class="form-control" type="text" >
				</div>
				<div class="mt-6">
                          <button type="submit" class="btn btn-primary me-3">Save</button>
                          <button type="reset" class="btn btn-outline-secondary">Cancel</button>
                        </div>
				</div>
				 </div>
				</div>
              </div>
            </div>
            <!-- / Content -->
					  

          <%- include('../footer') -%>