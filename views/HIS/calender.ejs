 <%- include('../header') -%>

          <!-- Content wrapper -->
          <div class="content-wrapper">
            <!-- Content -->
            <div class="container-xxl flex-grow-1 container-p-y">
              <div class="row">
                <!-- Vertical & Horizontal Scrollbars -->
                <div class="col-12">
                  <div class="card overflow-hidden">
                    <h5 class="card-header">Appointment Calender</h5>
                    <div class="card">
                    <!-- Account -->
                    <div class="card-body pt-4">
                      <form id="formAccountSettings" method="POST" onsubmit="return false">
                        <div class="row g-6">
                    <div class="col-lg-12 mb-12 mb-xl-0">
                      <small class="text-light fw-medium">Doctors</small>
                      <div class="mt-4">
                        <div class="row">
                          <div class="col-md-3 col-12 mb-6 mb-md-0">
                            <div class="list-group" id="doctorList">
                              </div>
                          </div>
                          <div class="col-md-9">
                            <div id="appointmentCalendarContainer">
                                <!-- Calendar will be updated dynamically -->
                            </div>
                        </div>
                        </div>
                      </div>
                    </div>

                        </div>

                      </form>
                    </div>
                    <!-- /Account -->
                  </div>
                  </div>
                </div>
                <!--/ Vertical & Horizontal Scrollbars -->
              </div>
            </div>
            <!-- / Content -->
					  

            <%- include('../footer') -%>

            <script>
              async function loadDoctors() {
                  try {
                      const elementId = 'Doctor';
                      const response = await axios.get(`/getDataFromField?elementId=${elementId}`);
                      const doctors = response.data.data;
                      console.log(doctors);
          
                      const doctorListContainer = document.getElementById('doctorList');
                      doctorListContainer.innerHTML = ''; // Clear existing items
          
                      doctors.forEach(doctor => {
                          const doctorItem = document.createElement('button');
                          doctorItem.classList.add('list-group-item', 'list-group-item-action');
                          doctorItem.setAttribute('data-id', doctor.id);
                          doctorItem.textContent = `${doctor.name} (${doctor.specialization})`;
          
                          // Attach event listener
                          doctorItem.addEventListener('click', () => loadAppointmentCalendar(doctor));
          
                          doctorListContainer.appendChild(doctorItem);
                      });
          
                  } catch (error) {
                      console.error("Error fetching doctors:", error);
                  }
              }
          
              async function loadAppointmentCalendar(doctor) {
    const container = document.getElementById('appointmentCalendarContainer');
    container.innerHTML = `<h4>Loading ${doctor.name}'s appointments...</h4>`;

    try {
        const appointmentResponse = await axios.get(`/getDoctorAppointments?doctorId=${doctor.id}`);
        const appointments = appointmentResponse.data; // Array of booked appointments
        console.log("Appointments:", appointments);

        const daysOfWeek = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];
        const today = new Date();
        let dateHeaders = "";
        let dates = [];

        for (let i = 0; i < 7; i++) {
            let date = new Date();
            date.setDate(today.getDate() + i);
            dates.push(date);
            dateHeaders += `<th>${date.toLocaleString('en-US', { month: 'short', day: 'numeric' })}</th>`;
        }

        const todayName = daysOfWeek[today.getDay()];
        const availableSlots = doctor.appointmentCalendar[todayName] || [];

        if (availableSlots.length === 0) {
            container.innerHTML = `<h4>${doctor.name}'s Appointment Calendar</h4><p>No available slots today.</p>`;
            return;
        }

        let minStartTime = Math.min(...availableSlots.map(slot => parseTime(slot.fromTime)));
        let maxEndTime = Math.max(...availableSlots.map(slot => parseTime(slot.toTime)));

        let startTime = new Date();
        startTime.setHours(Math.floor(minStartTime / 60), minStartTime % 60, 0, 0);
        let endTime = new Date();
        endTime.setHours(Math.floor(maxEndTime / 60), maxEndTime % 60, 0, 0);

        let timeSlotMinutes = doctor.timeslot || 15;
        let tableRows = "";

        while (startTime < endTime) {
            let timeStr = startTime.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: true });
            let rowCells = `<td>${timeStr}</td>`;

            dates.forEach(date => {
                let dayName = daysOfWeek[date.getDay()];
                let slots = doctor.appointmentCalendar[dayName] || [];
                let isAvailable = slots.some(slot => isTimeInRange(timeStr, slot.fromTime, slot.toTime));

                let bookedAppointments = appointments.filter(app => 
                    app.date === formatDate(date) && isTimeInRange(timeStr, app.time)
                );

                if (bookedAppointments.length > 0) {
                    bookedAppointments.forEach(bookedAppointment => {
                        rowCells += `<td><span class="badge bg-label-primary">${bookedAppointment.patientName}, ${bookedAppointment.age}, ${bookedAppointment.gender}</span></td>`;
                    });
                } else {
                    rowCells += `<td>${isAvailable ? "" : ""}</td>`;
                }
            });

            tableRows += `<tr>${rowCells}</tr>`;
            startTime.setMinutes(startTime.getMinutes() + timeSlotMinutes);
        }

        container.innerHTML = `
            <h4>Appointment Calendar for ${doctor.name}</h4>
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Time</th>
                            ${dateHeaders}
                        </tr>
                    </thead>
                    <tbody>
                        ${tableRows}
                    </tbody>
                </table>
            </div>
        `;
    } catch (error) {
        console.error("Error fetching appointments:", error);
        container.innerHTML = `<h4>Failed to load appointments for ${doctor.name}</h4>`;
    }
}

// Helper function to check if a time is within a given range
function isTimeInRange(slotTime, appointmentTimeRange) {
    // Ensure the appointmentTimeRange is defined and properly formatted
    if (!appointmentTimeRange || !appointmentTimeRange.includes('-')) {
        console.warn('Invalid appointment time range:', appointmentTimeRange);
        return false; // Return false for invalid or undefined time ranges
    }

    const [startTime, endTime] = appointmentTimeRange.split('-').map(t => t.trim());

    // Convert both times to 24-hour format for accurate comparison
    const startTime24 = convertTo24Hour(startTime);
    const endTime24 = convertTo24Hour(endTime);
    const slotTime24 = convertTo24Hour(slotTime);

    // Check if the slotTime is between the startTime and endTime
    return slotTime24 >= startTime24 && slotTime24 < endTime24; 
}

// Convert 12-hour or 24-hour time to 24-hour time (e.g., '5:00 PM' -> '17:00' or '10:01' -> '10:01')
function convertTo24Hour(time) {
    // Ensure time is defined and correctly formatted
    if (!time || !time.includes(':')) {
        console.warn('Invalid time format:', time);
        return 0; // Return 0 for invalid time format
    }

    // Check if the time includes AM/PM
    const is12HourFormat = time.match(/[APMapm]{2}$/);

    if (is12HourFormat) {
        // Handle 12-hour time format with AM/PM
        const [timePart, period] = time.split(' ').map(t => t.trim());
        const [hour, minute] = timePart.split(':').map(Number);

        let adjustedHour = hour;
        if (period === 'PM' && hour < 12) adjustedHour += 12;  // Convert PM to 24-hour time
        if (period === 'AM' && hour === 12) adjustedHour = 0;  // Convert 12 AM to 00:00

        return adjustedHour * 60 + minute;  // Return minutes since midnight
    } else {
        // Handle 24-hour time format (e.g., '10:01')
        const [hour, minute] = time.split(':').map(Number);
        return hour * 60 + minute;  // Return minutes since midnight
    }
}

             // Convert HH:MM to minutes since midnight for easy comparison
              function parseTime(t) {
                  let [hours, minutes] = t.split(':').map(Number);
                  return hours * 60 + minutes;
              }
          
              // Format date as YYYY-MM-DD for comparison
              function formatDate(date) {
                  return date.toISOString().split('T')[0];
              }
          
              // Load doctors when the page loads
              document.addEventListener("DOMContentLoaded", loadDoctors);
          </script>
          
          