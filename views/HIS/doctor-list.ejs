<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <title>Doctors</title>
    <%- include("../header") -%>
  </head>
  <body>
    

    <div class="content-wrapper">
      <div class="container-xxl flex-grow-1 container-p-y">
        <div class="card mb-4">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">All Doctors</h5>
            <button
              class="btn btn-primary"
              onclick="window.location.href='/doctor-registration'"
            >
              <i class="bx bx-plus me-1"></i> New Doctor
            </button>
          </div>

          <div class="table-responsive text-nowrap">
            <table class="table" id="doctorsTable">
              <thead>
                <tr>
                  <th>Photo</th>
                  <th>Name</th>
                  <th>Specialization</th>
                  <th>Phone</th>
                  <th>Email</th>
                  <th>Since</th>
                  <th>Fees</th>
                  <th>IPD</th>
                  <th>OPD</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="doctorTbody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <%- include("../footer") -%>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const tbody = document.getElementById("doctorTbody");

        axios.get("/getdoctors")
          .then(({ data }) => {
            if (!data.success) return;
            tbody.innerHTML = "";

            data.doctors.forEach((d) => {
              const imgUrl = d.image
                ? `/MyUploads/${d.image}`
                : "/images/1.png";

              tbody.insertAdjacentHTML("beforeend", `
                <tr data-doctorid="${d.id}">
                  <td>
                    <img
                      src="${imgUrl}"
                      alt="${d.name}"
                      class="rounded-circle"
                      width="40"
                    />
                  </td>
                  <td>${d.name}</td>
                  <td>${d.specialization || "-"}</td>
                  <td>${d.phoneNumber}</td>
                  <td>${d.email || "-"}</td>
                  <td>${d.practicingSince || "-"}</td>
                  <td>${d.consultationFees != null ? d.consultationFees : "-"}</td>
                  <td>
                    <input
          class="form-check-input"
          type="checkbox"
          disabled
          ${d.ipd ? "checked" : ""}
        />
                   
                  </td>
                  <td>
                    <input
          class="form-check-input"
          type="checkbox"
          disabled
          ${d.opd ? "checked" : ""}
        />
                   
                  </td>
                
                   <td>
              <button class="btn btn-icon item-edit">
                <i class="bx bx-edit"></i>
              </button>
            </td>
                </tr>
              `);
            });
          })
          .catch((err) => {
            console.error("Error loading doctors:", err);
          });

           document.getElementById("doctorsTable").addEventListener("click", e => {
    if (!e.target.closest(".item-edit")) return;
    const tr = e.target.closest("tr");
    ViewBtn("doctor-registration", tr.dataset.doctorid);
  });
      });
    </script>
  </body>
</html>
