   </style>
  <%- include('../footer') -%>
<script src="../javascripts/helpers.js"></script>
<script src="../javascripts/config.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
   function formatDateTime(dateTimeStr) {
    if (!dateTimeStr) return '—';
    const dt = new Date(dateTimeStr);
    return dt.toLocaleString('en-GB', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  }
  // Initialize Bootstrap components
  document.addEventListener('DOMContentLoaded', function() {

     const now = new Date();
    // Format to "YYYY-MM-DDTHH:MM"
    const year = now.getFullYear();
    const month = String(now.getMonth() + 1).padStart(2, "0");
    const day = String(now.getDate()).padStart(2, "0");
    const hours = String(now.getHours()).padStart(2, "0");
    const minutes = String(now.getMinutes()).padStart(2, "0");

    const formatted = `${year}-${month}-${day}T${hours}:${minutes}`;
    document.getElementById("paymentDate").value = formatted;
      // Helper to get query parameter from URL
  
    // Tab functionality
    const triggerTabList = [].slice.call(document.querySelectorAll('#patientTabs a'))
    triggerTabList.forEach(function (triggerEl) {
      const tabTrigger = new bootstrap.Tab(triggerEl)
      
      triggerEl.addEventListener('click', function (event) {
        event.preventDefault()
        tabTrigger.show()
      })
    });
    
    // Form submission handlers
   document.getElementById('followUpForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const patientId = document.getElementById('patientId').value;
    const formData = new FormData(this);
    const payload = {
      patientId: patientId,
      nextFollowUpDate: formData.get('nextFollowUpDate'),
      followUpType: formData.get('followUpType'),
      notes: formData.get('notes')
    };

    try {
      await axios.post('/save-followup', payload);
      alert('Follow-up scheduled successfully!' );
      this.reset();
      fetchFollowupHistory();
      fetchPatientDetails();
    } catch (error) {
      console.error('Error saving follow-up:', error);
      alert('Failed to schedule follow-up.');
    }
  });
    
   
  // Handle interaction form submission
  document.getElementById('interactionForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = e.target;
    const formData = new FormData();

    formData.append('patientId', document.getElementById('patientId').value);
    formData.append('interactionType', document.getElementById('interactionType').value);
    formData.append('interactionDateTime', document.getElementById('interactionDateTime').value); 
    formData.append('interactionFollowupDate', document.getElementById('interactionFollowupDate').value); 
    formData.append('interactionFollowupType', document.getElementById('interactionFollowUpType').value); 
    formData.append('discardDate', document.getElementById('discardDate').value); 
    formData.append('shiftedDate', document.getElementById('shiftedDate').value); 
    formData.append('summary', document.getElementById('summary').value);

    const fileInput = document.getElementById('document');
    if (fileInput.files.length) {
      formData.append('document', fileInput.files[0]);
    }

    try {
      await axios.post('/save-interaction', formData, {
        headers: { 'Content-Type': 'multipart/form-data' }
      });
      alert('Interaction logged successfully!');
      form.reset();
      fetchInteractionHistory();
      fetchPatientDetails();
    } catch (err) {
      console.error('Error saving interaction:', err);
      alert('Failed to log interaction.');
    }
  });

  
  document.getElementById('paymentForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    const patientId = document.getElementById('patientId').value;
    const paidAmount = parseFloat(document.getElementById('amountPaid').value);
    const paidUptoDate = document.getElementById('paidUptoDate').value;
      const paymentDate = document.getElementById('paymentDate').value;
    const notes = document.getElementById('paymentNotes').value || '';

    // paymentDate = now
    const nowISOString = new Date().toISOString();

    const payload = {
      patientId: Number(patientId),
      paidAmount,
      paidUptoDate,
      balance: parseFloat(document.getElementById('balance').value) || null,
      notes,
      paymentDate
    };

    try {
      await axios.post('/save-payment', payload);
      alert('Payment recorded successfully!');
      this.reset();
      // Reset balance field
      document.getElementById('balance').value = '';
      fetchPaymentHistory();
      fetchPatientDetails();
    } catch (error) {
      console.error('Error saving payment:', error);
      alert('Failed to record payment.');
    }
  });

  // Helper to get query parameter from URL
  function getQueryParam(param) {
    const urlParams = new URLSearchParams(window.location.search);
    return urlParams.get(param);
  }

  // Convert date from YYYY-MM-DD to readable format (e.g. 25 Aug 2023)
  function formatDate(dateStr) {
    if (!dateStr) return '—';
    const options = { year: 'numeric', month: 'short', day: '2-digit' };
    return new Date(dateStr).toLocaleDateString('en-GB', options);
  }

  async function fetchPatientDetails() {
    const patientId = getQueryParam("id");
    if (!patientId) {
      alert("No patient ID provided in the URL.");
      return;
    }

    try {
      const response = await axios.get(`/patients/${patientId}`);
      const data = response.data.patient;

      // Set patient details
      console.log(data)
      const status = data.status?.toLowerCase();
  if (status === 'discarded' || status === 'shifted') {
    // disable all action buttons
    document.getElementById('logInteractionBtn').disabled   = true;
    document.getElementById('saveFollowupbtn').disabled     = true;
    document.getElementById('savePaymentBtn').disabled      = true;
  }

      document.getElementById("regNo").textContent = data.reg_no || '—';
      document.getElementById("patientId").value = data.id;
      document.getElementById("patientName").textContent = data.patient_name || '—';
      document.getElementById("spouseName").textContent = data.spouse_name || '—';
      document.getElementById("primaryMobile").textContent = data.primary_mobile || '—';
      document.getElementById("secondaryMobile").textContent = data.secondary_mobile || '—';
      document.getElementById("email").textContent = data.email || '—';
      document.getElementById("opuDate").textContent = formatDate(data.opu_date);

      // Follow-ups and freezing
      document.getElementById("nextFollowup").textContent = formatDate(data.next_followup_date);
      document.getElementById("lastFollowup").textContent = formatDate(data.last_followup_date);
      document.getElementById("nextFreezingDue").textContent = formatDate(data.next_freezing_due_date);

      // Embryo & Egg status
      document.getElementById("embryosFrozen").textContent = data.no_of_embryo_frozen ?? '0';
      document.getElementById("eggsFrozen").textContent = data.no_of_egg_frozen ?? '0';
      document.getElementById("embryosRemaining").textContent = data.remaining_embryo ?? '0';
      document.getElementById("eggsRemaining").textContent = data.remaining_egg ?? '0';
      document.getElementById("patientBalance").textContent = data.amount_payable ?? '0';
      document.getElementById("patientStatus").textContent = data.status ?? 'Active';

    } catch (error) {
      console.error("Error fetching patient details:", error);
      alert("Failed to load patient data.");
    }
  }
    
  async function fetchFollowupHistory() {
     const patientId = getQueryParam("id");
    if (!patientId) {
      alert("No patient ID provided in the URL.");
      return;
    }
    try {
      const response = await axios.get(`/followups/${patientId}`);
      const history = response.data.followups; // expects an array\
      console.log(history)
      const tbody = document.getElementById('followupHistoryBody');
      tbody.innerHTML = '';
      history.forEach(fu => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${formatDate(fu.nextFollowUpDate)}</td>
          <td>${fu.followUpType.charAt(0).toUpperCase() + fu.followUpType.slice(1)}</td>
          <td>${fu.notes}</td>
        
          <td>${fu.username}</td>
        `;
        tbody.appendChild(tr);
      });
    } catch (error) {
      console.error('Error fetching follow-up history:', error);
    }
  }

  async function fetchInteractionHistory() {
     const patientId = getQueryParam("id");
    if (!patientId) {
      alert("No patient ID provided in the URL.");
      return;
    }
    try {
      const response = await axios.get(`/interactions/${patientId}`);
      const interactions = response.data.interactions; // expects [{ interactionDateTime, interactionType, summary, username, documentUrl }, ...]
      const tbody = document.getElementById('interactionHistoryBody');
      console.log(interactions)
      tbody.innerHTML = '';

      interactions.forEach(item => {
        const tr = document.createElement('tr');
        // Link to download/view document if available
        const docCell = item.documentUrl
          ? `<a href="/MyUploads/${item.documentUrl}" target="_blank">View</a>`
          : '—';

        tr.innerHTML = `
          <td>${formatDateTime(item.interactionDateTime)}</td>
          <td>${item.interactionType.charAt(0).toUpperCase() + item.interactionType.slice(1)}</td>
          <td>${item.summary}</td>
          <td>${item.username}</td>
          <td>${docCell}</td>
        `;
        tbody.appendChild(tr);
      });
    } catch (err) {
      console.error('Error fetching interaction history:', err);
    }
  }
 
  async function fetchPaymentHistory() {
     const patientId = getQueryParam("id");
    if (!patientId) {
      alert("No patient ID provided in the URL.");
      return;
    }
    try {
      const response = await axios.get(`/payments/${patientId}`);
      const payments = response.data.payments; // expects array of { paymentDate, paidAmount, paidUptoDate, balance, notes, username }
      const tbody = document.getElementById('paymentHistoryBody');
      tbody.innerHTML = '';
      payments.forEach(item => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${formatDateTime(item.paymentDate)}</td>
          <td>₹${parseFloat(item.paidAmount).toFixed(2)}</td>
          <td>${item.paidUptoDate ? new Date(item.paidUptoDate).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : '—'}</td>
          <td>₹${item.balance != null ? parseFloat(item.balance).toFixed(2) : '0.00'}</td>
          <td>${item.notes || '—'}</td>
          <td>${item.username}</td>
        `;
        tbody.appendChild(tr);
      });
    } catch (error) {
      console.error('Error fetching payment history:', error);
    }
  }
   
  fetchPatientDetails();
    fetchFollowupHistory();
    fetchInteractionHistory();
    fetchPaymentHistory();
  
  });
</script>




</body>
