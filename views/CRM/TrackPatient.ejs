        </div>
      </div>
    

      <div class="col-md-12">
        <button type="submit" id="logInteractionBtn" class="btn btn-primary">Log Interaction</button>
      </div>
    </div>
  </form>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const typeSelect    = document.getElementById('interactionType');
    const docInput      = document.getElementById('document');
    const discardWrap   = document.getElementById('discardDateWrapper');
    const discardInput  = document.getElementById('discardDate');
    const shiftedWrap   = document.getElementById('shiftedDateWrapper');
    const shiftedInput  = document.getElementById('shiftedDate');

    function updateFields() {
      const val = typeSelect.value;
      
      // Reset all
      discardWrap.style.display   = 'none';
      discardInput.required       = false;
      shiftedWrap.style.display   = 'none';
      shiftedInput.required       = false;
      docInput.required           = false;

      if (val === 'Discard') {
        discardWrap.style.display = 'block';
        discardInput.required     = true;
        docInput.required         = true;
      }
      else if (val === 'Shifted To Another Clinic') {
        shiftedWrap.style.display = 'block';
        shiftedInput.required     = true;
        docInput.required         = true;
      }
    }

    typeSelect.addEventListener('change', updateFields);
    // initialize on load
    updateFields();
  });
</script>
  <div class="mt-4">
    <h5 class="section-title">Interaction History</h5>
    <div class="table-responsive">
