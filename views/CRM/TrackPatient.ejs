  <form id="interactionForm" class="mb-4" enctype="multipart/form-data">
    <input type="hidden" id="patientId" name="patientId">
    <div class="row">
      <div class="col-md-4">
        <div class="mb-3">
          <label class="form-label">Interaction Type*</label>
          <select class="form-select" id="interactionType" name="interactionType" required>
            <option value="">Select Type</option>
            <option value="phone">Phone Call</option>
            <option value="whatsapp">Whatsapp</option>
            <option value="letter">Letter</option>
            <option value="email">Email</option>
            <option value="sms">SMS</option>
            <option value="in_person">In-person</option>
            <option value="Discard">Discard</option>
            <option value="Shifted To Another Clinic">Shifted To Another Clinic</option>
          </select>
        </div>
          <div class="mb-3" id="discardDateWrapper" style="display:none;">
  <label class="form-label">Discard Date*</label>
  <input type="date" class="form-control" id="discardDate" name="discardDate">
</div>
<div class="mb-3" id="shiftedDateWrapper" style="display:none;">
  <label class="form-label">Shifted Date*</label>
  <input type="date" class="form-control" id="shiftedDate" name="shiftedDate">
</div>

      </div>
      <div class="col-md-4">
        <div class="mb-3">
          <label class="form-label">Date & Time*</label>
          <input type="datetime-local" class="form-control" id="interactionDateTime" name="interactionDateTime" required>
        </div>
      
        <script>
  window.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById("interactionDateTime");
    const now = new Date();

    const year = now.getFullYear();
    const month = String(now.getMonth() + 1).padStart(2, '0');
    const day = String(now.getDate()).padStart(2, '0');
    const hours = String(now.getHours()).padStart(2, '0');
    const minutes = String(now.getMinutes()).padStart(2, '0');

    const localDateTime = `${year}-${month}-${day}T${hours}:${minutes}`;
    input.value = localDateTime;
  });
</script>
 <div class="mb-3">
          <label class="form-label">Next Follow-up Date</label>
          <input type="date" class="form-control" id="interactionFollowupDate" name="interactionFollowupDate" >
        </div>
      </div>
       
      <div class="col-md-4">
        <div class="mb-3">
          <label class="form-label">Attach Document</label>
          <input type="file" id="document" name="document" class="form-control">
        </div>
        <div class="mb-3">
                          <label class="form-label">Follow-up Type</label>
                          <select class="form-select" name="interactionFollowUpType"  id="interactionFollowUpType">
                            <option value="">Select Type</option>
                            <option value="consultation">Consultation</option>
                            <option value="procedure">Procedure</option>
                            <option value="payment" selected>Payment</option>
                            <option value="checkup">Check-up</option>
                          </select>
                        </div>
        
      </div>
      <div class="col-md-12">
        <div class="mb-3">
