    if (!procedures.length) {
      $list.html('<div>No procedures available</div>');
      return;
    }

    // Build checkboxes dynamically
    const items = procedures.map(p => {
      const val = p.name ?? '';
      const isChecked = selectedValues.includes(val) ? 'checked' : '';
      return `<label><input type="checkbox" value="${val}" ${isChecked}> ${escapeHtml(val)}</label>`;
    });

    $list.html(items.join(''));

    // Update summary when checked
