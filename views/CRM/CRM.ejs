// 1) Fetch & render appointments
async function fetchAppointments() {
  if (!patientId) return;

  try {
    const res   = await axios.get(`/crm/leadAppointments?patientId=${patientId}`);
    console.log('fetchAppointments -> response:', res.data);
    const rows  = res.data.appointments || [];
    const tbody = document.querySelector('#appointmentTable tbody');
    tbody.innerHTML = '';

    if (!rows.length) return;

    // Render appointment rows
    rows.forEach(apt => {
      const dt = new Date(apt.appointment_date)
        .toLocaleDateString('en-US', {
          month: 'long',
          day: 'numeric',
          year: 'numeric'
        });

      const key = (apt.status || '').toLowerCase().replace(/\s+/g, '-');
      let statusCellHtml = `
        <span class="status-badge status-${key} clickable"
              data-id="${apt.id}"
              data-datetime="${apt.appointment_date}"
              data-status="${apt.status}">
          ${apt.status}
        </span>`;

      if (apt.status !== 'Scheduled') {
        statusCellHtml = `<span class="status-badge status-${key}">${apt.status}</span>`;
      }

      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>${apt.appointment_clinic}</td>
        <td>${dt} at ${apt.apptTimeSlot}</td>
        <td>${apt.appointment_doctor}</td>
        <td class="status-cell">${statusCellHtml}</td>`;
      tbody.appendChild(tr);
    });

    // ✅ If first record is 'Scheduled', click aptTabBtn and disable followupTabBtn
    const latest = rows[0];
    const aptTabBtn = document.getElementById('aptTabBtn');
    const followupTabBtn = document.getElementById('followupTabBtn');

    if (latest && latest.status === 'Scheduled') {
      if (aptTabBtn) aptTabBtn.click();
      if (followupTabBtn) {
        followupTabBtn.disabled = true;
        followupTabBtn.style.opacity = '0.5';
        followupTabBtn.style.cursor = 'not-allowed';
      }
    } else if (followupTabBtn) {
      // Re-enable followupTabBtn if not scheduled
      followupTabBtn.disabled = false;
      followupTabBtn.style.opacity = '1';
      followupTabBtn.style.cursor = 'pointer';
    }

    // 🟢 Attach click handler for status updates
    document.querySelectorAll('.status-cell .clickable').forEach(badge => {
      badge.onclick = () => {
        const id        = badge.dataset.id;
        const oldStatus = badge.dataset.status;
        const cell      = badge.parentElement;
        const date      = badge.dataset.datetime;

        const select = document.createElement('select');
        ['Scheduled','Visited','Rescheduled','Cancelled'].forEach(opt => {
          const o = document.createElement('option');
          o.value = opt;
          o.textContent = opt;
          if (opt === oldStatus) o.selected = true;
          select.appendChild(o);
        });

        select.onchange = async e => {
          const newStatus = e.target.value;
          if (newStatus === 'Rescheduled') {
            apptModalEl2.dataset.appointmentId = id;
            apptModal2.show();
          } else if (newStatus === 'Cancelled') {
            followupModalEl.dataset.appointmentId = id;
            followupModal.show();
          } else {
            await updateAppointment(id, { status: newStatus, date });
            fetchAppointments();
          }
        };

        cell.innerHTML = '';
        cell.appendChild(select);
        select.focus();
      };
    });

  } catch (err) {
    console.error('Fetch appointments failed', err);
  }
}

