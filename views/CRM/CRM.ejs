<style>
/* Multiselect dropdown-checkbox styles */
.multiselect {
  position: relative;
  user-select: none;
  width: 100%;
  max-width: 480px;
}

.multiselect-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 10px;
  border: 1px solid var(--border, #ddd);
  border-radius: 6px;
  background: #fff;
  cursor: pointer;
  gap: 8px;
  min-height: 40px;
  box-sizing: border-box;
}

.multiselect-toggle .summary {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1 1 auto;
  font-size: 0.95rem;
}

.multiselect-toggle .caret {
  margin-left: 8px;
  transform: rotate(0deg);
  transition: transform 0.15s ease;
}

/* open state rotates caret */
.multiselect.open .caret {
  transform: rotate(180deg);
}

/* the dropdown list */
.multiselect-list {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  width: 100%;
  max-height: 210px;
  overflow: auto;
  background: white;
  border: 1px solid var(--border, #ddd);
  border-radius: 6px;
  box-shadow: 0 6px 18px rgba(0,0,0,0.08);
  z-index: 60;
  padding: 8px;
  display: none;
}

/* show */
.multiselect.open .multiselect-list { display: block; }

/* each checkbox row */
.multiselect-list label {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 6px;
  cursor: pointer;
  border-radius: 4px;
}
.multiselect-list label:hover {
  background: rgba(0,0,0,0.03);
}

.multiselect-list input[type="checkbox"] {
  width: 16px;
  height: 16px;
}

/* small helper text */
.multiselect-note {
  font-size: 0.85rem;
  color: #666;
  margin-top: 6px;
}

/* Responsive small adjustments — same grid system used earlier */
.add-record-form { display: grid; grid-template-columns: 1fr; gap: 0.75rem; }
@media (min-width: 720px) {
  .add-record-form { grid-template-columns: 1fr 1fr; }
}
.full-span { grid-column: 1 / -1; }
.form-group { display:flex; flex-direction:column; }
.form-group label { font-size: 0.9rem; margin-bottom: 0.25rem; }
.form-group input, .form-group textarea, .form-group select { padding:8px; border:1px solid var(--border,#ddd); border-radius:6px; width:100%; box-sizing:border-box; }
.btn-group { display:flex; justify-content:flex-end; }
@media (max-width:719px) { .btn-group{justify-content:stretch} .btn-group .add-btn{width:100%} }
</style>

