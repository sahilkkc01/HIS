    const currentDate = new Date();

    if (selectedDate > currentDate) {
      alert("Marriage date cannot be in the future.");
      return;
    }

    let years = currentDate.getFullYear() - selectedDate.getFullYear();
    let months = currentDate.getMonth() - selectedDate.getMonth();
    let days = currentDate.getDate() - selectedDate.getDate();

    if (days < 0) {
      months--;
      days += new Date(currentDate.getFullYear(), currentDate.getMonth(), 0).getDate();
    }

    if (months < 0) {
      years--;
      months += 12;
    }

    document.getElementById('marriageYears').value = years;
    document.getElementById('marriageMonths').value = months;
    document.getElementById('marriageDays').value = days;
  });

  // Show "Other" treatment input
  document.getElementById('otherTreatmentCheckbox').addEventListener('change', function () {
    const input = document.getElementById('otherTreatmentInput');
    input.style.display = this.checked ? 'block' : 'none';
  });
</script>

<script>
document.getElementById('patientForm').addEventListener('submit', async function (e) {
    e.preventDefault();

    const patientId      = document.getElementById('patientId').value;
    const leadDate       = document.getElementById('leadDate').value;
    const femaleName     = document.getElementById('femaleName').value.trim();
    const femaleAge      = document.getElementById('femaleAge').value;
    const maleName       = document.getElementById('maleName').value.trim();
    const maleAge        = document.getElementById('maleAge').value;
    const contactPrimary = document.getElementById('contactNumber1').value;
    const contactAlt     = document.getElementById('contactNumber2').value;
    const email          = document.getElementById('email').value.trim();
    const clinic         = document.getElementById('clinic').value;
    const marriageDate   = document.getElementById('marriageDate').value;

    const marriageYears  = document.getElementById('marriageYears').value;
    const marriageMonths = document.getElementById('marriageMonths').value;
    const marriageDays   = document.getElementById('marriageDays').value;

    const pastTreatmentEls = document.querySelectorAll('input[name="pastTreatment"]:checked');
    const pastTreatments = Array.from(pastTreatmentEls).map(cb => cb.value);
    if (pastTreatments.includes('Others')) {
      const otherTx = document.getElementById('otherTreatmentInput').value.trim();
      pastTreatments[pastTreatments.indexOf('Others')] = otherTx || 'Others';
    }

    let sourcePrimary = document.getElementById('sourceP').value;
    if (sourcePrimary === 'other') {
      const o = document.getElementById('otherSourcePInput').value.trim();
      sourcePrimary = o || 'Other';
    }
    const sourceSecondary = document.getElementById('sourceS').value.trim();

    const country     = document.getElementById('country').value;
    const state       = document.getElementById('state').value;
    const pinCode     = document.getElementById('pinCode').value.trim();
    const fullAddress = document.getElementById('fullAddress').value.trim();

    const agent = document.getElementById('agent').value;
    const admin = document.getElementById('admin').value;

    const payload = {
      patientId,
      leadDate,
      female: { name: femaleName, age: femaleAge },
      male:   { name: maleName,   age: maleAge   },
      contacts: { primary: contactPrimary, alternate: contactAlt },
      email,
      clinic,
      marriage: {
        date: marriageDate,
        years: marriageYears,
        months: marriageMonths,
        days: marriageDays
      },
      pastTreatments,
      sources: {
        primary: sourcePrimary,
        secondary: sourceSecondary
      },
      address: { country, state, pinCode, fullAddress },
      agent,
      admin
    };

    try {
      let res;
      if (patientId) {
        // Update existing lead
        res = await axios.post('/updateLead', payload);
        alert('Lead updated successfully!');
      } else {
        // Create new lead
        res = await axios.post('/crm/saveLead', payload);
        alert('Lead saved successfully!');
      }

      const pid = res.data.lead.patientId;
      window.location.href = `/crm/crm?id=${pid}`;

    } catch (err) {
      console.error(err);
      alert('Error saving lead: ' + (err.response?.data?.message || err.message));
    }
  });

  async function loadSourceOptions(defaultId = '') {
  const $select = $('#sourceP');
  $select.prop('disabled', true);
  $select.html('<option value="">Loading sources...</option>');

  try {
    const res = await axios.get('/sources/list');
    // server may return { sources: [...] } or an array directly
    const list = Array.isArray(res.data) ? res.data : (res.data.sources || []);
    if (!list.length) {
      $select.html('<option value="">No sources available</option>');
      return;
    }

    // build options
    const options = ['<option value="">Select source...</option>'];
    list.forEach(s => {
      // use s.id (or s.source_id) depending on your API; handle both
      const val = s.name ?? '';
      const name = (s.name || s.sourceName || '').toString();
      options.push(`<option value="${val}">${escapeHtml(name)}</option>`);
    });

    $select.html(options.join(''));
    if (defaultId) {
      $select.val(defaultId.toString());
    }
  } catch (err) {
    console.error('Failed to load sources:', err);
    $select.html('<option value="">Failed to load sources</option>');
  } finally {
    $select.prop('disabled', false);
  }
}
 
