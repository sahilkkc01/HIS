function getSelectedProcedures() {
  const list = document.querySelector('#procedureList');
  if (!list) return [];
  return Array.from(list.querySelectorAll('input[type="checkbox"]:checked')).map(cb => cb.value);
}

/* Collect payload for converted form */
function collectConvertedPayload(patientId) {
  return {
    patient_id: patientId,
    procedures: getSelectedProcedures(), // array
    package_price: parseFloat(document.getElementById('packagePrice')?.value) || 0,
    package_offered: parseFloat(document.getElementById('packageOffered')?.value) || 0,
    discount: parseFloat(document.getElementById('conversionDiscount')?.value) || 0,
    counselor_name: document.getElementById('counselorName')?.value?.trim() || '',
    booking_date: document.getElementById('bookingDate')?.value || null,
    payment_status: 'pending' // default
  };
}

/* Clear converted form */
function clearConvertedForm() {
  document.querySelectorAll('#procedureList input[type="checkbox"]').forEach(cb => cb.checked = false);
  document.getElementById('packagePrice').value = '';
  document.getElementById('packageOffered').value = '';
  document.getElementById('conversionDiscount').value = '';
  document.getElementById('counselorName').value = '';
  document.getElementById('bookingDate').value = '';
  const evt = new Event('change');
  document.getElementById('procedureList')?.dispatchEvent(evt);
}

/* Save converted record using Axios */
async function saveConverted() {
  const params = new URLSearchParams(window.location.search);
  const patientId = params.get('id');

  if (!patientId) {
    alert('Patient ID is required');
    return;
  }

  const payload = collectConvertedPayload(patientId);
  console.log('Converted payload:', payload);

  try {
    const res = await axios.post('/crm/saveConverted', payload);
    if (res.status === 201 || res.status === 200) {
      alert(res.data.message || 'Conversion record saved successfully');
      clearConvertedForm();
      fetchConvertedForPatient(patientId);
    } else {
      alert(res.data.message || 'Failed to save conversion');
    }
  } catch (err) {
    console.error('Error saving converted record:', err);
    alert(err.response?.data?.message || 'Error saving converted record (check console)');
  }
}

async function fetchConvertedForPatient(patientId) {
  if (!patientId) return;

  try {
    const res = await axios.get(`/crm/getConverted?patientId=${encodeURIComponent(patientId)}`);
    if (res.status !== 200) throw new Error('Failed to fetch converted records');

    const converted = res.data.converted || [];
    const tbody = document.querySelector('#convertedTable tbody');
    const conversionSection = document.getElementById('conversionForSection');
    const addOnProcBtn = document.getElementById('addOnProcBtn');

    if (!tbody) return;
    tbody.innerHTML = '';

    if (converted.length > 0) {
      // Hide the form section if records exist
      if (conversionSection) conversionSection.style.display = 'none';
      // Show the "Add On Procedure" button
      if (addOnProcBtn) addOnProcBtn.style.display = 'block';
    } else {
      // Show the form section if no records
      if (conversionSection) conversionSection.style.display = 'block';
      // Hide the "Add On Procedure" button
      if (addOnProcBtn) addOnProcBtn.style.display = 'none';
      tbody.innerHTML = `<tr><td colspan="7" style="text-align:center; padding:8px;">No conversion records found.</td></tr>`;
      return;
    }

    // Populate table
    converted.forEach(c => {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>${formatDate(c.latest_visited_date) || ''}</td>
        <td>${formatDate(c.booking_date) || ''}</td>
        <td>${c.procedures.join(', ')}</td>
        <td>${c.package_price || '0.00'}</td>
        <td>${c.package_offered || '0.00'}</td>
        <td>${c.discount || '0.00'}</td>
        <td>${c.counselor_name || ''}</td>
      `;
      tbody.appendChild(tr);
    });
  } catch (err) {
    console.error('Error fetching converted records:', err);
  }
}



