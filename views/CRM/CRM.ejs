/* Fetch follow-ups for a visit */
async function fetchFollowUpsForVisit(visitId) {
  try {
    const res = await fetch(`/crm/visitFollowUps?visitId=${encodeURIComponent(visitId)}`);
    const json = await res.json();
    const followUps = json.followUps || [];

    const tbody = document.getElementById(`followUpTbody_${visitId}`);
    if (!tbody) return;
    tbody.innerHTML = '';

    if (!followUps.length) {
      tbody.innerHTML = `<tr><td colspan="6" style="text-align:center; padding:8px;">No follow-ups found.</td></tr>`;
      return;
    }

    followUps.forEach(f => {
      // sanitize classes (lowercase, replace spaces with hyphen)
      const safeStatusClass = (f.status || '').toString().toLowerCase().replace(/\s+/g, '-');
      const safePriorityClass = (f.priority || '').toString().toLowerCase().replace(/\s+/g, '-');

      // build status HTML: clickable only when status is exactly "Scheduled"
      let statusCellHtml;
     
        statusCellHtml = `
          <span class="status-badge status-${safeStatusClass} "
                data-id="${escapeHtml(f.id)}"
                data-datetime="${escapeHtml(f.followup_date || '')}"
                data-status="${escapeHtml(f.status)}">
            ${escapeHtml(f.status)}
          </span>`;
      

      const tr = document.createElement('tr');
      console.log('Rendering follow-up for visit', visitId, f);
      tr.innerHTML = `
        <td>${formatDate(f.call_date)}</td>
        <td>${formatDate(f.followup_date)}</td>
        <td>${escapeHtml(f.remark)}</td>
        <td>
          <span class="status-badge badge-priority badge-priority-${safePriorityClass}">
            ${escapeHtml(f.priority || '')}
          </span>
        </td>
        <td>${statusCellHtml}</td>
        <td>${escapeHtml(f.created_by)}</td>
      `;
      tbody.appendChild(tr);
    });

  } catch (err) {
    console.error('fetchFollowUpsForVisit error', visitId, err);
  }
}

async function saveVisitedFollowUp(visitId, visitRecord = {}) {
  try {
    const callDateEl     = document.getElementById(`callDate_${visitId}`);
    const remarkEl       = document.getElementById(`followUpRemark_${visitId}`);
    const priorityEl     = document.getElementById(`prioritySelect_${visitId}`);
    const statusEl       = document.getElementById(`statusSelect_${visitId}`);
    const followupDateEl = document.getElementById(`followupDate_${visitId}`);

    const payload = {
      visit_id: visitId,
      patient_id: visitRecord.patient_id || patientId || null,
      call_date: callDateEl?.value,
      remark: remarkEl?.value?.trim(),
      priority: priorityEl?.value,
      status: statusEl?.value,
      followup_date: followupDateEl?.value || null,
    };
    console.log('saveVisitedFollowUp payload', payload);

    const res = await fetch('/crm/saveVisitfollowUp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    if (!res.ok) {
      const err = await res.json().catch(()=>({}));
      throw new Error(err.message || 'Failed to save follow-up');
    }

    const json = await res.json();
    alert(json.message || 'Follow-up saved');

     
      if (payload.status === "converted") {
        const convTabBtn = document.getElementById("convTabBtn");
        if (convTabBtn) convTabBtn.click();
      }
    // ✅ Clear inputs after save
    // if (callDateEl) callDateEl.value = '';
    if (remarkEl) remarkEl.value = '';
    // if (priorityEl) priorityEl.value = '';   // or reset to default option if needed
    if (statusEl) statusEl.value = '';
    if (followupDateEl) followupDateEl.value = '';

    // reload list
    fetchFollowUpsForVisit(visitId);

  } catch (err) {
    console.error('saveVisitedFollowUp error', visitId, err);
    alert(err.message || 'Failed to save follow-up (check console)');
  }
}


