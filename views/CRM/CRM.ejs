    }
  }
});

  async function fetchLead(patientId) {
    try {
     
      const res = await axios.get(`/crm/getlead/${patientId}`);
      const data = res.data.lead;

      // populate each field:
      document.getElementById('patientId').value      = data.patientId;
      const lead_date =  document.getElementById('leadDate')
      lead_date.value= data.lead_date;
lead_date.readOnly = true;
const femaleInput = document.getElementById('femaleName');
femaleInput.value = data.female_name;
femaleInput.readOnly = true;


      document.getElementById('femaleAge').value      = data.female_age;
      document.getElementById('maleName').value       = data.male_name || '';
      document.getElementById('maleAge').value        = data.male_age || '';
     const contactInput = document.getElementById('contactNumber1');
contactInput.value = data.primary_mobile;
contactInput.readOnly = true;
      document.getElementById('contactNumber2').value = data.secondary_mobile || '';
      document.getElementById('email').value          = data.email || '';
      document.getElementById('clinic').value         = data.clinic;
      
      // marriage
      const md = data.marriage_duration;
      document.getElementById('marriageDate').value   = data.marriageDate;
      document.getElementById('marriageYears').value  = md.years;
      document.getElementById('marriageMonths').value = md.months;
      document.getElementById('marriageDays').value   = md.days;

      // past treatments
      const pts = JSON.parse(data.past_treatments || '[]');
      document.querySelectorAll('input[name="pastTreatment"]').forEach(cb => {
        cb.checked = pts.includes(cb.value);
      });
      if (pts.some(v => !['IVF','IUI','Surgery','Others'].includes(v))) {
        document.getElementById('otherTreatmentCheckbox').checked = true;
        document.getElementById('otherTreatmentInput').style.display = 'block';
        document.getElementById('otherTreatmentInput').value = pts.find(v => !['IVF','IUI','Surgery','Others'].includes(v));
      }

      // sources
      // if (['google-seo','google-ppc','social-media','camp','opd','staff','dr-referral','visiting-doctor'].includes(data.source_primary)) {
      //   document.getElementById('sourceP').value = data.source_primary;
      // } else {
      //   document.getElementById('sourceP').value = 'other';
      //   document.getElementById('otherSourcePInput').style.display = 'block';
      //   document.getElementById('otherSourcePInput').value = data.source_primary;
      // }
      console.log('Setting source primary to:', data.source_primary);
           document.getElementById('sourceP').value = data.source_primary;
      document.getElementById('sourceS').value = data.source_secondary || '';

      // address
      document.getElementById('country').value     = data.country;
      document.getElementById('state').value       = data.state;
      document.getElementById('pinCode').value     = data.pin_code || '';
      document.getElementById('fullAddress').value = data.full_address || '';

      // agent/admin
      document.getElementById('agent').value = data.agent;
      document.getElementById('admin').value = data.admin;

    } catch (err) {
      console.error('Fetch lead failed', err);
      alert('Could not load lead data.');
    }
  }
 
</script>
