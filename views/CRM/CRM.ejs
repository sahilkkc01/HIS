/* Multiselect dropdown behavior */
(function () {
  const wrapper = document.getElementById('procedureDropdown');
  if (!wrapper) return;
  const toggle = wrapper.querySelector('.multiselect-toggle');
  const list = wrapper.querySelector('.multiselect-list');
  const summary = document.getElementById('procedureSummary');

  function updateSummary() {
    const checked = Array.from(list.querySelectorAll('input[type="checkbox"]:checked')).map(i => i.value);
    if (!checked.length) {
      summary.textContent = 'Select procedures';
    } else if (checked.length <= 4) {
      summary.textContent = checked.join(', ');
    } else {
      summary.textContent = `${checked.length} selected`;
    }
  }

  toggle.addEventListener('click', e => {
    e.stopPropagation();
    wrapper.classList.toggle('open');
    toggle.setAttribute('aria-expanded', wrapper.classList.contains('open'));
  });

  list.addEventListener('change', updateSummary);

  document.addEventListener('click', e => {
    if (!wrapper.contains(e.target)) {
      wrapper.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
    }
  });

  wrapper.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      wrapper.classList.toggle('open');
      toggle.setAttribute('aria-expanded', wrapper.classList.contains('open'));
    } else if (e.key === 'Escape') {
      wrapper.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
    }
  });

  updateSummary();

  async function loadProcedureOptions(selectedValues = []) {
  const $list = $('#procedureList');
  const $summary = $('#procedureSummary');

  // Show loading state
  $list.html('<div>Loading Procedures...</div>');

  try {
