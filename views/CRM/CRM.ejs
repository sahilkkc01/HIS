<script>
let doctorsData = []; // store fetched doctors

// helper: parse "HH:mm" (or "H:mm") to minutes since midnight
function timeToMinutes(t) {
  if (!t) return null;
  const m = /^(\d{1,2}):(\d{2})(?::\d{2})?$/.exec(t.trim());
  if (!m) return null;
  return parseInt(m[1], 10) * 60 + parseInt(m[2], 10);
}

// helper: returns {startMin, endMin} for a slot string.
// supports "HH:mm", "HH:mm - HH:mm", "HH:mm-HH:mm"
function slotToRange(slotStr) {
  if (!slotStr) return null;
  const s = String(slotStr).trim();
  if (s.includes('-')) {
    const parts = s.split('-').map(p => p.trim());
    const startMin = timeToMinutes(parts[0]);
    const endMin = timeToMinutes(parts[1]);
    if (startMin == null || endMin == null) return null;
    return { startMin, endMin: endMin };
  } else {
    const startMin = timeToMinutes(s);
    if (startMin == null) return null;
    return { startMin, endMin: startMin + 10 }; // default 10-min duration for single time
  }
}

// generate 10-min slots between startTime and endTime (HH:MM)
function generateTimeSlots(startTime, endTime) {
  const slots = [];
  if (!startTime || !endTime) return slots;
  const start = new Date(`1970-01-01T${startTime}:00`);
  const end = new Date(`1970-01-01T${endTime}:00`);
  if (isNaN(start) || isNaN(end) || start >= end) return slots;

  let cur = new Date(start);
  const hhmm = t => t.toTimeString().slice(0,5);
  while (true) {
    const slotEnd = new Date(cur.getTime() + 10 * 60000);
    if (slotEnd > end) break;
    slots.push({ value: hhmm(cur), label: `${hhmm(cur)} - ${hhmm(slotEnd)}`, startMin: parseInt(hhmm(cur).split(':')[0],10)*60 + parseInt(hhmm(cur).split(':')[1],10) });
    cur = slotEnd;
  }
  return slots;
}

async function fetchDoctors() {
  try {
    const res = await axios.get('/doctors/list'); // returns { doctors: [...] }
    const doctors = res.data.doctors || [];
    window.doctorsData = doctors;
    console.log('Fetched doctors:', doctors);

    // Populate both selects (if they exist)
    const selectors = ['#apptDoctor', '#apptDoctor2'];
    selectors.forEach(sel => {
      const $sel = $(sel);
      if (!$sel.length) {
        console.warn('Doctor select not found:', sel);
        return;
      }
      const prev = $sel.val();
      $sel.empty().append('<option value="">Select Doctor</option>');
      doctors.forEach(d => {
        const name = (d.name || '').replace(/"/g, '&quot;');
        $sel.append(`<option value="${d.id}" data-name="${name}">${name}</option>`);
      });
      if (prev) $sel.val(prev);
    });

    // Update slots if anything prefilled
    updateTimeSlotsFor('#apptDoctor', '#apptDate', '#apptTimeSlot');
    updateTimeSlotsFor('#apptDoctor2', '#apptDateTime2', '#apptTimeSlot2');
  } catch (err) {
    console.error('Failed to fetch doctors', err);
  }
}

/**
 * updateTimeSlotsFor: populates a slot <select> and disables booked slots.
 * doctorSelector -> doctor <select>
 * dateSelector -> date input
 * slotSelector -> slot <select> to populate
 */
async function updateTimeSlotsFor(doctorSelector = '#apptDoctor', dateSelector = '#apptDate', slotSelector = '#apptTimeSlot') {
  const $doctorSelect = $(doctorSelector);
  const $dateInput = $(dateSelector);
  const $slotSelect = $(slotSelector);

  if (!$doctorSelect.length) { console.warn('Doctor selector not found:', doctorSelector); return; }
  if (!$dateInput.length) { console.warn('Date selector not found:', dateSelector); return; }
  if (!$slotSelect.length) { console.warn('Slot selector not found:', slotSelector); return; }

  const doctorIdRaw = $doctorSelect.val();
  const date = $dateInput.val(); // YYYY-MM-DD

  $slotSelect.empty().append('<option value="">Select Time Slot</option>');

  if (!doctorIdRaw) {
    $slotSelect.append('<option value="">Please select a doctor</option>');
    return;
  }
  if (!date) {
    $slotSelect.append('<option value="">Please select a date</option>');
    return;
  }

  const doctors = window.doctorsData || [];
  if (!doctors.length) {
    console.warn('No doctors cached yet (window.doctorsData empty).');
    $slotSelect.append('<option value="">Doctor data unavailable</option>');
    return;
  }

  const doctor = doctors.find(d => String(d.id) === String(doctorIdRaw));
  if (!doctor) {
    console.warn('Selected doctor not found in doctorsData. selectedId=', doctorIdRaw);
    $slotSelect.append('<option value="">Doctor data unavailable</option>');
    return;
  }

  // compute weekday name
  const dayName = new Date(date).toLocaleDateString('en-US', { weekday: 'long' });
  let times = (doctor.availability && doctor.availability[dayName]) ? doctor.availability[dayName] : null;
  if (!times && doctor.availability) {
    times = doctor.availability[dayName.toLowerCase()] || doctor.availability[new Date(date).getDay()];
  }
  if (!times || !times.start || !times.end) {
    $slotSelect.append('<option value="">No slots available</option>');
    return;
  }

  // build candidate slots
  const slots = generateTimeSlots(times.start, times.end);
  if (!slots.length) {
    $slotSelect.append('<option value="">No 10-min slots available</option>');
    return;
  }

  // Fetch booked appointments for this doctor on this date.
let bookedRanges = []; // array of {startMin, endMin}
try {
  const res = await axios.get('/crm/appointments', {
    params: {
      doctor_id: doctorIdRaw,
      start: date, // backend interprets as YYYY-MM-DD
      end: date
    }
  });
  const appts = res.data.appointments || [];
  
  // Only consider appointments that are Scheduled
  appts.forEach(a => {
    if (a.status === 'Scheduled') {
      const rng = slotToRange(a.apptTimeSlot);
      if (rng) bookedRanges.push(rng);
    }
  });
} catch (err) {
  console.warn('Failed to fetch appointments for booked slots; continuing without blocking slots', err);
}


  // helper: checks overlap between [aStart,aEnd) and [bStart,bEnd)
  function overlaps(aStart, aEnd, bStart, bEnd) {
    return aStart < bEnd && bStart < aEnd;
  }

  // Now populate options, disabling those that overlap any booked range
  slots.forEach(s => {
    const optVal = s.value; // e.g. "10:00"
    const optLabel = s.label; // "10:00 - 10:10"
    const slotStartMin = timeToMinutes(optVal);
    const slotEndMin = slotStartMin + 10;

    // check overlap
    let isBooked = false;
    for (const br of bookedRanges) {
      if (overlaps(slotStartMin, slotEndMin, br.startMin, br.endMin)) {
        isBooked = true;
        break;
      }
    }

    if (isBooked) {
      // disabled option — append book text and set disabled attribute
      $slotSelect.append(`<option value="${optVal}" disabled data-booked="1">${optLabel} — Booked</option>`);
    } else {
      $slotSelect.append(`<option value="${optVal}">${optLabel}</option>`);
    }
  });
}

// wiring
$(function () {
  fetchDoctors();

  // wire both groups
  $('#apptDoctor, #apptDate').on('change', function () {
    updateTimeSlotsFor('#apptDoctor', '#apptDate', '#apptTimeSlot');
  });

  $('#apptDoctor2, #apptDateTime2').on('change', function () {
    updateTimeSlotsFor('#apptDoctor2', '#apptDateTime2', '#apptTimeSlot2');
  });

  $('#appointmentModal').on('shown.bs.modal', function () {
    updateTimeSlotsFor('#apptDoctor', '#apptDate', '#apptTimeSlot');
    updateTimeSlotsFor('#apptDoctor2', '#apptDateTime2', '#apptTimeSlot2');
  });
});
</script>



