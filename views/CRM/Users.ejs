<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>User Master</title>
  <%- include('../header') -%>

  <style>
    .user-list { max-height:70vh; overflow-y:auto; }
    .user-item { cursor:pointer; padding:.5rem .75rem; border-bottom:1px solid #f1f1f1; }
    .user-item:hover { background:#f8f9fa; }
    .user-item.active { background:#e9f2ff; font-weight:600; }
    .no-users { padding:1rem; color:#6c757d; text-align:center; }
    .small-muted { font-size:.85rem; color:#6c757d; }
  </style>
</head>

<body>
<div class="container-fluid vh-100 d-flex flex-column">
<div class="container-fluid py-4">

<div class="card">
<h5 class="card-header">User Master</h5>

<div class="card-body">
<div class="row gx-4">

<!-- LEFT SIDE LIST -->
<div class="col-md-4 mb-3">
  <div class="d-flex justify-content-between align-items-center mb-2">
    <input id="userSearch" class="form-control form-control-sm" placeholder="Search users...">
    <button id="newUserBtn" class="btn btn-sm btn-outline-primary ms-2">New</button>
  </div>

  <div class="card shadow-sm">
    <div class="card-body p-2 user-list" id="userListContainer">
      <div class="no-users">Loading users...</div>
    </div>
  </div>
</div>

<!-- RIGHT SIDE FORM -->
<div class="col-md-8">

<form id="UserForm">
<input type="hidden" id="userId">

<div id="errordiv" style="display:none;"></div>

<div class="row mb-3">
  <div class="col-6 mb-2">
    <label class="form-label">Username*</label>
    <input type="text" id="username" class="form-control form-control-sm" required>
  </div>

  <div class="col-6 mb-2">
    <label class="form-label">Password*</label>
    <input type="password" id="password" class="form-control form-control-sm">
  </div>
</div>

<div class="row mb-3">
  <div class="col-6 mb-2">
    <label class="form-label">Full Name*</label>
    <input type="text" id="name" class="form-control form-control-sm" required>
  </div>

  <div class="col-6 mb-2">
    <label class="form-label d-block">Status</label>
    <div class="form-check form-switch">
      <input class="form-check-input" type="checkbox" id="status" checked>
      <label class="form-check-label">Active</label>
    </div>
  </div>
</div>

<div class="mt-3">
  <button type="submit" class="btn btn-primary btn-sm me-2">Save User</button>
</div>

</form>

</div>
</div>
</div>
</div>

</div>
</div>

<%- include('../footer') -%>

<script>
$(function(){

const listContainer = $('#userListContainer');
const formId = '#UserForm';
const errorDiv = '#errordiv';
let cache = [];
let activeId = null;

/* ---------------- LOAD USERS ---------------- */
async function loadUsers(){
  listContainer.html('<div class="no-users">Loading users...</div>');
  try{
    const res = await axios.get('/getUsers');
    cache = res.data.users || [];
    renderList(cache);
  }catch(e){
    listContainer.html('<div class="no-users">Failed to load users.</div>');
  }
}

/* ---------------- RENDER LIST ---------------- */
function renderList(list, filter=''){
  listContainer.empty();

  const filtered = list.filter(u =>
    (u.username||'').toLowerCase().includes(filter.toLowerCase())
  );

  if(!filtered.length){
    listContainer.html('<div class="no-users">No users found.</div>');
    return;
  }

  filtered.forEach(u=>{
    const el = $(`
      <div class="user-item" data-id="${u.id}">
        <div>${u.username}</div>
        <div class="small-muted">${u.name||''}</div>
      </div>
    `);

    if(u.id == activeId) el.addClass('active');

    el.on('click', ()=>{
      $('.user-item').removeClass('active');
      el.addClass('active');
      activeId = u.id;
      fillForm(u);
    });

    listContainer.append(el);
  });
}

/* ---------------- FILL FORM ---------------- */
function fillForm(u){
  $('#userId').val(u.id);
  $('#username').val(u.username).prop('disabled', true);
  $('#password').val('');
  $('#name').val(u.name);
  $('#status').prop('checked', u.status == 1);
  $(errorDiv).hide();
}

/* ---------------- NEW BUTTON ---------------- */
$('#newUserBtn').on('click', ()=>{
  activeId = null;
  $('.user-item').removeClass('active');
  $('#userId').val('');
  $('#username').val('').prop('disabled', false);
  $('#password').val('');
  $('#name').val('');
  $('#status').prop('checked', true);
  $(errorDiv).hide();
});

/* ---------------- SEARCH ---------------- */
$('#userSearch').on('input', function(){
  renderList(cache, $(this).val());
});

/* ---------------- SAVE USER ---------------- */
$(formId).on('submit', async function(e){
  e.preventDefault();

  const idVal = $('#userId').val();
  const data = {
    id: idVal,
    username: $('#username').val(),
    password: $('#password').val(),
    name: $('#name').val(),
    status: $('#status').is(':checked') ? 1 : 0
  };

  try{
    let res;
    if(idVal){
      res = await axios.post('/users/update', data);
    } else {
      res = await axios.post('/createUser', data);
    }

    $(errorDiv)
      .removeClass('alert-danger')
      .addClass('alert alert-success')
      .text(res.data.message || 'Saved successfully')
      .show();

    await loadUsers();
    setTimeout(()=>$(errorDiv).fadeOut(),1500);

  }catch(err){
    const em = err.response?.data?.message || 'Error saving user.';
    $(errorDiv)
      .removeClass('alert-success')
      .addClass('alert alert-danger')
      .text(em)
      .show();
  }
});

/* ---------------- INIT ---------------- */
loadUsers();

});
</script>

</body>
</html>