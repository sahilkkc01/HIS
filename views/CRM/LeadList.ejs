    tbody.innerHTML = '';
    res.data.forEach(a => {
      tbody.innerHTML += `<tr>
        <td>${a.patient_id}</td>
        <td>${a.female_name || 'N/A'}</td>
        <td>${a.male_name || 'N/A'}</td>
        <td>${a.appointment_clinic || '-'}</td>
        <td>${a.appointment_date ? new Date(a.appointment_date).toLocaleDateString() : '-'}</td>
        <td>${a.apptTimeSlot || '-'}</td>
        <td>${a.appointment_doctor || '-'}</td>
        <td>
  <button class="btn btn-sm btn-success"
    onclick="window.location.href='/patient-registration?leadId=${encodeURIComponent(a.patient_id)}'">
    Register
  </button>
</td>
        <td>${a.status || '-'}</td>
        <td>
          <button class="btn-primary" onclick="window.location.href='/crm/crm?id=${encodeURIComponent(a.patient_id)}'">
            View
          </button>
        </td>
      </tr>`;
    });
  } catch (err) { console.error('Failed loading appointments', err); }
}

