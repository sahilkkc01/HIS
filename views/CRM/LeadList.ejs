    onclick="window.location.href='/patient-registration?leadId=${encodeURIComponent(c.patient_id)}'">
    Register
  </button>
</td>
        <td>
          <button class="btn-primary" onclick="window.location.href='/crm/crm?id=${encodeURIComponent(c.patient_id)}'">
            View
          </button>
        </td>
      </tr>`;
    });
  } catch (err) { console.error('Failed loading conversions', err); }
