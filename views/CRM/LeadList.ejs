let allLeadsCurrentPage = 1;
let allLeadsTotalPages = 1;
const allLeadsLimit = 50;

async function loadAllLeads(page = 1) {
  try {
    allLeadsCurrentPage = page;

    const qs = buildFilters();
    qs.page = page;
    qs.limit = allLeadsLimit;

    const url = '/crm/getAllLeads?' + queryStringFromObj(qs);
    const res = await axios.get(url);

    const leads = res.data.leads;
    allLeadsTotalPages = res.data.totalPages;

    const tbody = document.querySelector('#allLeadsTable tbody');
    tbody.innerHTML = '';

   leads.forEach(l => {
  tbody.innerHTML += `
    <tr>
      <td>${l.patientId}</td>
      <td>${l.female_name || 'N/A'}</td>
      <td>${l.male_name || 'N/A'}</td>
      <td>${l.primary_mobile || '-'}</td>
      <td>${l.email || '-'}</td>
      <td>${l.lead_date ? new Date(l.lead_date).toLocaleDateString() : '-'}</td>
      <td>${l.status || '-'}</td>
<td>
  <button class="btn btn-sm btn-success"
    onclick="window.location.href='/patient-registration?leadId=${encodeURIComponent(l.patient_id)}'">
    Register
  </button>
</td>
      <td style="text-align:center;">
        ${l.primary_mobile ? `
          <button class="btn btn-sm btn-outline-primary"
            onclick="callPatient('${l.primary_mobile}')">
            <i class="fas fa-phone"></i>
          </button>` : '-'}
      </td>

      <td style="text-align:center;">
        ${l.primary_mobile ? `
          <button class="btn btn-sm"
            style="background:#25D366;color:white;border:none;"
            onclick="whatsappPatient('${l.primary_mobile}')">
            <i class="fab fa-whatsapp"></i>
          </button>` : '-'}
      </td>

      <td>
        <button class="btn btn-sm btn-primary"
          onclick="window.location.href='/crm/crm?id=${encodeURIComponent(l.patientId)}'">
          View
        </button>
      </td>
    </tr>
  `;
});

    renderAllLeadsPagination();

  } catch (err) {
    console.error('Failed loading all leads', err);
  }
}

function renderAllLeadsPagination() {
  const container = document.getElementById('allLeadsPagination');
  container.innerHTML = '';

  if (allLeadsTotalPages <= 1) return;

  // Previous button
  if (allLeadsCurrentPage > 1) {
    container.innerHTML += `
      <button class="btn btn-sm btn-outline-primary"
        onclick="loadAllLeads(${allLeadsCurrentPage - 1})">
        Prev
      </button>
    `;
  }

  // Page numbers (show max 5 around current)
  const start = Math.max(1, allLeadsCurrentPage - 2);
  const end = Math.min(allLeadsTotalPages, allLeadsCurrentPage + 2);

  for (let i = start; i <= end; i++) {
    container.innerHTML += `
      <button class="btn btn-sm ${i === allLeadsCurrentPage ? 'btn-primary' : 'btn-outline-primary'}"
        onclick="loadAllLeads(${i})">
        ${i}
      </button>
    `;
  }

  // Next button
  if (allLeadsCurrentPage < allLeadsTotalPages) {
    container.innerHTML += `
      <button class="btn btn-sm btn-outline-primary"
        onclick="loadAllLeads(${allLeadsCurrentPage + 1})">
        Next
      </button>
    `;
  }
}

/* ----------------- Date filters ----------------- */
function setDateFilter(range) {
  document.querySelectorAll('.date-filters button').forEach(b => b.classList.remove('active'));
  document.getElementById('customStart').value = '';
  document.getElementById('customEnd').value = '';

  const today = new Date();
  let start, end;

  switch(range) {
    case 'today':
      document.getElementById('todayFilter').classList.add('active');
      start = end = today.toISOString().slice(0,10);
      break;
    case 'week':
      document.getElementById('weekFilter').classList.add('active');
      const firstDay = new Date(today);
      firstDay.setDate(today.getDate() - today.getDay());
      start = firstDay.toISOString().slice(0,10);
      end = today.toISOString().slice(0,10);
      break;
    case 'month':
      document.getElementById('monthFilter').classList.add('active');
      const firstOfMonth = new Date(today.getFullYear(), today.getMonth(), 1);
      start = firstOfMonth.toISOString().slice(0,10);
      end = today.toISOString().slice(0,10);
      break;
  }

  if(start && end) {
    document.getElementById('customStart').value = start;
    document.getElementById('customEnd').value = end;
  }

  reloadActiveTab();
}

function applyCustomDate() {
  reloadActiveTab();
}

function reloadActiveTab() {
  const activeTab = document.querySelector('.toggle-btn.active')?.id || 'followupTabBtn';
  switch(activeTab) {
    case 'followupTabBtn': loadFollowUps(); break;
    case 'apptTabBtn': loadAppointments(); break;
    case 'visitedTabBtn': loadVisits(); break;
    case 'convTabBtn': loadConversions(); break;
    case 'allLeadsTabBtn': loadAllLeads(1); break;
  }
}

/* ----------------- Event listeners ----------------- */
// Filter inputs
document.querySelectorAll('#leadIdFilter, #femaleNameFilter, #mobileFilter, #emailFilter').forEach(el => 
  el.addEventListener('input', reloadActiveTab)
);

// Date filters
document.querySelectorAll('#leadDateFilter, #customStart, #customEnd').forEach(el => 
  el.addEventListener('change', applyCustomDate)
);

// Initial load
setDateFilter('today');
showSection('followUp');
</script>

</body>
</html>
