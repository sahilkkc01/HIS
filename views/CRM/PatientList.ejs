<!doctype html>
<html lang="en" class="light-style layout-menu-fixed layout-compact" dir="ltr">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>List of Patients</title>
  <%- include('../header') -%>
</head>

<body>
  <div class="content-wrapper">
    <div class="container-xxl flex-grow-1 container-p-y">
      <div class="card">
        <div class="row card-header flex-column flex-md-row pb-4">
          <div class="d-md-flex justify-content-between align-items-center col-md-auto me-auto mt-0">
            <h5 class="card-title mb-0 text-md-start text-center">All Patients</h5>
          </div>
          <div class="btn-group">
            <input type="search" class="form-control ms-2" id="regNoFilter" placeholder="Reg No">
            <input type="search" class="form-control ms-2" id="nameFilter" placeholder="Name">
            <input type="search" class="form-control ms-2" id="mobileFilter" placeholder="Mobile">
            <input type="search" class="form-control ms-2" id="emailFilter" placeholder="Email">
            <select id="followupFilter" class="form-control ms-2">
              <option value="">Next Follow-up</option>
              <option value="today">Today</option>
              <option value="week">This Week</option>
              <option value="month">This Month</option>
            </select>
            <!-- New freezing due date range filters -->
            <input type="date" class="form-control ms-2" id="freezingFromFilter" placeholder="Freezing From">
            <input type="date" class="form-control ms-2" id="freezingToFilter" placeholder="Freezing To">

            <button id="exportButton" class="btn btn-label-primary">Export</button>
            <button class="btn create-new btn-primary" type="button" onclick="window.location.href = '/addPatient'">+</button>
          </div>
        </div>

        <div class="table-responsive text-nowrap" id="tableContainer">
          <table class="table" id="patientsTable">
            <!-- table head unchanged -->
            <thead>
              <tr>
                <th>ID</th>
                <th>Reg No</th>
                <th>Name</th>
                <th>Primary Mobile</th>
                <th>Email</th>
                      <th>Next Freezing</th>
                      <th>Status</th>
                <th>OPU Date</th>
                <th>Frozen Embryos</th>
                <th>Frozen Eggs</th>
                <th>Remaining Embryos</th>
                <th>Remaining Eggs</th>
          
                <th>Next Follow-up</th>
                <th>Amount Payable</th>
                <th>Created By</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="patientsTbody" class="table-border-bottom-0"></tbody>
          </table>
          <div id="paginationControls" class="mt-3"></div>
        </div>
      </div>
    </div>
  </div>
  <%- include('../footer') -%>

  <script>
    let currentPage = 1;
    const pageSize = 50;
    let currentFilters = {};

    document.addEventListener("DOMContentLoaded", function () {
      loadPatients(currentPage);

      // Attach filter listeners
      const filterIds = [
        'regNoFilter', 'nameFilter', 'mobileFilter', 'emailFilter', 'followupFilter',
        'freezingFromFilter', 'freezingToFilter'  // include new filters
      ];

      filterIds.forEach(id => {
        const el = document.getElementById(id);
        el.addEventListener("input", () => {
          clearTimeout(window.filterTimer);
          window.filterTimer = setTimeout(applyFilters, 300);
        });
        el.addEventListener("change", applyFilters);
      });

      document.getElementById("exportButton").addEventListener("click", function () {
        const rows = document.querySelectorAll("#patientsTable tbody tr");
        if (!rows.length) { alert("No data to export."); return; }
        let csv = "data:text/csv;charset=utf-8,";
        const hdrs = ["ID","Reg No","Name","Primary Mobile","Email","OPU Date",
          "Frozen Embryos","Frozen Eggs","Remaining Embryos","Remaining Eggs",
          "Next Freezing","Next Follow-up","Amount Due","Created By"];
        csv += hdrs.join(",")+"\r\n";
        rows.forEach(r=>{
          const cols = r.querySelectorAll('td');
          let row = [];
          for(let i=0; i<cols.length-1; i++) row.push(`"${cols[i].textContent.trim()}"`);
          csv += row.join(",")+"\r\n";
        });
        const uri = encodeURI(csv);
        const link = document.createElement('a'); link.href=uri; link.download='patients_export.csv';
        document.body.appendChild(link); link.click(); document.body.removeChild(link);
      });
    });

    async function loadPatients(page, filters = {}) {
  try {
    const params = new URLSearchParams({ page, limit: pageSize, ...filters }).toString();
    const response = await axios.get(`/getAllPatients?${params}`);
    const { patients, totalPatients, totalPages } = response.data;

    const tbody = document.getElementById("patientsTbody");
    tbody.innerHTML = "";

    const today    = new Date();
    const todayMid = new Date(today.getFullYear(), today.getMonth(), today.getDate());

    // Helper to format dates as "24 May 2025"
    function formatDate(dateString) {
      if (!dateString) return "N/A";
      const date = new Date(dateString);
      return new Intl.DateTimeFormat("en-GB", {
        day: "2-digit",
        month: "short",
        year: "numeric"
      }).format(date);
    }

    patients.forEach(p => {
      const row = document.createElement("tr");

      // 1️⃣ color by patient status
      if (p.status === "Discarded") {
        row.style.backgroundColor = "rgba(173, 216, 230, 0.5)"; // light blue
      } else if (p.status === "Shifted") {
        row.style.backgroundColor = "rgba(216, 191, 216, 0.5)"; // light violet
      }
      // 2️⃣ else color by next_freezing_due_date
      else if (p.next_freezing_due_date) {
        const fDate   = new Date(p.next_freezing_due_date);
        const fMid    = new Date(fDate.getFullYear(), fDate.getMonth(), fDate.getDate());
        const diffMs  = fMid - todayMid;
        const diffDays= diffMs / (1000 * 60 * 60 * 24);
        if (diffDays < 0) {
          row.style.backgroundColor = "rgba(255, 204, 203, 0.5)"; // light red
        } else if (diffDays <= 30) {
          row.style.backgroundColor = "rgba(255, 246, 205, 0.6)"; // light yellow
        }
      }

      row.innerHTML = `
        <td>${p.id}</td>
        <td>
          <button type="button" class="btn btn-primary p-2" onclick="trackPatient(${p.id})">
            ${p.reg_no} <i class="bx bx-map"></i>
          </button>
        </td>
        <td>${p.patient_name}</td>
        <td>${p.primary_mobile || 'N/A'}</td>
        <td>${p.email || 'N/A'}</td>
        <td>${formatDate(p.next_freezing_due_date)}</td>
   <td>
          ${p.status}
          ${
            p.status === 'Discarded'
              ? `<br/><small>(${formatDate(p.dicard_date)})</small>`
              : p.status === 'Shifted'
                ? `<br/><small>(${formatDate(p.shifted_date)})</small>`
                : ``
          }
        </td>
        <td>${formatDate(p.opu_date)}</td>
        <td>${p.no_of_embryo_frozen}</td>
        <td>${p.no_of_egg_frozen}</td>
        <td>${p.remaining_embryo}</td>
        <td>${p.remaining_egg}</td>
        <td>${formatDate(p.next_followup_date)}</td>
        <td>${p.amount_payable}</td>
        <td>${p.createdBy}</td>
        <td>
          <a class="btn p-0" href="/addPatient?id=${p.id}">
            <i class="bx bx-edit-alt me-1"></i>
          </a>
        </td>
      `;
      tbody.appendChild(row);
    });

    updatePaginationControls(totalPatients, totalPages);
  } catch (error) {
    console.error("Error fetching patients:", error);
  }
}

    function applyFilters() {
      currentFilters = {
        reg_no: document.getElementById('regNoFilter').value.trim(),
        patient_name: document.getElementById('nameFilter').value.trim(),
        primary_mobile: document.getElementById('mobileFilter').value.trim(),
        email: document.getElementById('emailFilter').value.trim(),
        next_followup: document.getElementById('followupFilter').value,
        next_freezing_from: document.getElementById('freezingFromFilter').value,
        next_freezing_to: document.getElementById('freezingToFilter').value
      };
      Object.keys(currentFilters).forEach(k => { if (!currentFilters[k]) delete currentFilters[k]; });
      currentPage = 1;
      loadPatients(currentPage, currentFilters);
    }

    function updatePaginationControls(total, totalPages) {
      const div = document.getElementById('paginationControls');
      div.innerHTML = `<button id="prevPage" class="btn btn-sm btn-outline-secondary me-2" ${currentPage===1?'disabled':''}>Prev</button>`+
                      `Page ${currentPage} of ${totalPages}`+
                      `<button id="nextPage" class="btn btn-sm btn-outline-secondary ms-2" ${currentPage>=totalPages?'disabled':''}>Next</button>`;
      if (currentPage>1) document.getElementById('prevPage').onclick = ()=>{currentPage--; loadPatients(currentPage,currentFilters);};
      if (currentPage<totalPages) document.getElementById('nextPage').onclick = ()=>{currentPage++; loadPatients(currentPage,currentFilters);};
    }

    function trackPatient(id){ window.location.href=`/trackPatient?id=${id}`; }
  </script>
</body>
</html>
