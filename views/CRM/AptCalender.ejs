<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Doctor Calendar</title>

  <!-- Bootstrap (optional) -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- FullCalendar CSS -->
  <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet">

  <style>
    /* body { padding: 18px; } */
    .left-panel { max-width: 280px; }
    .doctor-item { cursor: pointer; padding: 10px; border-bottom: 1px solid #eee; }
    .doctor-item.active { background: #f0f8ff; }
    #calendar { min-height: 700px; }
  </style>
    <%- include('../header') -%>
</head>

<body>
  <div class="container-fluid mt-4" >
    <div class="row g-3">
      <!-- Left: doctor list -->
      <div class="col-md-3 left-panel">
        <div class="card">
         <div class="card-header d-flex justify-content-between align-items-center">
  <strong>Doctors</strong>
  <div>
    <a href="/DocMaster" class="btn btn-sm btn-primary me-2">Add Doctor</a>
    <button id="refreshDoctors" class="btn btn-sm btn-outline-secondary">Refresh</button>
  </div>
</div>

<div class="card-body p-0" id="doctorList">
  <!-- doctor items inserted here -->
  <div class="p-3 text-center text-muted">Loading doctors...</div>
</div>

        </div>
      </div>

      <!-- Right: calendar -->
      <div class="col-md-9">
        <div class="card">
          <div class="card-body">
            <div id="calendar"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Appointment modal -->
 <div class="modal fade" id="apptModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <div>
          <h5 class="modal-title mb-1">Appointment Details</h5>
          <!-- Status badge shown below title -->
          <span id="m_apptStatus" class="badge bg-info text-dark"></span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <div id="apptAlert"></div>

        <div class="row g-2">
          <div class="col-md-6">
            <p><strong>Patient:</strong> <span id="m_patientName"></span></p>
            <p><strong>Patient ID:</strong> <span id="m_patientId"></span></p>
            <p><strong>Phone:</strong> <span id="m_patientPhone"></span></p>
          </div>

          <div class="col-md-6">
            <p><strong>Doctor:</strong> <span id="m_doctorName"></span></p>
            <p><strong>Date:</strong> <span id="m_apptDateTime"></span></p>
            <p><strong>Slot:</strong> <span id="m_apptSlot"></span></p>
          </div>

          <div class="col-12">
            <hr />
            <p><strong>Notes:</strong></p>
            <p id="m_notes" class="small text-muted"></p>
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <button id="cancelApptBtn" class="btn btn-danger me-2">Cancel Booking</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>
<style>
  .ps {
  pointer-events: auto !important;
}

.ps__rail-x,
.ps__rail-y {
  pointer-events: none !important;
}
</style>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

  <!-- FullCalendar (global build) -->
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>

  <!-- Bootstrap JS (optional) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/perfect-scrollbar@1.5.5/dist/perfect-scrollbar.min.js"></script>
  <script>
    (function () {
      let doctors = [];       // cached doctors
      let selectedDoctor = null;
      let calendar = null;
      let currentEvents = []; // cached events
      const doctorListEl = document.getElementById('doctorList');
      const apptModalEl = document.getElementById('apptModal');
      const apptModal = new bootstrap.Modal(apptModalEl);
      let currentEventClicked = null;

      // initialize FullCalendar
      function initCalendar() {
        const calendarEl = document.getElementById('calendar');
        calendar = new FullCalendar.Calendar(calendarEl, {
          initialView: 'dayGridMonth',
          height: 'auto',
          headerToolbar: {
            left: 'prev,next today',
            center: 'title',
            right: 'dayGridMonth,timeGridWeek,timeGridDay'
          },
          events: fetchEventsForCalendar,
          eventClick: function(info) {
            currentEventClicked = info.event;
            openAppointmentModal(info.event.extendedProps.appointmentId);
          }
        });
        calendar.render();
      }

      // Fetch doctors and render left list
      async function loadDoctors() {
        try {
          doctorListEl.innerHTML = '<div class="p-3 text-center text-muted">Loading doctors...</div>';
          const res = await axios.get('/doctors/list'); // backend endpoint
          doctors = res.data.doctors || [];
          if (!doctors.length) {
            doctorListEl.innerHTML = '<div class="p-3 text-center">No doctors found</div>';
            return;
          }

          // render
          doctorListEl.innerHTML = '';
          doctors.forEach((d, idx) => {
            const div = document.createElement('div');
            div.className = 'doctor-item d-flex justify-content-between align-items-center';
            div.dataset.doctorId = d.id;
            div.innerHTML = `<div>
                                <strong>${d.name}</strong><div class="small text-muted">${d.contact || ''}</div>
                              </div>
                              <div class="small text-muted">${d.clinic || ''}</div>`;
            div.addEventListener('click', () => selectDoctor(d.id, div));
            doctorListEl.appendChild(div);

            // auto-select first doctor
            if (idx === 0) {
              selectDoctor(d.id, div);
            }
          });
        } catch (err) {
          console.error('Failed to load doctors', err);
          doctorListEl.innerHTML = '<div class="p-3 text-danger">Failed loading doctors</div>';
        }
      }

      // highlight selected and load calendar events for doctor
      function selectDoctor(doctorId, el) {
        selectedDoctor = doctorId;
        document.querySelectorAll('.doctor-item').forEach(x => x.classList.remove('active'));
        if (el) el.classList.add('active');

        // refetch events on calendar (FullCalendar will call events function)
        calendar.refetchEvents();
      }

      // FullCalendar events fetcher
      // info has startStr / endStr; we pass doctor_id to backend
    async function fetchEventsForCalendar(info, successCallback, failureCallback) {
  try {
    if (!selectedDoctor) {
      successCallback([]); return;
    }
    const res = await axios.get('/crm/appointments', {
      params: {
        doctor_id: selectedDoctor,
        start: info.startStr,
        end: info.endStr
      }
    });

    const appts = res.data.appointments || [];

    currentEvents = appts.map(a => {
      // build start/end by combining date + appt.apptTimeSlot
      // ensure appointment_date is in YYYY-MM-DD (or ISO)
      const parsed = parseSlotToStartEnd(a.appointment_date, a.apptTimeSlot);
      const start = parsed ? parsed.startISO : a.appointment_date; // fallback to date only
      const end = parsed ? parsed.endISO : a.appointment_date;

      // title: patient name or id
      const title = a.patient_name || a.patient_id || 'Appointment';

      return {
        id: String(a.id),
        title,
        start,
        end,
        allDay: false,
        extendedProps: { appointmentId: a.id, raw: a, patient_id: a.patient_id, slot: a.apptTimeSlot }
      };
    });

    successCallback(currentEvents);
  } catch (err) {
    console.error('Failed to fetch appointments', err);
    failureCallback(err);
  }
}

async function openAppointmentModal(appointmentId) {
  try {
    const res = await axios.get(`/crm/leadAppointment/${appointmentId}`);
    const appt = res.data.appointment;
    const lead = res.data.lead || null;

    if (!appt) {
      alert('Appointment not found.');
      return;
    }

    // Status badge
    const statusEl = document.getElementById('m_apptStatus');
    statusEl.textContent = appt.status || 'Unknown';
    statusEl.className = 'badge';
    if (appt.status === 'Scheduled') statusEl.classList.add('bg-primary');
    else if (appt.status === 'Visited') statusEl.classList.add('bg-success');
    else if (appt.status === 'Cancelled') statusEl.classList.add('bg-danger');
    else if (appt.status === 'Rescheduled') statusEl.classList.add('bg-warning', 'text-dark');
    else statusEl.classList.add('bg-secondary');

    // Fill other details
    document.getElementById('m_patientName').textContent =
      lead ? (lead.female_name || lead.male_name || '') : (appt.patient_name || '');
    document.getElementById('m_patientId').textContent = appt.patient_id || '';
    document.getElementById('m_patientPhone').textContent =
      lead ? (lead.primary_mobile || '') : '';
    document.getElementById('m_doctorName').textContent = appt.appointment_doctor || '';
    document.getElementById('m_apptDateTime').textContent =
      new Date(appt.appointment_date).toLocaleDateString();
    document.getElementById('m_apptSlot').textContent = appt.apptTimeSlot || '';
    document.getElementById('m_notes').textContent =
      appt.notes || (lead ? (lead.past_treatments || '') : '');

    // Set current appointment ID on cancel button
    const cancelBtn = document.getElementById('cancelApptBtn');
    cancelBtn.dataset.appointmentId = appointmentId;

    // Make Cancel button clickable only if status is Scheduled
    if (appt.status === 'Scheduled') {
      cancelBtn.disabled = false;
      cancelBtn.classList.remove('btn-secondary');
      cancelBtn.classList.add('btn-danger');
    } else {
      cancelBtn.disabled = true;
      cancelBtn.classList.remove('btn-danger');
      cancelBtn.classList.add('btn-secondary');
    }

    apptModal.show();
  } catch (err) {
    console.error('Failed to load appointment details:', err);
    alert('Failed to load appointment details');
  }
}

// Cancel button handler
document.getElementById('cancelApptBtn').addEventListener('click', async (e) => {
  const id = e.target.dataset.appointmentId;
  if (!id) return;

  if (!confirm('Are you sure you want to cancel this booking?')) return;

  try {
    await axios.patch(`/crm/leadAppointment/${id}/cancel`);
    alert('Booking cancelled successfully');
    apptModal.hide();
  } catch (err) {
    console.error('Failed to cancel booking:', err);
    alert('Failed to cancel booking');
  }
});

function parseSlotToStartEnd(appointmentDate, slot) {
  if (!appointmentDate || !slot) return null;

  // normalize appointmentDate to YYYY-MM-DD
  let dateStr;
  if (appointmentDate instanceof Date) {
    const y = appointmentDate.getFullYear();
    const m = String(appointmentDate.getMonth() + 1).padStart(2, '0');
    const d = String(appointmentDate.getDate()).padStart(2, '0');
    dateStr = `${y}-${m}-${d}`;
  } else {
    // try to extract only YYYY-MM-DD chunk (Sequelize may return ISO datetime)
    dateStr = String(appointmentDate).slice(0,10);
  }

  // normalize slot
  const s = String(slot).trim();
  let startTime = null;
  let endTime = null;

  if (s.includes('-')) {
    // formats like "10:00 - 10:10" or "10:00-10:10"
    const parts = s.split('-').map(p => p.trim());
    startTime = parts[0];
    endTime = parts[1] || null;
  } else {
    // single time like "10:11" -> treat as start, add 10 minutes
    startTime = s;
  }

  // verify startTime has at least HH:mm
  const hhmmRe = /^(\d{1,2}):(\d{2})(?::\d{2})?$/;
  const mStart = hhmmRe.exec(startTime || '');
  if (!mStart) return null;

  // if no explicit end, compute +10 minutes
  if (!endTime) {
    const [hh, mm] = [parseInt(mStart[1], 10), parseInt(mStart[2], 10)];
    const dt = new Date(`${dateStr}T00:00:00`);
    dt.setHours(hh, mm, 0, 0);
    const dtEnd = new Date(dt.getTime() + 10 * 60000); // +10 min
    // format to ISO-ish local (FullCalendar accepts ISO string)
    const startISO = dt.toISOString();
    const endISO = dtEnd.toISOString();
    return { startISO, endISO };
  } else {
    const mEnd = hhmmRe.exec(endTime);
    if (!mEnd) return null;
    const dtStart = new Date(`${dateStr}T${startTime.length === 5 ? startTime : startTime}:00`);
    const dtEnd = new Date(`${dateStr}T${endTime.length === 5 ? endTime : endTime}:00`);
    // if end <= start, add 10 minutes as safe fallback
    if (dtEnd <= dtStart) {
      dtEnd.setTime(dtStart.getTime() + 10 * 60000);
    }
    return { startISO: dtStart.toISOString(), endISO: dtEnd.toISOString() };
  }
}
      // wire refresh button
      document.getElementById('refreshDoctors').addEventListener('click', () => loadDoctors());

      // init
      initCalendar();
      loadDoctors();
    })();
  </script>
</body>
</html>
